global const asset CHALLENGE_REWARD_MODEL = $"mdl/menu/challenge_reward_star/challenge_reward_star.rmdl"
global const asset BATTLEPASS_STAR_REWARD_MODEL = $"mdl/menu/reward_star.rmdl"
global const asset BATTLEPASS_MODEL_BOOST = $"mdl/menu/xp_badge.rmdl"
global const asset BATTLEPASS_MODEL_APEX_COINS = $"mdl/menu/coin.rmdl"
global const asset BATTLEPASS_MODEL_LEVEL_BADGE = $"mdl/menu/bp_badge.rmdl"
global const asset BATTLEPASS_MODEL_CRAFTING_METALS = $"mdl/currency/crafting/currency_crafting_epic.rmdl"
global const float BATTLEPASS_XP_BOOST_AMOUNT = 0.1

const string RECURRING_GRINDLORD_STAT = "stats.challenge_xp_earned"
const string GRINDLORD_CHALLENGE_BAKERY_KEY = "recurringGrindlordChallenge"

const int BATTLEPASS_REWARD_SEQUENCE_QUERYGOAL = GRX_HTTPQUERYGOAL_GIVE_BATTLEPASS_SEQUENCE_REWARD






void function ShBattlePass_LevelInit()
{
	FileStruct_LifetimeLevel newFileLevel
	fileLevel = newFileLevel

	ShBattlePass_RefreshCachedSeasonInfo()


	Remote_RegisterServerFunction( "ClientCallback_UpdateBattlePassLastInfo", "itemflavor", eItemType.battlepass ) 
	Remote_RegisterServerFunction( "ClientCallback_UpdateBattlePassGrantLastSeen", "itemflavor", eItemType.battlepass ) 





















	AddCallback_RegisterRootItemFlavors( void function() {
		foreach ( asset assetData in GetBaseItemFlavorsFromArray("accountPass") )
		{
			ItemFlavor ornull itemFlavorData = RegisterItemFlavorFromSettingsAsset( assetData )
			Assert ( itemFlavorData != null, "Account pass should not be null." )
			fileLevel.accountPass = expect ItemFlavor( itemFlavorData )
			break
		}
	} )

	AddCallback_OnItemFlavorRegistered( eItemType.battlepass, void function( ItemFlavor pass ) {
		if ( !PlayerPass_IsPassOfType( pass, ePassType.SEASONAL ) ) 
		{
			return
		}

		
		
		int sortOrdinal = 0

		fileLevel.battlePassList.append( pass )

		BattlePassData passData
		passData.pass = pass

		var passDataTable                 = BattlePass_GetScheduleDatatable( pass )
		int numRows                       = GetDataTableRowCount( passDataTable )
		int maxLevels                     = GetDataTableInt( passDataTable, numRows - 1, GetDataTableColumnByName( passDataTable, "levelIndex" ) ) + 1
		int cumulativeXP                  = 0
		bool shouldRegisterSubArrayAssets = true

		if ( GetCalEventBeingProcessed() != null )
			shouldRegisterSubArrayAssets = !CalEvent_IsExpired( expect ItemFlavor( GetCalEventBeingProcessed() ) )

		asset passAsset = ItemFlavor_GetAsset( pass )

		
		RegisterItemFlavorFromSettingsAsset( GetGlobalSettingsAsset( passAsset, "xpPurchaseFlav" ) )
		asset xpPurchaseLegendToken = GetGlobalSettingsAsset( passAsset, "bubblePurchaseFlav" )
		if ( xpPurchaseLegendToken != $"" )
			RegisterItemFlavorFromSettingsAsset( xpPurchaseLegendToken )

		if ( shouldRegisterSubArrayAssets )
		{
			RegisterItemFlavorFromSettingsAsset( GetGlobalSettingsAsset( passAsset, "xpBoostFlav" ) )

			asset reroll = GetGlobalSettingsAsset( passAsset, "challengeRerollFlav" )
			if ( reroll != $"" )
				RegisterItemFlavorFromSettingsAsset( reroll )
		}

		passData.maxPassLevel = maxLevels - 1 

		string typeStr = GetGlobalSettingsString( ItemFlavor_GetAsset( pass ), "progressionSystem" )
		Assert( typeStr in eBattlePassProgressionSystem )
		passData.progressionSystem = eBattlePassProgressionSystem[typeStr]
		int xpPerLevel = GetDataTableInt( passDataTable, 0, GetDataTableColumnByName( passDataTable, "xpPerLevel" ) )
		passData.xpPerLevel = GetCurrentPlaylistVarInt( format( "battlepass_%s_xp_per_level", ItemFlavor_GetGUIDString( pass ) ), xpPerLevel )












		passData.challenges[ eChallengeTimeSpanKind.SEASON_WEEKLY_RECURRING ] <- {}
		passData.challenges[ eChallengeTimeSpanKind.SEASON_WEEKLY_RECURRING ][-1] <- []
		if ( shouldRegisterSubArrayAssets && passData.progressionSystem == eBattlePassProgressionSystem.STARS )
		{
			asset chAsset = GetGlobalSettingsAsset( passAsset, GRINDLORD_CHALLENGE_BAKERY_KEY )
			Assert( chAsset != $"" )
			ItemFlavor challenge = expect ItemFlavor( RegisterItemFlavorFromSettingsAsset( chAsset ) )
			passData.challenges[ eChallengeTimeSpanKind.SEASON_WEEKLY_RECURRING ][-1].append( challenge )
			Assert( Challenge_GetStatRefs( null, challenge, 0 )[0] == RECURRING_GRINDLORD_STAT )
			passData.recurringGrindlordChallenge = challenge
		}

		array<asset> dupeCheck = []

		passData.challenges[ eChallengeTimeSpanKind.DAILY ] <- {}
		passData.challenges[ eChallengeTimeSpanKind.DAILY ][-1] <- []
		if ( shouldRegisterSubArrayAssets)
		{
			foreach ( var block in IterateSettingsAssetArray( passAsset, "dailyChallenges" ) )
			{
				asset chAsset = GetSettingsBlockAsset( block, "flavor" )

				Assert( !dupeCheck.contains( chAsset ) )
				dupeCheck.append( chAsset )

				ItemFlavor ornull challenge = RegisterItemFlavorFromSettingsAsset( chAsset )
				if ( challenge != null )
					passData.challenges[ eChallengeTimeSpanKind.DAILY ][-1].append( expect ItemFlavor( challenge ) )
			}
		}

		dupeCheck.clear()

		passData.challenges[ eChallengeTimeSpanKind.SEASON_WEEKLY ] <- {}
		if ( shouldRegisterSubArrayAssets )
		{
			foreach ( var block in IterateSettingsAssetArray( passAsset, "weeklyChallenges" ) )
			{
				int week = GetSettingsBlockInt( block, "weekNumber" )
				passData.challenges[ eChallengeTimeSpanKind.SEASON_WEEKLY ][week] <- []
				foreach ( var chBlock in IterateSettingsArray( GetSettingsBlockArray( block, "challenges" ) ) )
				{
					asset chAsset = GetSettingsBlockAsset( chBlock, "flavor" )

					Assert( !dupeCheck.contains( chAsset ) )
					dupeCheck.append( chAsset )

					ItemFlavor ornull challenge = RegisterItemFlavorFromSettingsAsset( chAsset )
					if ( challenge != null )
					{
						expect ItemFlavor( challenge )
						RegisterChallengeSource( challenge, pass, sortOrdinal++ )
						passData.challenges[ eChallengeTimeSpanKind.SEASON_WEEKLY ][week].append( challenge )
					}
				}
			}
		}

		dupeCheck.clear()

		if ( BattlePassV2_IsV2BattlePass( pass ) )
		{
			asset ultimateOwnershipAsset = BattlePassV2_GetUltimateOwnershipAsset( pass )
			if ( ultimateOwnershipAsset != $"" )
			{
				ItemFlavor ornull ultimateOwnershipFlav = RegisterItemFlavorFromSettingsAsset( ultimateOwnershipAsset )

				if ( ultimateOwnershipFlav != null )
				{
					expect ItemFlavor( ultimateOwnershipFlav )
					passData.ultimateOwnershipFlav = ultimateOwnershipFlav
				}
			}

			asset ultimatePlusOwnershipAsset = BattlePassV2_GetUltimatePlusOwnershipAsset( pass )
			if ( ultimatePlusOwnershipAsset != $"" )
			{
				ItemFlavor ornull ultimatePlusOwnershipFlav = RegisterItemFlavorFromSettingsAsset( ultimatePlusOwnershipAsset )

				if ( ultimatePlusOwnershipFlav != null )
				{
					expect ItemFlavor( ultimatePlusOwnershipFlav )
					passData.ultimatePlusOwnershipFlav = ultimatePlusOwnershipFlav
				}
			}
		}

		if ( shouldRegisterSubArrayAssets )
		{
			RegisterReferencedItemFlavorsFromArray( pass, "challengeTiles", "challengeTile" )
		}

		fileLevel.battlePassMap[pass] <- passData
	} )


















}

int function GetMaxBattlePassLevelIndex( var passDataTable )
{
	int numRows = GetDataTableRowCount( passDatr flav )
{
	Assert( ItemFlavor_GetType( flav ) == eItemType.battlepass )
	Assert( BattlePassV2_IsV2BattlePass( flav ) )
	Assert( "bpv2StartUnixTime" in flav.metaData )

	if ( "bpv2StartUnixTime" in flav.metaData )
	{
		table< string, string > ornull metaData = flav.metaData
		expect table< string, string >( metaData )

		return int( metaData[ "bpv2StartUnixTime" ] )
	}

	Warning( "BPV2 asset (%s) did not have bpv2StartUnixTime defined; returning fallback", ItemFlavor_GetAssetString( flav ) )
	return UNIX_TIME_FALLBACK_1970
}

int function BattlePassV2_GetFinishUnixTime( ItemFlavor flav )
{
	Assert( ItemFlavor_GetType( flav ) == eItemType.battlepass )
	Assert( BattlePassV2_IsV2BattlePass( flav ) )
	Assert( "bpv2FinishUnixTime" in flav.metaData )

	if ( "bpv2FinishUnixTime" in flav.metaData )
	{
		table< string, string > ornull metaData = flav.metaData
		expect table< string, string >( metaData )

		return int( metaData[ "bpv2FinishUnixTime" ] )
	}

	Warning( "BPV2 asset (%s) did not have bpv2FinishUnixTime defined; returning fallback", ItemFlavor_GetAssetString( flav ) )
	return UNIX_TIME_FALLBACK_2038
}


