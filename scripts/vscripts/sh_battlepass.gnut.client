void function MilestoneEvents_Init()
{









}





ItemFlavor ornull function GetActiveMilestoneEvent( int t )
{
	Assert( IsItemFlavorRegistrationFinished() )
	if ( fileLevel.storeOnlyEvents )
	{
		array<ItemFlavor> activeStoreOnlyMilestoneEvents = GetActiveStoreOnlyMilestoneEvents( t )
		if ( activeStoreOnlyMilestoneEvents.len() > 0 )
		{
			ItemFlavor ornull event = activeStoreOnlyMilestoneEvents[0]
			return event
		}
		else
			return null
	}
	else
	{
		return GetActiveEventTabMilestoneEvent( t )
	}

	unreachable
}










ItemFlavor ornull function GetActiveEventTabMilestoneEvent( int t )
{
	Assert( IsItemFlavorRegistrationFinished() )
	ItemFlavor ornull event = null
	foreach ( ItemFlavor ev in GetAllItemFlavorsOfType( eItemType.calevent_milestone ) )
	{
		if ( !CalEvent_IsActive( ev, t ) )
			continue

		bool isStoreOnly = GetGlobalSettingsBool( ItemFlavor_GetAsset( ev ), "isStoreOnlyMilestoneEvent" )
		if ( isStoreOnly )
			continue

		Assert( event == null, format( "Multiple collection events are active!! (%s, %s)", string(ItemFlavor_GetAsset( expect ItemFlavor(event) )), string(ItemFlavor_GetAsset( ev )) ) )
		event = ev
	}
	return event
}



array<ItemFlavor> function GetActiveStoreOnlyMilestoneEvents( int t )
{
	Assert( IsItemFlavorRegistrationFinished() )
	array<ItemFlavor> activeStoreOnlyMilestoneEvents
	foreach ( ItemFlavor ev in GetAllItemFlavorsOfType( eItemType.calevent_milestone ) )
	{
		if ( !CalEvent_IsActive( ev, t ) )
			continue

		bool isStoreOnly = GetGlobalSettingsBool( ItemFlavor_GetAsset( ev ), "isStoreOnlyMilestoneEvent" )
		if ( !isStoreOnly )
			continue

		activeStoreOnlyMilestoneEvents.append( ev )
	}
	return activeStoreOnlyMilestoneEvents
}



array<ItemFlavor> function GetAllMilestoneEvents( bool includeEventTab = true, bool includeStoreOnly = false )
{
	Assert( IsItemFlavorRegistrationFinished() )
	array<ItemFlavor> storeOnlyMilestoneEvents
	foreach ( ItemFlavor ev in GetAllItemFlavorsOfType( eItemType.calevent_milestone ) )
	{
		bool isStoreOnly = GetGlobalSettingsBool( ItemFlavor_GetAsset( ev ), "isStoreOnlyMilestoneEvent" )

		if ( !includeEventTab && !isStoreOnly )
			continue

		if ( !includeStoreOnly && isStoreOnly )
			continue

		storeOnlyMilestoneEvents.append( ev )
	}
	return storeOnlyMilestoneEvents
}



bool function IsMilestoneEventStoreOnly( ItemFlavor ornull event )
{
	if ( event == null )
		return false

	expect ItemFlavor( event )

	Assert( IsItemFlavorRegistrationFinished() )
	Assert( ItemFlavor_GetType( event ) == eItemType.calevent_milestone )
	return GetGlobalSettingsBool( ItemFlavor_GetAsset( event ), "isStoreOnlyMilestoneEvent" )
}



array<ItemFlavor> function GetAllActiveMilestoneEvents( int t )
{
	Assert( IsItemFlavorRegistrationFinished() )
	array<ItemFlavor> activeMilestoneEvents

	ItemFlavor ornull activeEvent = GetActiveEventTabMilestoneEvent( t )
	if ( activeEvent != null )
	{
		expect ItemFlavor( activeEvent )
		activeMilestoneEvents.append( activeEvent )
	}

	foreach ( ItemFlavor event in GetActiveStoreOnlyMilestoneEvents( t ) )
	{
		activeMilestoneEvents.append( event )
	}

	return activeMilestoneEvents
}



MilestoneEventRewardTrackerData function GetRewardTrackerDataFor( ItemFlavor event, bool isRestricted )
{
	Assert( ItemFlavor_GetType( event ) == eItemType.calevent_milestone )
	if ( event in fileLevel.rewardTrackerTierData )
	{
		return fileLevel.rewardTrackerTierData[ event ]
	}

	
	MilestoneEventRewardTrackerData data
	string rewardPath = isRestricted ? "restrictedRewardGroups" : "rewardGroups"
	foreach ( var groupBlock in IterateSettingsAssetArray( ItemFlavor_GetAsset( event ), rewardPath ) )
	{
		MilestoneEventRewardTrackerTierData tierData
		foreach ( var rewardBlock in IterateSettingsArray( GetSettingsBlockArray( groupBlock, "rewards" ) ) )
		{
			if ( GetSettingsBlockBool( rewardBlock, "useRewardSetTracker" ) )
			{
				tierData.useRewardSetTracker = true
				asset trackerAsset = GetSettingsBlockAsset( rewardBlock, "flavor" )
				tierData.rewardSetTracker = GetItemFlavorByAsset( trackerAsset )
				tierData.quantity = GetSettingsBlockInt( rewardBlock, "rewardSetTrackerCount" )
				break
			}
			else
			{
				tierData.useRewardSetTracker = false
			}
		}

		int rarity = eRarityTier[ GetSettingsBlockString( groupBlock, "quality" ) ]
		data[ rarity ] <- tierData
	}

	fileLevel.rewardTrackerTierData[ event ] <- data
	return data
}



MilestoneEventRewardTrackerTierData function GetRewardTrackerTierDataFor( ItemFlavor event, int rarity, bool isRestricted )
{
	Assert( ItemFlavor_GetType( event ) == eItemType.calevent_milestone )
	MilestoneEventRewardTrackerData data = GetRewardTrackerDataFor( event, isRestricted )

	Assert( rarity in data, format( "No rarity tier %d defined for milestone event %s", rarity, ItemFlavor_GetAssetString( event ) ) )

	return data[ rarity ]
}



bool function MilestoneEvent_HasRewardSetTracker( ItemFlavor event, int rarity, bool isRestricted )
{
	Assert( ItemFlavor_GetType( event ) == eItemType.calevent_milestone )
	MilestoneEventRewardTrackerData data = GetRewardTrackerDataFor( event, isRestricted )

	if ( rarity in data )
	{
		return data[ rarity ].useRewardSetTracker
	}

	return false
}



ItemFlavor function MilestoneEvent_GetRewardTracker( ItemFlavor event, int rarity, bool isRestricted )
{
	Assert( ItemFlavor_GetType( event ) == eItemType.calevent_milestone )
	MilestoneEventRewardTrackerTierData config = GetRewardTrackerTierDataFor( event, rarity, isRestricted )

	return config.rewardSetTracker
}



int function MilestoneEvent_GetRewardTrackerQuantityForTier( ItemFlavor event, int rarity, bool isRestricted )
{
	Assert( ItemFlavor_GetType( event ) == eItemType.calevent_milestone )
	MilestoneEventRewardTrackerTierData config = GetRewardTrackerTierDataFor( event, rarity, isRestricted )

	return config.quantity
}



int function MilestoneEvent_GetTotalItemsInPoolIncludingTrackerTiers( ItemFlavor event, bool isRestricted )
{
	Assert( ItemFlavor_GetType( event ) == eItemType.calevent_milestone )
	MilestoneEventRewardTrackerData data = GetRewardTrackerDataFor( event, isRestricted )

	int count = 0
	array<CollectionEventRewardGroup> rewardGroups = MilestoneEvent_GetRewardGroups( event, isRestricted )
	foreach ( CollectionEventRewardGroup rewardGroup in rewardGroups )
	{
		if ( MilestoneEvent_HasRewardSetTracker( event, rewardGroup.quality, isRestricted ) )
		{
			count += data[ rewardGroup.quality ].quantity
		}
		else
		{
			count += rewardGroup.rewards.len()
		}
	}

	return count
}



int function MilestoneEvent_GetProgressBasedOnRewardSetTrackerForTier( entity player, ItemFlavor event, int rarity, bool isRestricted )
{
	Assert( ItemFlavor_GetType( event ) == eItemType.calevent_milestone )

	if ( MilestoneEvent_HasRewardSetTracker( event, rarity, isRestricted ) )
	{
		ItemFlavor rewardSetTracker = MilestoneEvent_GetRewardTracker( event, rarity, isRestricted )




			int count = GRX_GetConsumableCount( ItemFlavor_GetGRXIndex( rewardSetTracker ) )


		return maxint( 0, count )
	}

	return 0
}



table< int, array< ItemFlavor > > function MilestoneEvent_SplitItemPoolIntoRarities( array< ItemFlavor > items )
{
	table< int, array< ItemFlavor > > sorted
	foreach ( string _, int rarity in eRarityTier )
	{
		sorted[ rarity ] <- []
	}

	foreach ( ItemFlavor item in items )
	{
		int tier = ItemFlavor_GetQuality( item )
		sorted[ tier ].append( item )
	}

	return sorted
}



int function MilestoneEvent_GetProgressBasedOnRewardSetTracker( entity player, ItemFlavor event, bool isRestricted )
{
	Assert( ItemFlavor_GetType( event ) == eItemType.calevent_milestone )

	int progress = 0
	array< ItemFlavor > items = MilestoneEvent_GetEventItems( event, isRestricted )
	table< int, array< ItemFlavor > > poolItems = MilestoneEvent_SplitItemPoolIntoRarities( items )

	foreach ( string _, int rarity in eRarityTier )
	{
		if ( MilestoneEvent_HasRewardSetTracker( event, rarity, isRestricted ) )
		{
			progress += MilestoneEvent_GetProgressBasedOnRewardSetTrackerForTier( player, event, rarity, isRestricted )
		}
		else
		{
			progress += GRX_GetNumberOfOwnedItemsByPlayer( poolItems[ rarity ], player )
		}
	}

	return progress
}



string function MilestoneEvent_GetEventId( ItemFlavor event )
{
	Assert( ItemFlavor_GetType( event ) == eItemType.calevent_milestone )
	return ItemFlavor_GetGUIDString( event )
}



ItemFlavor ornull function MilestoneEvent_GetEventById( string id, bool activeOnly = false )
{
	Assert( IsItemFlavorRegistrationFinished() )
	Assert( id != "" )
	ItemFlavor ornull event = null
	int unixTimeNow = GetUnixTimestamp()
	foreach ( ItemFlavor ev in GetAllItemFlavorsOfType( eItemType.calevent_milestone ) )
	{
		if ( activeOnly && !CalEvent_IsActive( ev, unixTimeNow ) )
			continue

		if ( MilestoneEvent_GetEventId( ev ) == id )
			return ev
	}
	return null
}



bool function MilestoneEvent_IsEventStoreOnly(  ItemFlavor event )
{
	Assert( ItemFlavor_GetType( event ) == eItemType.calevent_milestone )
	return GetGlobalSettingsBool( ItemFlavor_GetAsset( event ), "isStoreOnlyMilestoneEvent" )
}



array<ItemFlavor> function MilestoneEvent_GetLoginRewards( ItemFlavor event )
{
	Assert( ItemFlavor_GetType( event ) == eItemType.calevent_milestone )

	array<ItemFlavor> rewards = []
	foreach ( var rewardBlock in IterateSettingsAssetArray( ItemFlavor_GetAsset( event ), "loginRewards" ) )
	{
		asset rewardAsset = GetSettingsBlockAsset( rewardBlock, "flavor" )
		if ( IsValidItemFlavorSettingsAsset( rewardAsset ) )
			rewards.append( GetItemFlavorByAsset( rewardAsset ) )
	}
	return rewards
}



