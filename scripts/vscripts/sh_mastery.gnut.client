void function StatsArraysShrinkToFit()
{
	
	fileLevel.stats_Int.shrinktofit()
	fileLevel.allStats.shrinktofit()
#if DEV
		foreach ( StatTemplate stat in fileLevel.rootFieldsList.childStatTemplates )
		{
			stat.allEntries.shrinktofit()
		}
#endif
}


array<int> function Stats_GetGameModesFromBitfield( int modeBitfield )
{
	array<int> out = []

	foreach ( int entry in eChallengeGameMode )
	{
		if ( IsBitFlagSet( modeBitfield, entry ) )
		{
			out.append( entry )
		}
	}

	return out
}



int function Stats_GetModeBitfieldForGameModes( array<int> modes )
{
	int bitField

	foreach ( int mode in modes )
	{
		bitField = SetBitFlag( bitField, mode )
	}

	
	

	return bitField
}








































































































































































































































































