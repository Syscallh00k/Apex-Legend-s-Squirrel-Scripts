void function ShCaptureRoom_LevelInit()
{

		PrecacheModel( CAPTURE_ROOM_LIGHTING_RIG_MODEL )



		AddCallback_EntitiesDidLoad( EntitiesDidLoad )

		RegisterSignal( "CaptureRoomAvailable" )

