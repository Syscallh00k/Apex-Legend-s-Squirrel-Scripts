bool function IsCaptureRoomAvailable()
{
	foreach( CaptureRoom room in file.roomList )
	{
		if ( !room.inUse )
			return true
	}
	return false
}




CaptureRoom ornull function TryReserveCaptureRoom()
{
	foreach( int roomIndex, CaptureRoom room in file.roomList )
	{
		if ( room.inUse )
			continue

		room.inUse = true

		return room
	}

	return null
}




CaptureRoom function ReserveCaptureRoom()
{
	CaptureRoom ornull captureRoom = TryReserveCaptureRoom()
	Assert( captureRoom != null, "No free Scene capture rooms." )
	expect CaptureRoom( captureRoom )
	return captureRoom
}




CaptureRoom function WaitForReserveCaptureRoom()
{
	
	
	
	while( true )
	{
		foreach( int roomIndex, CaptureRoom room in file.roomList )
		{
			if ( room.inUse )
				continue

			room.inUse = true

			return room
		}
		WaitSignal( file.signalDummy, "CaptureRoomAvailable" )
	}

	unreachable
}




void function ReleaseCaptureRoom( CaptureRoom room )
{
	Assert( room.inUse, "Attempted to end release a Scene capture room that was not in use." )

#if DEV
		foreach( entity light in room.tweakLights )
			Assert( IsValerbose( state.key, format( "%s = %s", attachmentName, string( lightOrigin ) ) )
	}
}

void function TryPlayLightingRigAnimSeq( ClientPIPSceneState state )
{
	if ( state.captureRoom == null )
		return

	if ( state.lightingRig == null )
		return

	if ( state.lightingRigAnimSeq == "" )
		return

	if ( !state.lightingRig.Anim_HasSequence( state.lightingRigAnimSeq ) )
		return

	state.lightingRig.Anim_Play( state.lightingRigAnimSeq )

	SetTweakLightOriginAngles( state )
}



