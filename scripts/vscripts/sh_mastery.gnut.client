const string SHOW_LOADING_HINTS_PVAR = "show_loading_hints"
const int MAX_HINT_COUNT = 3	


struct LoadingScreenHint
{
	string title = ""
	string description = ""
	asset image = $""

	var nestedHintRui
}


struct
{

		var                             loadingHintsGroupRui
		table< int, LoadingScreenHint > loadingScreenHints

} file



void function ClLoadingHints_Init()
{
	AddCallback_GameStateEnter( eGameState.Playing, LoadingScreenHints_OnPlaying )
	AddCallback_OnControllerModeChanged( LoadingScreenHints_OnControllerModeChanged )

	LoadingScreenHints_CreateHintsForMode()
}

bool function LoadingScreenHints_ShowLoadingHintsForMode()
{
	return IsFullyConnected() && GetCurrentPlaylistVarBool( SHOW_LOADING_HINTS_PVAR, false )
}

void function LoadingScreenHints_CreateHintsForMode()
{
	if ( IsLobby() )
		return

	
	thread LoadingScreenHints_CreateHintsForMode_Thread()
}

void function LoadingScreenHints_CreateHintsForMode_Thread()
{
	AssertIsNewThread()

	while ( !IsFullyConnected() )
	{
		WaitFrame()
	}

	if ( !LoadingScreenHints_ShowLoadingHintsForMode() )
		return

	if ( GetGameState() >= eGameState.Playing )
		return

	asset loadingHintsHud = LoadingScreenHints_GetHintsGroupAsset()
	if ( loadingHintsHud != $"" )
	{
		file.loadingHintsGroupRui = CreatePermanentCockpitPostFXRui( loadingHintsHud, MINIMAP_Z_BASE + 1 )
		RunUIScript( "LoadingScreenHints_ClientToUI_GetHintsData" )
	}
}

void function LoadingScreenHints_OnPlaying()
{
	LoadingScreenHints_DestroyHints()
}

void function LoadingScreenHints_DestroyHints()
{
	if ( file.loadingHintsGroupRui != null )
		RuiDestroyIfAlive( file.loadingHintsGroupRui )

	file.loadingHintsGroupRui = null
	file.loadingScreenHints.clear()

	RemoveCallback_OnControllerModeChanged( LoadingScreenHints_OnControllerModeChanged )
}

asset function LoadingScreenHints_GetHintsGroupAsset()
{
	return $"ui/loading_hints_group.rpak"
}

asset function LoadingScreenHints_GetHintAsset()
{
	return $"ui/loading_hint_widget.rpak"
}


void function LoadingScreenHints_UIToClient_UpdateHintsRui( int index, string title, string description, asset image )
{
	if ( index in file.loadingScreenHints )
	{
		file.loadingScreenHints[ index ].title = title
		file.loadingScreenHints[ index ].description = description
		file.loadingScreenHints[ index ].image = image
	}
	else
	{
		LoadingScreenHint hint
		hint.title = title
		hint.description = description
		hint.image = image
		file.loadingScreenHints[index] <- hint
	}

	LoadingScreenHints_CreateOrUpdateHintRui( index, file.loadingScreenHints[ index ] )
}

void function LoadingScreenHints_CreateOrUpdateHintRui( int index, LoadingScreenHint hint )
{
	
	if ( file.loadingHintsGroupRui == null || !RuiIsAlive( file.loadingHintsGroupRui ) )
		return

	asset loadingHintAsset = LoadingScreenHints_GetHintAsset()
	if ( hint.nestedHintRui == null || !RuiIsAlive( hint.nestedHintRui ) )
	{
		hint.nestedHintRui = RuiCreateNested( file.loadingHintsGroupRui, "hint" + index + "Handle", loadingHintAsset )
	}

	RuiSetString( hint.nestedHintRui, "title", hint.title )
	RuiSetString( hint.nestedHintRui, "description", hint.description )
	RuiSetImage( hint.nestedHintRui, "hintImage", hint.image )
}

void function LoadingScreenHints_OnControllerModeChanged( bool isControllerMode )
{
	RunUIScript( "LoadingScreenHints_ClientToUI_GetHintsData" )
}












































