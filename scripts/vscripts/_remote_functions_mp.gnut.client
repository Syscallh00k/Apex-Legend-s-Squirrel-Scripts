	RegisterNetworkedVariable( "roundEndTime", SNDC_GLOBAL_NON_REWIND, SNVT_TIME, 0.0 )
	RegisterNetworkedVariable( "roundsPlayed", SNDC_GLOBAL_NON_REWIND, SNVT_INT, 0 )

