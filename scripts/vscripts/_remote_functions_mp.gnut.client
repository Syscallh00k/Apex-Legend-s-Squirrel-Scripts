				RegisterNetworkedVariable( ABANDONMENT_DID_PLAYER_HAVE_FULL_TEAM, SNDC_PLAYER_GLOBAL, SNVT_BOOL, false )

			bool shouldRegisterRankedVars = GameModeVariant_IsActive( eGameModeVariants.SURVIVAL_RANKED )


			if( GameMode_IsActive( eGameModes.ARENAS ) && GameModeVariant_IsActive( eGameModeVariants.ARENAS_RANKED ) )
