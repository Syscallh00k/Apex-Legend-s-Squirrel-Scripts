struct
{





		array< void functionref( int, int ) > boardDeniedCallbacks  







} file

void function Sh_EvacShip_Init()
{












	RegisterSignal( "ForceEarlyDeparture" )

	Remote_RegisterClientFunction( "EvacShip_ServerCallback_BoardingDenied", "int", 0, eEvacBoardDenied._count, "int", 0, INT_MAX )
	Remote_RegisterClientFunction( "ServerCallback_PromptSayGetOnTheDropship" )



















}

















































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































string function EvacShip_GetBoardDeniedHint( int reason )
{
	switch ( reason )
	{
		case eEvacBoardDenied.SHIP_FULL:            return "#EVAC_SHIP_FULL_HINT"
		case eEvacBoardDenied.ZONE_HOLD_INCOMPLETE:  return "#EVAC_STAND_BY_HINT"
		case eEvacBoardDenied.CUSTOM_CHECK_FAILED:   return "#EVAC_BOARD_DENIED_HINT"
		case eEvacBoardDenied.NO_SEATS:              return "#EVAC_SHIP_FULL_HINT"
	}

	return ""
}



























void function EvacShip_AddBoardDeniedCallback( void functionref( int, int ) callback )
{
	file.boardDeniedCallbacks.append( callback )
}

void function EvacShip_ServerCallback_BoardingDenied( int reason, int subReason )
{
	string locKey = EvacShip_GetBoardDeniedHint( reason )
	if ( locKey != "" )
		AddPlayerHint( EVACSHIP_ANNOUNCEMENT_DURATION, 0.5, $"", Localize( locKey ) )

	foreach ( void functionref( int, int ) callback in file.boardDeniedCallbacks )
		callback( reason, subReason )
}














































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































































