void function EvoWeapons_UpdateRuiForEvoWeapons( entity player, entity weapon, var rui )
{
	if ( !RuiIsAlive( rui ) )
		return

	int expTotal         = -1
	int expTierThreshold = -1
	bool isPastMaxTier   = false
	bool isMaxTier       = false
	bool allMaxTier      = false
	bool shouldDisplayExpUI = !ShouldUseLockedWeaponSlingLayout( player )

	if ( IsValid( weapon ) )
	{
		LootData lootData = SURVIVAL_GetLootDataFromWeapon( weapon )
		int tier = lootData.tier

		isMaxTier     = (tier == tunings.maxWeaponTier)
		isPastMaxTier = (tier > tunings.maxWeaponTier)
		allMaxTier    = EvoWeapon_DoesPlayerHaveAllMaxTierWeapons( player )

		bool hideXP = ( allMaxTier && isMaxTier ) || ( tier == eLootTier.MYTHIC && !allMaxTier )

		if ( !hideXP )
		{
			int evoXp         = EvoWeapons_GetEvoWeaponPoints( weapon )
			expTierThreshold  = EvoWeapons_GetRequirementForEvolution( tier, lootData )

			int currentTierExp = expTierThreshold - evoXp
			expTotal = isMaxTier ? expTierThreshold : currentTierExp
		}
	}

	RuiSetInt( rui, "expTotal", expTotal )
	RuiSetInt( rui, "expTierThreshold", expTierThreshold )
	RuiSetBool( rui, "isPastMaxTier", isPastMaxTier )
	RuiSetBool( rui, "allMaxTier", allMaxTier )
	RuiSetBool( rui, "isMaxTier", isMaxTier )
	RuiSetBool( rui, "shouldDisplayExpUI", shouldDisplayExpUI )
}

void function HideEvoRuiDuringWeaponInspect( bool inspect )
{
	RuiSetBool( file.evoWeaponRui, "weaponInspect", inspect )
}



void function EvoWeapons_SetForceVisible( bool forceVisible )
{
	if ( !RuiIsAlive( file.evoWeaponRui ) )
		return

	if ( forceVisible )
	{
		entity player = GetLocalViewPlayer()
		entity weapon = IsValid( player ) ? player.GetPlayerNetEnt( EVO_WEAPON_NETVAR ) : null
		RuiSetBool( file.evoWeaponRui, "shouldDisplayExpUI", !ShouldUseLockedWeaponSlingLayout( player ) )
		RuiSetBool( file.evoWeaponRui, "weaponInspect", false )
	}
}



