struct{















	var evoWeaponRui
	table< entity, array<int> > playerWeaponUpgradesToDisplay

}file

struct Tuning
{
	int damageThresholdZero		= 100
	int damageThresholdOne		= 150
	int damageThresholdTwo		= 225
	int damageThresholdThree	= 275
	int damageThresholdFour		= 350
	int maxWeaponTier			= 5
	int maxOverflow 			= 0

	bool otherWeaponsGivePartial = true
	float partialPercentGain	= 0.25
	float respawnPercentToGive	= 0.5

	bool shouldDroppedWeaponUpgradeIfAble = true
	bool slingWeaponAllowed = false
	float evoWeaponMessageDuration = 2.0

	bool shareEvoAtAllMaxTier	= true
	bool allowOverflowEvo 		= true
	bool allowTierSkips 		= true
}
Tuning tunings

void function EvoWeapons_Init()
{
	EvoWeapons_InitTuningValues()

	if ( !EvoWeapons_IsEnabled() )
		return


		
		if ( DormantHopups_IsEnabled() )
			return



	RegisterNetworkedVariable( EVO_WEAPON_XP_NETVAR, SNDC_PLAYER_EXCLUSIVE, SNVT_BIG_INT, 0 )
	RegisterNetworkedVariable( EVO_WEAPON_XP_OVERFLOW_NETVAR, SNDC_PLAYER_EXCLUSIVE, SNVT_BIG_INT, 0 )
	RegisterNetworkedVariable( EVO_WEAPON_TIER_NETVAR, SNDC_PLAYER_EXCLUSIVE, SNVT_UNSIGNED_INT, 0 )
	RegisterNetworkedVariable( EVO_WEAPON_NETVAR, SNDC_PLAYER_EXCLUSIVE, SNVT_ENTITY )
	RegisterNetworkedVariable( EVO_WEAPON_EQUIPPED_NETVAR, SNDC_PLAYER_EXCLUSIVE, SNVT_BOOL, false )

	Remote_RegisterClientFunction( "ServerCallback_EvoWeapons_UpdatePlayerExpHUDWeaponEvo", "bool", "bool" )
	Remote_RegisterClientFunction( "ServerCallback_EvoWeapon_WeaponUpgraded", "int", -1, 1023, "bool" )

	RegisterSignal( EVO_WEAPON_XP_CHANGED_SIGNAL )














	AddCallback_OnClientScriptInit( EvoWeapons_Init_Client )
	RegisterNetVarEntityChangeCallback( EVO_WEAPON_NETVAR, EvoWeaponEntityChanged )
	RegisterNetVarIntChangeCallback( EVO_WEAPON_XP_NETVAR, EvoWeaponXpChanged )
	if ( tunings.allowOverflowEvo )
	{
		RegisterNetVarIntChangeCallback( EVO_WEAPON_XP_OVERFLOW_NETVAR, EvoWeaponXpChanged )
	}
	RegisterNetVarIntChangeCallback( EVO_WEAPON_TIER_NETVAR, EvoWeaponXpChanged )
	AddCallback_OnSelectedWeaponChanged( EvoWeapons_OnSelectedWeaponChanged )

	RegisterSignal( "EvoWeapons_StopWeaponEvoHints" )

	AddCallback_OnInventoryOpened( EvoWeapons_OnInventoryOpened )

}

