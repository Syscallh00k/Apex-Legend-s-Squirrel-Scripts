int function EvoWeapons_GetRequirementForEvolution( int tier, LootData weaponData )
{
	switch ( tier )
	{
		case 0:
			return tunings.damageThresholdZero

		case 1:
			return tunings.damageThresholdOne

		case 2:
			return tunings.damageThresholdTwo

		case 3:
			return tunings.damageThresholdThree

		case 4:
			return tunings.damageThresholdFour

		default:
			return 0
	}

	return 0
}


bool function EvoWeapons_IsActiveWeaponUnHolstered( entity player )
{
	if ( !IsValid( player ) )
		return false

	entity primaryWeapon = player.GetActiveWeapon( eActiveInventorySlot.mainHand )
	return primaryWeapon != null && IsValid( primaryWeapon ) && primaryWeapon.GetWeaponTypeFlags() == WPT_PRIMARY
}

int function EvoWeapons_GetEvoWeaponPoints( entity weapon )
{
	if( !EvoWeapons_IsEnabled() )
		return EVO_WEAPON_XP_DISABLED

	return weapon.GetEvoWeaponPoints()
}

bool function EvoWeapon_DoesPlayerHaveAllMaxTierWeapons( entity player )
{
	array<entity> equippedWeapons = EvoWeapon_GetPlayerWeapons( player )
	bool areAllWeaponsAtMaxTier = false

	if ( equippedWeapons.len() < EVO_SHARING_MIN_EQUIPPED_WEAPONS ) 
		return areAllWeaponsAtMaxTier

	foreach ( weapon in equippedWeapons )
	{
		LootData weaponData = SURVIVAL_GetLootDataFromWeapon( weapon )
		if ( !SURVIVAL_Loot_IsLootIndexValid( weaponData.index ) )
			return areAllWeaponsAtMaxTier

		int weaponTier = weaponData.tier
		if( weaponTier < tunings.maxWeaponTier )
		{
			areAllWeaponsAtMaxTier = false
			return areAllWeaponsAtMaxTier
		}
		else
		{
			areAllWeaponsAtMaxTier = true
		}
	}

	return areAllWeaponsAtMaxTier
}

array<entity> function EvoWeapon_GetPlayerWeapons( entity player )
{
	array< entity > playerWeapons = []
	array< entity > weapons       = tunings.slingWeaponAllowed ? SURVIVAL_GetPrimaryWeaponsIncludingSling( player ) : SURVIVAL_GetPrimaryWeapons( player )
	foreach ( entity weapon in weapons )
	{
		if ( !IsValid( weapon ) )
			continue

		LootData weapData = SURVIVAL_GetLootDataFromWeapon( weapon )
		if ( weapData.lootType != eLootType.MAINWEAPON )
			continue

		playerWeapons.append( weapon )
	}

	return playerWeapons
}































































































































































































































































































































































































































































































































































































































































































































































































































































































