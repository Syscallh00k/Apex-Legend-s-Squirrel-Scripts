bool function EvoWeapons_IsActiveWeaponReadyToEvolve( entity player )
{
	if ( !IsValid( player ) )
	return false

	entity weapon = player.GetPlayerNetEnt( EVO_WEAPON_NETVAR )
	if ( !IsValid( weapon ) || (weapon.GetWeaponClassName() == "") )
		return false

	int evoXp = player.GetPlayerNetInt( EVO_WEAPON_XP_NETVAR )
	int evoOverflowXp = player.GetPlayerNetInt( EVO_WEAPON_XP_OVERFLOW_NETVAR )
	return evoOverflowXp > 0 || (evoXp == 0)
}

void function EvoWeaponXpChanged( entity player, int val )
{
	EvoWeapons_UpdateEvoWeaponXPMeter( player, file.evoWeaponRui )
	EvoWeapons_UpdateEvoWeaponXPMeter( player, GetInventoryUltimateEvoWeaponsMeter() )
}

void function EvoWeapons_UpdateEvoWeaponXPMeter( entity player, var rui )
{
	if ( !IsValid( player ) || rui == null || !RuiIsAlive( rui ) )
		return

	entity weapon = player.GetPlayerNetEnt( EVO_WEAPON_NETVAR )
	bool isBleedingOut = Bleedout_IsBleedingOut( player )

	if ( !IsValid( weapon ) || isBleedingOut || ShouldUseLockedWeaponSlingLayout( player ) )
	{
		RuiSetBool( rui, "shouldDisplayExpUI", false )
		return
	}

	bool showSlingWeapon = tunings.slingWeaponAllowed || GetSlotForWeapon( player, weapon ) != SLING_WEAPON_SLOT
	int evoXp = player.GetPlayerNetInt( EVO_WEAPON_XP_NETVAR )
	int evoOverflowXp = player.GetPlayerNetInt( EVO_WEAPON_XP_OVERFLOW_NETVAR )
	
	
	
	if( !showSlingWeapon || evoXp == EVO_WEAPON_XP_DISABLED || (weapon.GetWeaponClassName() == "") )
	{
		RuiSetBool( rui, "shouldDisplayExpUI", false )
	}
	else
	{
		LootData data = SURVIVAL_GetLootDataFromWeapon( weapon )
		int tier = player.GetPlayerNetInt( EVO_WEAPON_TIER_NETVAR )
		bool isMaxTier = tier == tunings.maxWeaponTier
		bool isPastMaxTier = tier > tunings.maxWeaponTier
		bool allMaxTier = EvoWeapon_DoesPlayerHaveAllMaxTierWeapons( player )

		RuiSetImage( rui, "upgradeIcon", allMaxTier ? $"rui/hud/common/squad_trios" : data.hudIconSquare )
		RuiSetBool( rui, "shouldDisplayExpUI", true )
		RuiSetBool( rui, "isMaxTier", isMaxTier )
		RuiSetBool( rui, "allMaxTier", allMaxTier )
		RuiSetBool( rui, "isPastMaxTier", isPastMaxTier )
		RuiSetString( rui, "headerText", isMaxTier || isPastMaxTier ? "#MAX_LEVEL" : "#EVO_WEAPON_UPGRADE_UNLOCK" )

		int totalDamageToEvolve =  EvoWeapons_GetRequirementForEvolution( tier, data )
		int overflowExp = (tunings.allowOverflowEvo ? evoOverflowXp : 0)
		int currentTierExp =  totalDamageToEvolve - evoXp + overflowExp
		RuiSetInt( rui, "expTotal", isMaxTier ? totalDamageToEvolve : currentTierExp )
		RuiSetInt( rui, "expTierThreshold", totalDamageToEvolve )
		RuiSetInt( rui, "expTierColor", tier )

		RuiSetBool( rui, "forceFullExp", data.tier == eLootTier.MYTHIC )

		if ( currentTierExp > 0 )
		{
			RuiSetGameTime( rui, "expGainedTime", Time() )
		}
	}
}

void function EvoWeapons_OnSelectedWeaponChanged( entity selectedWeapon )
{
	if ( !IsValid( selectedWeapon ) )
		return

	if ( file.evoWeaponRui == null || !RuiIsAlive( file.evoWeaponRui ) )
		return

	entity viewPlayer = GetLocalViewPlayer()
	if ( !IsValid( viewPlayer ) )
		return

	array<entity> playerWeapons = EvoWeapon_GetPlayerWeapons( viewPlayer )

	bool isSelectedWeaponEvoWeapon = false
	foreach ( entity playerWeapon in playerWeapons )
	{
		
		if ( playerWeapon == selectedWeapon )
		{
			isSelectedWeaponEvoWeapon = true
			break
		}
	}

	if ( ShouldUseLockedWeaponSlingLayout( viewPlayer ) )
		isSelectedWeaponEvoWeapon = false

	RuiSetBool( file.evoWeaponRui, "shouldDisplayExpUI", isSelectedWeaponEvoWeapon )

	var inventoryEvoWeaponRui = GetInventoryUltimateEvoWeaponsMeter()
	if ( inventoryEvoWeaponRui != null )
	{
		RuiSetBool( inventoryEvoWeaponRui, "shouldDisplayExpUI", isSelectedWeaponEvoWeapon )
	}

	
	if ( isSelectedWeaponEvoWeapon )
	{
		UpdateEvoWeaponMeterOffset( viewPlayer, file.evoWeaponRui )
		UpdateEvoWeaponMeterOffset( viewPlayer, inventoryEvoWeaponRui )
	}
}

void function UpdateEvoWeaponMeterOffset( entity viewPlayer, var rui )
{
	if ( rui == null || !RuiIsAlive( rui ) )
		return

	int slot = eOffhandInv.ULTIMATE
	entity weapon = viewPlayer.GetOffhandWeapon( slot )
	if( weapon != null )
	{
		switch ( weapon.GetWeaponSettingEnum( eWeaponVar.cooldown_type, eWeaponCooldownType ) )
		{
			case eWeaponCooldownType.ammo_timed:
			case eWeaponCooldownType.ammo_instant:
			case eWeaponCooldownType.ammo_deployed:
			case eWeaponCooldownType.ammo:
				int maxAmmoReady = weapon.UsesClipsForAmmo() ? weapon.GetWeaponSettingInt( eWeaponVar.ammo_clip_size ) : weapon.GetWeaponPrimaryAmmoCountMax( weapon.GetActiveAmmoSource() )
				int ammoPerShot = weapon.GetWeaponSettingInt( eWeaponVar.ammo_per_shot )

				
				int burstCount = weapon.GetWeaponSettingInt( eWeaponVar.burst_fire_count )
				if ( burstCount <= 0 )
				{
					burstCount = 1
				}

				int ammoPerActivation = ammoPerShot * burstCount
				if ( ammoPerActivation <= 0 )
				{
					RuiSetInt( rui, "ultimateSegments", 1 )
					break
				}

				int segments = maxAmmoReady / ammoPerActivation
				if ( segments < 1 )
				{
					segments = 1
				}

				RuiSetInt( rui, "ultimateSegments", segments )
				break
			default:
				RuiSetInt( rui, "ultimateSegments", 1 )
				break
		}
	}
	else
	{
		RuiSetInt( rui, "ultimateSegments", 1 )
	}
}


void function ServerCallback_EvoWeapons_UpdatePlayerExpHUDWeaponEvo( bool didGainNewExpTier, bool isActiveWeapon )
{
	entity player = GetLocalViewPlayer()
	if ( !IsValid( player ) )
		return

	player.Signal( "EvoWeapons_StopWeaponEvoHints" ) 

	if ( GetGameState() == eGameState.Playing )
	{
		EvoWeapons_UpdatePlayerExpHUDWeaponEvo( player, file.evoWeaponRui, didGainNewExpTier, isActiveWeapon )
		EvoWeapons_UpdatePlayerExpHUDWeaponEvo( player, GetInventoryUltimateEvoWeaponsMeter(), didGainNewExpTier, isActiveWeapon )
	}
}

void function EvoWeapons_UpdatePlayerExpHUDWeaponEvo( entity player, var rui, bool didGainNewExpTier, bool isActiveWeapon )
{
	if ( rui == null || !RuiIsAlive( rui ) )
		return

	if ( didGainNewExpTier )
	{
		RuiSetGameTime( rui, "expGainedTime", Time() )
	}
}

void function EvoWeapons_OnInventoryOpened()
{
	EvoWeapons_UpdateEvoWeaponXPMeter( GetLocalClientPlayer(), GetInventoryUltimateEvoWeaponsMeter() )
	UpdateEvoWeaponMeterOffset( GetLocalClientPlayer(), GetInventoryUltimateEvoWeaponsMeter() )
}

void function EvoWeapon_PlayViewmodelWeaponEvolveHighlight( int lootTier )
{
	entity player = GetLocalViewPlayer()
	if ( !IsValid( player ) )
		return

	entity mainHandWeaponViewModel = player.GetViewModelEntity( eActiveInventorySlot.mainHand )
	entity altHandWeaponViewModel = player.GetViewModelEntity( eActiveInventorySlot.altHand )
	if ( IsValid( mainHandWeaponViewModel ) )
	{
		PlayWeaponEvolveHighlight( mainHandWeaponViewModel, lootTier )
	}
	if ( IsValid( altHandWeaponViewModel ) )
	{
		PlayWeaponEvolveHighlight( altHandWeaponViewModel, lootTier )
	}
}

void function ServerCallback_EvoWeapon_WeaponUpgraded( int weaponIdx, bool isActiveWeapon )
{
	entity player = GetLocalViewPlayer()
	if ( !IsValid( player ) )
		return

	if ( !SURVIVAL_Loot_IsLootIndexValid( weaponIdx ) )
		return

	if ( isActiveWeapon )
	{
		LootData data = SURVIVAL_Loot_GetLootDataByIndex( weaponIdx )

		EvoWeapon_PlayViewmodelWeaponEvolveHighlight( data.tier )

		string upgradeSFX = CONTROL_SFX_WEAPON_EVO_LVL_1
		switch ( data.tier )
		{
			case 1:
				upgradeSFX = CONTROL_SFX_WEAPON_EVO_LVL_1
				break
			case 2:
				upgradeSFX = CONTROL_SFX_WEAPON_EVO_LVL_2
				break
			case 3:
				upgradeSFX = CONTROL_SFX_WEAPON_EVO_LVL_3
				break
			case 4:
				upgradeSFX = CONTROL_SFX_WEAPON_EVO_LVL_4
				break
			default:
				upgradeSFX = CONTROL_SFX_WEAPON_EVO_LVL_1
				break
		}
		EmitSoundOnEntity( player, upgradeSFX )
	}

	if ( player in file.playerWeaponUpgradesToDisplay )
	{
		file.playerWeaponUpgradesToDisplay[ player ].append( weaponIdx )
	}
	else
	{
		file.playerWeaponUpgradesToDisplay[ player ] <- [weaponIdx]
		thread DisplayEvoWeaponUpgradeMessagingDelayed_Thread( player )
	}
}

void function DisplayEvoWeaponUpgradeMessagingDelayed_Thread( entity player )
{
#if DEV
		Assert( IsNewThread(), "Must be threaded off" )
#endif

	if ( GetGameState() > eGameState.Playing )
		return

	if ( !IsValid( clGlobal.levelEnt ) )
		return

	EndSignal( clGlobal.levelEnt, "OnDestroy" )

	entity localPlayer = GetLocalClientPlayer()
	if ( !IsValid( localPlayer ) )
		return

	EndSignal( localPlayer, "OnDestroy", "OnDeath" )

	OnThreadEnd(
		function() : ( player )
		{
			delete file.playerWeaponUpgradesToDisplay[ player ]
		}
	)

	WaitFrame()

	array< asset > upgradeIcons
	array< int > upgradeTiers
	array< vector > iconAspectRatios

	foreach ( int weaponIdx in file.playerWeaponUpgradesToDisplay[ player ] )
	{
		LootData data = SURVIVAL_Loot_GetLootDataByIndex( weaponIdx )
		upgradeTiers.append( data.tier )
		upgradeIcons.append( data.hudIcon )

		vector imageSize = GetImageSize( data.hudIcon )
		vector aspectRatio = GetAspectRatioBase1( imageSize )
		iconAspectRatios.append( aspectRatio )
	}

	string announcementMessage = Localize( "#EVOWEAPONS_HUD_EXP_WEAPON_EVOLVED" )
	AnnouncementData announcement = Announcement_Create( announcementMessage )
	Announcement_SetStyle( announcement, ANNOUNCEMENT_STYLE_WEAPON_UPGRADED )
	Announcement_SetPurge( announcement, true )
	Announcement_SetDuration( announcement, 3.0 )

	if ( upgradeIcons.len() > 0 )
	{
		Announcment_SetOptionalImageAssetArgsArray( announcement, upgradeIcons )
		Announcment_SetOptionalImageTierArgsArray( announcement, upgradeTiers )
		Announcment_SetOptionalImageAspectRatioArgsArray( announcement, iconAspectRatios )
	}

	AnnouncementFromClass( GetLocalViewPlayer(), announcement )
}

void function EvoWeaponEntityChanged( entity player, entity weaponEntity )
{
	int evoXP = player.GetPlayerNetInt( EVO_WEAPON_XP_NETVAR )
	EvoWeaponXpChanged( player, evoXP )
}

void function EvoWeapons_Init_Client( entity player )
{
	file.evoWeaponRui = CreateCockpitPostFXRui( $"ui/evo_weapon_survival.rpak", HUD_Z_BASE )
	RuiSetBool( file.evoWeaponRui, "shouldDisplayExpUI", false )
}

var function EvoWeapons_GetHudEvoWeaponXPMeter()
{
	return file.evoWeaponRui
}

bool function EvoWeapons_CanShowEvoWeaponXPMeter()
{
	var evoWeaponRui = EvoWeapons_GetHudEvoWeaponXPMeter()
	if ( !evoWeaponRui || !RuiIsAlive( evoWeaponRui ) )
		return false

	entity player = GetLocalViewPlayer()
	if ( !IsValidPlayer( player ) )
		return false

	if ( Bleedout_IsBleedingOut( player ) )
		return false

	entity weapon = player.GetPlayerNetEnt( EVO_WEAPON_NETVAR )

	if ( !IsValid( weapon ) )
		return false

	if ( ShouldUseLockedWeaponSlingLayout( player ) )
		return false

	return true
}


