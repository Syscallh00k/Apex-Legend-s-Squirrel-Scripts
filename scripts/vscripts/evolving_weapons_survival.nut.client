void function EvoWeapons_InitTuningValues()
{
	tunings.damageThresholdZero      	= GetCurrentPlaylistVarInt( "evo_weapon_damagethreshold_zero", tunings.damageThresholdZero )
	tunings.damageThresholdOne      	= GetCurrentPlaylistVarInt( "evo_weapon_damagethreshold_one", tunings.damageThresholdOne )
	tunings.damageThresholdTwo      	= GetCurrentPlaylistVarInt( "evo_weapon_damagethreshold_two", tunings.damageThresholdTwo )
	tunings.damageThresholdThree      	= GetCurrentPlaylistVarInt( "evo_weapon_damagethreshold_three", tunings.damageThresholdThree )
	tunings.damageThresholdFour      	= GetCurrentPlaylistVarInt( "evo_weapon_damagethreshold_four", tunings.damageThresholdFour )
	tunings.maxWeaponTier      			= GetCurrentPlaylistVarInt( "evo_weapon_max_tier", tunings.maxWeaponTier )
	tunings.maxOverflow 				= tunings.damageThresholdZero + tunings.damageThresholdOne + tunings.damageThresholdTwo + tunings.damageThresholdThree + tunings.damageThresholdFour

	tunings.otherWeaponsGivePartial		= GetCurrentPlaylistVarBool( "evo_weapon_give_partial_enabled", tunings.otherWeaponsGivePartial )
	tunings.partialPercentGain      	= GetCurrentPlaylistVarFloat( "evo_weapon_partial_percent_gain", tunings.partialPercentGain )
	tunings.respawnPercentToGive      	= GetCurrentPlaylistVarFloat( "evo_weapon_respawn_percent", tunings.respawnPercentToGive )

	tunings.shouldDroppedWeaponUpgradeIfAble 	= GetCurrentPlaylistVarBool( "evo_weapon_upgrade_dropped_weapon", tunings.shouldDroppedWeaponUpgradeIfAble )
	tunings.shareEvoAtAllMaxTier      			= GetCurrentPlaylistVarBool( "evo_weapon_share_evo_at_all_weapons_max_tier", tunings.shareEvoAtAllMaxTier )
	tunings.slingWeaponAllowed      			= GetCurrentPlaylistVarBool( "evo_weapon_sling_weapon_allowed", tunings.slingWeaponAllowed )
	tunings.allowOverflowEvo      				= GetCurrentPlaylistVarBool( "evo_weapon_allow_overflow", tunings.allowOverflowEvo )
	tunings.allowTierSkips      				= GetCurrentPlaylistVarBool( "evo_weapon_allow_tier_skips", tunings.allowTierSkips )
}

bool function EvoWeapons_IsEnabled()
{
	return GetCurrentPlaylistVarBool( "enable_survival_evo_weapons", false )
}

bool function EvoWeapons_PlayerHasEvoWeapon( entity player )
{
	return player.GetPlayerNetBool( EVO_WEAPON_EQUIPPED_NETVAR )
}

bool function EvoWeapons_UsePlayerXPForProgression()
{
	return GetCurrentPlaylistVarBool( "evo_weapon_use_player_xp_for_progression", true )
}

bool function EvoWeapons_ApplyPlayerXPToAllWeapons()
{
	return GetCurrentPlaylistVarBool( "evo_weapon_apply_player_xp_to_all_weapons", true )
}


