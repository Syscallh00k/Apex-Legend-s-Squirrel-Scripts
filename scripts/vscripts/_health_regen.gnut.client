bool function HealthRegen_IsOctane( entity player )
{
	return PlayerHasPassive( player, ePassives.PAS_OCTANE )
}


















bool function HealthRegen_IsWattson( entity player )
{





	return PlayerHasPassive( player, ePassives.PAS_BATTERY_POWERED )
}

