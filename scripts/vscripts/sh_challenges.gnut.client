int function Challenge_GetDailyExpirationTimeWithOffset( entity player )
{

		Assert( IsPersistenceAvailable() )
		if ( !IsPersistenceAvailable() )
			return UNIX_TIME_FALLBACK_2038 


	int dailyExpirationTime = ClampChallengeExpireTime( player.GetPersistentVarAsInt( "dailyExpirationTime" ) )
	
	
	int approxUtcExpiration = dailyExpirationTime - DAILY_RESET_TIME_ZONE_OFFSET * SECONDS_PER_HOUR
	int dstAdjustment = GetIsDSTActiveForTime( approxUssert( ItemFlavor_GetType( challengeFlav ) == eItemType.challenge )
	ChallengeSet challengeSet = ChallengeSet_GetByGUID( Challenge_GetProgressUnlockDependency( challengeFlav ).guid )

	return ChallengeSet_GetProgress( player, challengeSet ) >= Challenge_GetMinimumNumberOfChallengesCompletedForUnlock( player, challengeFlav )
}

