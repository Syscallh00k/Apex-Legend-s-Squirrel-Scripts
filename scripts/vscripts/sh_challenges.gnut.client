{
	asset featuredChallengeOverride = GetGlobalSettingsAsset( ItemFlavor_GetAsset( tempUnlockFlav ), "featuredChallengeFlav" )
	if ( featuredChallengeOverride != $"" && IsValidItemFlavorSettingsAsset( featuredChallengeOverride ) )
	{
		return GetItemFlavorByAsset( featuredChallengeOverride )
	}
	return null
