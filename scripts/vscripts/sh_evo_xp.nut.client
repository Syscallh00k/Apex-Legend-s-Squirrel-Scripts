int function EvoXp_GetXP( entity player )
{
	if( !EvoXp_IsEnabled() )
		return 0

	return player.GetPlayerNetInt( EVO_XP_NETINT )
}


void function EvoXP_RegisterXpSystem( XpSystem system )
{
	if ( !EvoXp_IsEnabled() )
	{
		Warning( "Registering Evo XP System, but the Evo XP System is disabled!" )
	}

	Assert( file.xp.systemType == eXpSystemType.NONE, ("" + file.xp.systemType + " has already been registered as the XP system!" ) )
	Assert( system.systemType != eXpSystemType.NONE, "Trying to register a blank XP system!" )





	Assert( system.IsPlayerAtMaxXpCallback != null, "XP system is missing IsPlayerAtMaxXpCallback granted callback!" )
	file.xp = system
}

































































































































































bool function EvoXp_IsPlayerAtMaxXP( entity player )
{
	if ( file.xp.systemType != eXpSystemType.NONE )
	{
		return file.xp.IsPlayerAtMaxXpCallback( player )
	}

	return false
}



























































