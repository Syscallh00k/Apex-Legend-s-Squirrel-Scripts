void function ServerToClient_EvoXp_XPAwarded( int actionID, int amount, bool teamAward )
{
	entity player = GetLocalViewPlayer()

	EvoXPEvent evoXpEvent = EvoXp_GetEvoXPEventOffActionID( actionID )

	string xpAction       = evoXpEvent.locString
	bool sharerMessage    = evoXpEvent.isSharerMessage
	bool isDelayedMessage = evoXpEvent.isDelayed
	string xpSound        = amount >= tunings.largeXpThreshold ? "UI_InGame_XP_Gain_Large" : "UI_InGame_XP_Gain_Small"

	if ( isDelayedMessage )
	{
		if ( actionID in file.xpActionIDToAmountAwardedDuringDelayedMsgInterval )
		{
			int xpAwarded = file.xpActionIDToAmountAwardedDuringDelayedMsgInterval[ actionID ]
			xpAwarded += amount
			file.xpActionIDToAmountAwardedDuringDelayedMsgInterval[ actionID ] = xpAwarded
		}
		else
		{
			file.xpActionIDToAmountAwardedDuringDelayedMsgInterval[ actionID ] <- amount
			thread DisplayXPAwardedMessagingDelayed_Thread( player, sharerMessage, teamAward, actionID, xpAction, xpSound )
		}
	}
	else
	{
		DisplayXPAwardedMessaging( player, sharerMessage, teamAward, xpAction, xpSound, amount )
	}
}

void function DisplayXPAwardedMessaging( entity player, bool isSharerMessage, bool isTeamAward, string xpActionString, string xpSound, int amount )
{
	entity localViewPlayer = GetLocalViewPlayer()
	if ( localViewPlayer == player && !EvoLevels_IsDisplayingLevelUpMessage() )
	{
		if ( isSharerMessage )
		{
			AnnouncementMessageRight( localViewPlayer, Localize( xpActionString ), "", <214, 214, 214>, $"", 2.5, xpSound )
		}
		else
		{
			if ( !isTeamAward )
			{
				AnnouncementMessageRight( localViewPlayer, Localize( "#LEGEND_UPGRADE_CURRENCY_AWARD", Localize( xpActionString ), amount ), "", <214, 214, 214>, $"", 2.5, xpSound ) 
			}
			else
			{
				AnnouncementMessageRight( localViewPlayer, Localize( "#LEGEND_UPGRADE_CURRENCY_AWARDTEAM", Localize( xpActionString ), amount ), "", <214, 214, 214>, $"", 2.5, xpSound )
			}
		}
	}
}

const float SCORE_MESSAGING_DELAY = 1.0

void function DisplayXPAwardedMessagingDelayed_Thread( entity player, bool isSharerMessage, bool isTeamAward, int actionID, string xpActionString, string xpSound )
{
#if DEV
		Assert( IsNewThread(), "Must be threaded off" )
#endif

	if ( !( actionID in file.xpActionIDToAmountAwardedDuringDelayedMsgInterval ) )
	{
		Assert( false, "OBJECTIVE BR: " + FUNC_NAME() + " was run with a actionID: " + actionID + " that wasn't entered in the file.xpActionIDToAmountAwardedDuringDelayedMsgInterval table first." )
		return
	}

	if ( GetGameState() > eGameState.Playing )
		return

	if ( !IsValid( clGlobal.levelEnt ) )
		return

	EndSignal( clGlobal.levelEnt, "OnDestroy" )

	entity localPlayer = GetLocalClientPlayer()
	if ( !IsValid( localPlayer ) )
		return

	EndSignal( localPlayer, "OnDestroy", "OnDeath" )

	OnThreadEnd(
		function() : ( actionID )
		{
			delete file.xpActionIDToAmountAwardedDuringDelayedMsgInterval[ actionID ]
		}
	)

	int currentPointsTotal = file.xpActionIDToAmountAwardedDuringDelayedMsgInterval[ actionID ]
	int updatedPointsTotal = currentPointsTotal

	
	while ( true )
	{
		wait SCORE_MESSAGING_DELAY

		updatedPointsTotal = file.xpActionIDToAmountAwardedDuringDelayedMsgInterval[ actionID ]

		if ( currentPointsTotal == updatedPointsTotal ) 
			break

		
		currentPointsTotal = updatedPointsTotal
	}

	DisplayXPAwardedMessaging( player, isSharerMessage, isTeamAward, xpActionString, xpSound, currentPointsTotal )
}

void function ServerCallback_Play1P_EvoGain_VFX( entity player )
{
	if ( !IsValid( player ) )
		return

	entity cockpit = player.GetCockpit()
	if ( !cockpit )
		return

	int fxHandle = StartParticleEffectOnEntity( cockpit, GetParticleSystemIndex( FX_EVO_GAIN_FEEDBACK_1P ), FX_PATTACH_ABSORIGIN_FOLLOW, ATTACHMENTID_INVALID )

	EffectSetControlPointVector( fxHandle, 1, EVO_VFX_COLOR )

	EffectSetIsWithCockpit( fxHandle, true )
}



