const bool EVO_XP_DEBUG = false

void function EvoXP_Init()
{
	EvoXP_InitTuningValues()

	if( !EvoXp_IsEnabled() )
		return

	EvoXP_NetvarsInit()


	Remote_RegisterClientFunction( FUNCNAME_ServerToClient_UpgradeCore_Play1pEvoGainVfx, "entity" )
	Remote_RegisterClientFunction( FUNCNAME_ServerToClient_EvoXp_XPAwarded, "int", -1, eUpgradeXPActions.COUNT, "int", -1, INT_MAX, "bool" )

	PrecacheParticleSystem( FX_EVO_GAIN_FEEDBACK_1P )
	EvoXP_RegisterEvoXPDatatable()
	SetUpScoreEvents()




















































}

void function EvoXP_InitTuningValues()
{

		RunUIScript( "EvoXP_InitTuningValues" )


	
	Tuning defaultTunings

	tunings.isEnabled = GetCurrentPlaylistVarBool( "evo_xp_enabled", true )



















































		tunings.overflowEvoXPToTeammatesWhenMaxLevel = GetCurrentPlaylistVarBool( "passive_upgrade_core_share_evo_at_max_level", defaultTunings.overflowEvoXPToTeammatesWhenMaxLevel )



	tunings.largeXpThreshold = GetCurrentPlaylistVarInt( "passive_upgrade_core_xp_notification_thresholds", defaultTunings.largeXpThreshold )
	tunings.usePersonalObitNotifications = EvoXp_IsEnabled() && GetCurrentPlaylistVarBool( "passive_upgrade_use_personal_obituary_notifications", defaultTunings.usePersonalObitNotifications )

		tunings.healthOnOrbPickupAmnt = GetCurrentPlaylistVarInt( "passive_upgrade_core_xpcache_health_on_orb_pickup_amt", defaultTunings.healthOnOrbPickupAmnt )
		tunings.shieldOnOrbPickupAmnt = GetCurrentPlaylistVarInt( "passive_upgrade_core_xpcache_shield_on_orb_pickup_amt", defaultTunings.shieldOnOrbPickupAmnt )



}

void function EvoXP_NetvarsInit()
{
	RegisterNetworkedVariable( EVO_XP_NETINT, SNDC_PLAYER_GLOBAL, SNVT_BIG_INT , 0.0 )
}

void function EvoXp_LobbyInit()
{
	EvoXP_NetvarsInit()
	EvoXP_InitTuningValues()
}

bool function EvoXp_IsEnabled()
{
	return LegendUpgrades_IsEnabled()
}















void function SetUpScoreEvents()
{
	if( !EvoXp_UsePersonalObituaryNotifications() )
		return

	ScoreEvent downedEvent = GetScoreEvent( "Sur_DownedPilot" )
	ScoreEvent_SetSplashText( downedEvent, "#SCORE_EVENT_SUR_DOWNED_PILOT_HUD_WITH_XP" )

	ScoreEvent eliminateEvent = GetScoreEvent( "EliminatePilot" )
	ScoreEvent_SetSplashText( eliminateEvent, "#SCORE_EVENT_SUR_ELIMINATE_PILOT_WITH_ICON" )

	ScoreEvent eliminateAssistEvent = GetScoreEvent( "EliminatePilotAssist" )
	ScoreEvent_SetSplashText( eliminateAssistEvent, "#SCORE_EVENT_SUR_ELIMINATE_PILOT_ASSIST_WITH_ICON" )

	EvoXPEvent squadWipeEventData = EvoXp_GetEvoXPEventOffActionID( eUpgradeXPActions.SQUADWIPE )
	ScoreEvent squadWipe = GetScoreEvent( "Sur_SquadWipe" )
	ScoreEvent_SetXpValue( squadWipe, squadWipeEventData.baseXP, squadWipeEventData.baseIsTeamXP )


		ScoreEvent_SetMessagingDelay( GetScoreEvent( "Evo_Cache_Tiny" ), tunings.xpCacheTinyScoreDelay )

}


