bool function EvoXp_UsePersonalObituaryNotifications()
{
	return tunings.usePersonalObitNotifications && !file.progressionLocked
}



EvoXPEvent function EvoXp_GetEvoXPEventOffActionID( int actionID )
{
	EvoXPEvent evoEvent

	Assert( actionID in file.xpEventDT, "Action ID can not be found in Evo XP Datatable. Be sure your actionID exists in the dt and use EvoXP_IncrementXPByEvoXPEvent() to grant Evo XP." )

	evoEvent = file.xpEventDT[ actionID ]
	return evoEvent
}




































































































