void function _____________XP_DataTables___________________________(){}
#endif


void function EvoXP_RegisterEvoXPDatatable()
{
	for ( int i = 0; i < eUpgradeXPActions.COUNT; i++ )
	{
		EvoXPEvent evoXpEvent
		file.xpEventDT[i] <- evoXpEvent
	}

	asset dataTableAsset = EVOXP_DATATABLE["DEFAULT"]
	array< EvoXPEvent > evoXpDataTable = ReadEvoXPDataTable( dataTableAsset )
	foreach ( EvoXPEvent evoXpEvent in evoXpDataTable)
	{
		if ( evoXpEvent.xpEvent in eUpgradeXPActions )
		{
			file.xpEventDT[ eUpgradeXPActions[evoXpEvent.xpEvent] ] <- evoXpEvent
#if EVO_XP_DEBUG
				evoXpEvent.updatedFromDT = true
#endif
		}
		else
		{
			Warning( "EvoXP_RegisterEvoXPDatatable: DataTable contains a value that is not in eUpgradeXPActions" )
		}
	}

	
	string evoXpDataTableOverrideID = PVAR_GetEvoXPDataTableID()
	if( evoXpDataTableOverrideID != "" )
	{
		if ( HasEvoXPTableDefined( evoXpDataTableOverrideID ) )
		{
			dataTableAsset = GetEvoXPDataTable_Asset( evoXpDataTableOverrideID )
		}
		else
		{
			Assert( false,evoXpDataTableOverrideID + " evo xp datatable override is not defined. Failed to initialize custom xp table. Please add your custom key and data table asset to EVOXP_DATATABLE." )
		}
	}

	array< EvoXPEvent > overrideXpTable = ReadEvoXPDataTable( dataTableAsset )

	foreach ( EvoXPEvent evoXpEvent in overrideXpTable )
	{
		if ( evoXpEvent.xpEvent in eUpgradeXPActions )
		{
			file.xpEventDT[ eUpgradeXPActions[evoXpEvent.xpEvent] ] = evoXpEvent
#if EVO_XP_DEBUG
				evoXpEvent.updatedFromDT = true
#endif
		}
		else
		{
			Warning( "EvoXP_RegisterEvoXPDatatable: Override DataTable contains a value that is not in eUpgradeXPActions" )
		}
	}

	EvoXP_OverrideEvoActionXP()

#if EVO_XP_DEBUG
		foreach ( key, evoXpEvent in file.xpEventDT )
		{
			if ( evoXpEvent.updatedFromDT == false )
			{
				printt( "EvoXP_RegisterEvoXPDatatable(): eUpgradeXPActions." + GetEnumString( "eUpgradeXPActions", key ) + " was not updated from the dataTable, using default struct values."  )
			}
		}
#endif
}

array< EvoXPEvent > function ReadEvoXPDataTable( asset dataTableAsset )
{
	var dataTable = GetDataTable( dataTableAsset )
	int numRows   = GetDataTableRowCount( dataTable )

	int featureFlagColumn   	= GetDataTableColumnByName( dataTable, "featureFlag" )
	int xpEventColumn   		= GetDataTableColumnByName( dataTable, "xpEvent" )
	int locStringColumn   		= GetDataTableColumnByName( dataTable, "locString" )
	int isDelayedColumn   		= GetDataTableColumnByName( dataTable, "isDelayed" )
	int dynamicXpColumn   		= GetDataTableColumnByName( dataTable, "dynamicXP" )
	int baseXpColumn   			= GetDataTableColumnByName( dataTable, "baseXP" )
	int baseIsTeamXpColumn		= GetDataTableColumnByName( dataTable, "baseIsTeamXP" )
	int scoreEventColumn		= GetDataTableColumnByName( dataTable, "scoreEvent" )
	int notifyWithPrompt		= GetDataTableColumnByName( dataTable, "notifyPlayerWithPrompt" )
	int isSharerMessage			= GetDataTableColumnByName( dataTable, "isSharerMessage" )

	array< EvoXPEvent > result
	for ( int i = 0; i < numRows; i++ )
	{
		EvoXPEvent evoXpEvent

		evoXpEvent.xpEvent 						= GetDataTableString( dataTable, i, xpEventColumn )
		evoXpEvent.locString 					= GetDataTableString( dataTable, i, locStringColumn )
		evoXpEvent.isDelayed 					= GetDataTableBool( dataTable, i, isDelayedColumn )
		evoXpEvent.isDynamicXP 					= GetDataTableBool( dataTable, i, dynamicXpColumn )
		evoXpEvent.baseXP 						= GetDataTableInt( dataTable, i, baseXpColumn )
		evoXpEvent.baseIsTeamXP 				= GetDataTableBool( dataTable, i, baseIsTeamXpColumn )
		evoXpEvent.scoreEvent 					= GetDataTableString( dataTable, i, scoreEventColumn )
		evoXpEvent.notifyPlayerWithPrompt	 	= GetDataTableBool( dataTable, i, notifyWithPrompt )
		evoXpEvent.isSharerMessage	 			= GetDataTableBool( dataTable, i, isSharerMessage )

		Assert( evoXpEvent.xpEvent in eUpgradeXPActions, "EvoXPEvent does not exist" )
		result.append( evoXpEvent)
	}

	return result
}

void function EvoXP_OverrideEvoActionXP()
{
	string playlistOverrides = PVAR_EvoActionXPOverrides()

	if( playlistOverrides == "" )
		return

	foreach ( string xpEvent in GetTrimmedSplitLoweredString( playlistOverrides, " " ) )
	{
		array<string> splitPair = GetTrimmedSplitString( xpEvent, ":" )

		if ( splitPair.len() == 2 )
		{
			string actionEventName = splitPair[0].toupper()
			int actionXp           = int(splitPair[1])

			if ( actionEventName in eUpgradeXPActions )
			{
				EvoXPEvent evoXpEvent = EvoXp_GetEvoXPEventOffActionID( eUpgradeXPActions[actionEventName] )
				evoXpEvent.baseXP = actionXp
			}
		}
		else
		{
			Assert( false, "EvoXP_OverrideEvoActionXP: Can only provide one XP override value" )
		}
	}
}

string function PVAR_GetEvoXPDataTableID()
{
	return GetCurrentPlaylistVarString( "evo_xp_custom_xp_data_table_id", "" )
}

bool function HasEvoXPTableDefined ( string evoXpTableID )
{
	return evoXpTableID in EVOXP_DATATABLE
}

asset function GetEvoXPDataTable_Asset( string evoXpTableID ) {
	return EVOXP_DATATABLE[ evoXpTableID ]
}

string function PVAR_EvoActionXPOverrides()
{
	return GetCurrentPlaylistVarString( "evo_xp_action_override", "" )
}



