array<ItemFlavor> function CharacterSelect_GetOPSkins( ItemFlavor flavor )
{
	Assert( ItemFlavor_GetType( flavor ) == eItemType.character_select )

	array<ItemFlavor> skins = []
	foreach ( var skinBlock in IterateSettingsAssetArray( ItemFlavor_GetAsset( flavor ), "opSkins" ) )
	{
		asset skinAsset = GetSettingsBlockAsset( skinBlock, "flavor" )
		if ( IsValidItemFlavorSettingsAsset( skinAsset ) )
			skins.append( GetItemFlavorByAsset( skinAsset ) )
	}

	return skins
}

bool function CharacterSelect_IsLockedToOPSkin( ItemFlavor flavor )
{
	Assert( ItemFlavor_GetType( flavor ) == eItemType.character_select )

	return GetGlobalSettingsBool( ItemFlavor_GetAsset( flavor ), "isLockedToOPSkin" )
}

var function CharacterSelect_GetOverrideSetBlockForSkin( ItemFlavor select, ItemFlavor skin )
{
	Assert( ItemFlavor_GetType( select ) == eItemType.character_select )
	Assert( ItemFlavor_GetType( skin ) == eItemType.character_skin )

	var assetBlock  = GetSettingsBlockForAsset( ItemFlavor_GetAsset( select ) )
	var overrideArr = GetSettingsBlockArray( assetBlock, "skinSpecificOverrideAnimSets" )
	asset skinAsset = ItemFlavor_GetAsset( skin )
	foreach ( var setBlock in IterateSettingsArray( overrideArr ) )
	{
		var skinArr = GetSettingsBlockArray( setBlock, "skins" )
		foreach ( var block in IterateSettingsArray( skinArr ) )
		{
			if ( skinAsset == GetSettingsBlockAsset( block, "flavor" ) )
				return setBlock
		}
	}

	return null
}

asset function CharacterSelect_GetCustomIntroAnim( ItemFlavor select, ItemFlavor ornull skin )
{
	Assert( ItemFlavor_GetType( select ) == eItemType.character_select )

	if ( skin != null )
	{
		expect ItemFlavor( skin )
		var overrideBlock = CharacterSelect_GetOverrideSetBlockForSkin( select, skin )
		if ( overrideBlock != null )
			return GetSettingsBlockAsset( overrideBlock, "customCharSelectIntroAnim" )
	}

	return GetGlobalSettingsAsset( ItemFlavor_GetAsset( select ), "customCharSelectIntroAnim" )
}

