bool function CharacterSkin_HasCustomCharacterSelect( ItemFlavor flavor )
{
	Assert( ItemFlavor_GetType( flavor ) == eItemType.character_skin )

	array<ItemFlavor> selects = []
	foreach ( var selectBlock in IterateSettingsAssetArray( ItemFlavor_GetAsset( flavor ), "customCharacterSelects" ) )
	{
		asset skinAsset = GetSettingsBlockAsset( selectBlock, "customCharacterSelect" )
		if ( IsValidItemFlavorSettingsAsset( skinAsset ) )
			selects.append( GetItemFlavorByAsset( skinAsset ) )
	}

	return ( selects.len() > 0 )
}

ItemFlavor function CharacterSkin_GetCustomSelect( ItemFlavor flavor )
{
	Assert( ItemFlavor_GetType( flavor ) == eItemType.character_skin )

	array<ItemFlavor> selects = []
	foreach ( var selectBlock in IterateSettingsAssetArray( ItemFlavor_GetAsset( flavor ), "customCharacterSelects" ) )
	{
		asset skinAsset = GetSettingsBlockAsset( selectBlock, "customCharacterSelect" )
		if ( IsValidItemFlavorSettingsAsset( skinAsset ) )
			selects.append( GetItemFlavorByAsset( skinAsset ) )
	}
	Assert( selects.len() > 0 )
	return selects[0]
}

