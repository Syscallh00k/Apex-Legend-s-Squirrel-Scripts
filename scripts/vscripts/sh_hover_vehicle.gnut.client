bool function HoverVehiclesAreEnabled()
{
	return GetCurrentPlaylistVarBool( "hover_vehicles_enabled", true )
}

bool function HoverVehicles_PingFromMap_Enabled()
{
	return GetCurrentPlaylistVarBool( "hover_vehicles_pingfrommap_enabled", true )
}

void function HoverVehicle_Init()
{
	file.hovervehicle_rework_enabled = GetCurrentPlaylistVarBool( "hovervehicle_rework_enabled", true )

	HoverVehicle_Names_Init()

	Tunings_Init()

	ConVars_And_TweakVars_Set()

	RegisterSignal( SIG_VEHICLE_EMBARK_BEGIN )
	RegisterSignal( SIG_HOVERVEHICLE_ALARM_OFF )
	RegisterSignal( SIG_HOVERVEHICLE_HEALTHREGEN )
	RegisterSignal( SIG_HOVERVEHICLE_HEALTHREGEN_OFF )
	RegisterSignal( SIG_HOVERVEHICLE_PLATFORM_SPAWNEDFX )

	RegisterSignal( SIG_HOVERVEHICLE_PARKEDICON )
	RegisterSignal( SIG_HOVERVEHICLE_EMBARK_DISRUPTED )

	AddCallback_EntitiesDidLoad( EntitiesDidLoad )










	PrecacheModel( TWO_PASSENGER_MODEL )

	if ( !HoverVehiclesAreEnabled() )
		return

	PrecacheScriptString( HOVER_VEHICLE_SCRIPTNAME )

		PrecacheModel( HOVER_VEHICLE_MODEL_OLD )

	PrecacheModel( HOVER_VEHICLE_MODEL )

	PrecacheParticleSystem( FX_VEHICLE_BOOST )
	PrecacheParticleSystem( FX_VEHICLE_BOOST_SML )
	PrecacheParticleSystem( FX_VEHICLE_AIR_BRAKE )
	PrecacheParticleSystem( FX_VEHICLE_JET_REAR )
	PrecacheParticleSystem( FX_VEHICLE_JET_SIDE )
	PrecacheParticleSystem( FX_VEHICLE_JET_BASE )
	PrecacheParticleSystem( FX_VEHICLE_TRAILS )
	PrecacheParticleSystem( FX_VEHICLE_TRAILS_BOOST )
	PrecacheParticleSystem( FX_VEHICLE_JUMP )
	PrecacheImpactEffectTable( FX_VEHICLE_JETWASH )

	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_BODY_LIGHT )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_BODY_MEDIUM )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_BODY_HEAVY )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_EXHAUST_LIGHT )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_EXHAUST_MEDIUM )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_EXHAUST_HEAVY )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_EXHAUST_HEAVY_BACK )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_REAR_LIGHT )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_REAR_MEDIUM )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_REAR_HEAVY )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_HOOD_LIGHT )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_HOOD_MEDIUM )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_HOOD_HEAVY )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_TOP_LIGHT )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_TOP_MEDIUM )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_TOP_HEAVY )
	PrecacheParticleSystem( FX_VEHICLE_DEATH_FX )

		PrecacheParticleSystem( FX_VEHICLE_DEATH_FX_OLD )
		PrecacheParticleSystem( FX_VEHICLE_SPAWN )
		PrecacheParticleSystem( FX_VEHICLE_HEALSHINE )

		PrecacheParticleSystem( FX_VEHICLE_RESPAWN_ARROW )
		PrecacheParticleSystem( FX_VEHICLE_RESPAWN_BEAM )


	
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_SMOKE_WHITE )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_SMOKE_BLACK )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_FIRE_SMALL )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_FIRE_LARGE )
	PrecacheParticleSystem( FX_VEHICLE_DAMAGE_EXP_SMALL )

	PrecacheParticleSystem( FX_VEHICLE_IDLE )
	PrecacheParticleSystem( FX_VEHICLE_IDLE_REAR )
	PrecacheParticleSystem( FX_LIGHT_HEAD )
	PrecacheParticleSystem( FX_LIGHT_HEAD_TOP )
	PrecacheParticleSystem( FX_LIGHT_BRAKE )
	PrecacheParticleSystem( FX_LIGHT_BRAKE_IDLE )

	PrecacheParticleSystem( FX_VEHICLE_LAUNCHPAD_LAUNCH )
	PrecacheParticleSystem( FX_VEHICLE_EJECT_PILOT_TRAILS )
	PrecacheParticleSystem( FX_VEHICLE_EJECT_PILOT_SCREEN )
	PrecacheParticleSystem( FX_VEHICLE_SPAWN_POINT )

	HoverVehicle_InitFX()













	AddCreateCallback( "player_vehicle", CL_OnVehicleCreated )
	RegisterMinimapPackages()
	AddCallback_OnClientScriptInit( LaunchVehicleHudManagement )
	AddCallback_FullUpdate( OnFullUpdate )
	AddCallback_GameStateEnter( eGameState.Playing, HoverVehicle_OnGameStartPlaying )

	RegisterSignal( "OnVehicleRuiEnd" )

	if( HoverVehicles_PingFromMap_Enabled() )
		AddCallback_OnFindFullMapAimEntity( GetVehicleUnderAim, PingVehicleUnderAim )


		AddCreateCallback( "prop_script", CL_OnPropCreated )




	AddCallback_CanStartCustomWeaponActivity( ACT_VM_WEAPON_INSPECT, CanWeaponInspect )

	Remote_RegisterClientFunction( "ServerCallback_VehicleOccupancyChange", "entity" )

	Remote_RegisterClientFunction( "SCB_EjectedFromHoverVehicleForSeldDestruct" )

	if( HoverVehicles_PingFromMap_Enabled() )
	{
		Remote_RegisterServerFunction( FUNCNAME_PingVehicleFromMap, "typed_entity", "player_vehicle" )

		Remote_RegisterClientFunction( FUNCNAME_SetVehiclePresenceAtPlatform, "entity" )
	}

	InitVehicleHorn()


	Remote_RegisterClientFunction( FUNC_HOVERVEH_DAMAGEINDICATOR, "entity", "entity", "float", 0.0, 10000.0, 32, "vector", -MAX_WORLD_COORD, MAX_WORLD_COORD, 32, "int", 0, INT_MAX, "int", eDamageSourceId.invalid, eDamageSourceId._count )

	Remote_RegisterServerFunction( FUNC_VO_TRIDENTDAMAGED, "typed_entity", "player_vehicle" )

	InitVehicleEject()

	
	


	Remote_RegisterClientFunction( FUNC_HOVERVEH_PARKEDICON_CREATE, 	"entity" )
	Remote_RegisterClientFunction( FUNC_HOVERVEH_PARKEDICON_DESTROY, "entity" )
}

void function HoverVehicle_Names_Init()
{
	file.hoverVehicleNames_ByType[ eHoverVehicleTypes.TRIDENT ] <- "trident"

		file.hoverVehicleNames_ByType[ eHoverVehicleTypes.TRIDENT_OLDMODEL ] <- "tridentoldmdl"


	
}


void function ConVars_And_TweakVars_Set()
{
	
	SetConVarBool( "hover_vehicle_yaw_spring_enabled", 					tunings_Shared.cvar_Camera_Yaw_Spring_Enabled )
	SetConVarFloat( "hover_vehicle_yaw_nospring_smoothtime", 			tunings_Shared.cvar_Camera_Yaw_NoSpring_SmoothTime )
	SetConVarFloat( "hover_vehicle_yaw_nospring_smoothtime_boosting",	tunings_Shared.cvar_Camera_Yaw_NoSpring_SmoothTime_Boosting )

	

		SetConVarFloat( "hover_vehicle_camera_offset_height_base", 			tunings_Shared.cvar_camera_offset_height_base )
		SetConVarFloat( "hover_vehicle_camera_offset_height_speedDelta", 	tunings_Shared.cvar_camera_offset_height_speedDelta )
		SetConVarFloat( "hover_vehicle_camera_smooth_rate", 				tunings_Shared.cvar_camera_smooth_rate )


	
	SetConVarBool	( "hover_vehicle_boost_on_hold",	tunings_Shared.cvar_Boost_On_Hold )
	SetConVarInt	( "hover_vehicle_boost_style",		tunings_Shared.cvar_hover_vehicle_boost_style )
	

	
	SetConVarInt( "hover_vehicle_air_brake_style", tunings_Shared.cvar_Air_Brake_Style )

	
	SetConVarBool( "hover_vehicle_health_start_on",	tunings_Shared.cvar_Health_Start_On )

	
	SetConVarBool( "hover_vehicle_eject_enabled",	tunings_Shared.cvar_Eject_Enabled  )


		SetConVarBool( "hover_vehicle_reset_camera_while_embarking", tunings_Shared.cvar_reset_camera_while_embarking  )
		SetConVarBool( "hover_vehicle_full_recharge_on_zero_boost", tunings_Shared.cvar_hover_vehicle_full_recharge )	

		
		SetConVarInt	( "hover_vehicle_glide_type", 			tunings_Shared.cvar_hover_vehicle_glide_type )
		SetConVarFloat	( "hover_vehicle_glide_debounce", 		tunings_Shared.cvar_hover_vehicle_glide_debounce )
		SetConVarFloat	( "hover_vehicle_glide_thrust_speed", 	tunings_Shared.cvar_hover_vehicle_glide_thrust_speed )
		SetConVarFloat	( "hover_vehicle_glide_descent_speed",	tunings_Shared.cvar_hover_vehicle_glide_descent_speed )
		SetConVarBool	( "hover_vehicle_glide_when_ascending", tunings_Shared.cvar_hover_vehicle_glide_when_ascending )
		SetConVarFloat	( "hover_vehicle_glide_max_thrust",		tunings_Shared.cvar_hover_vehicle_glide_max_thrust )
		SetConVarFloat	( "hover_vehicle_glide_min_thrust",		tunings_Shared.cvar_hover_vehicle_glide_min_thrust )
		SetConVarFloat	( "hover_vehicle_glide_to_min_thrust_duration",		tunings_Shared.cvar_hover_vehicle_glide_to_min_thrust_duration )
		SetConVarFloat	( "hover_vehicle_glide_air_accel",		tunings_Shared.cvar_hover_vehicle_glide_air_accel )
		SetConVarFloat	( "hover_vehicle_glide_tightness_up",	tunings_Shared.cvar_hover_vehicle_glide_tightness_up )
		SetConVarFloat	( "hover_vehicle_glide_tightness_down",	tunings_Shared.cvar_hover_vehicle_glide_tightness_down )
		SetConVarFloat	( "hover_vehicle_glide_max_duration", 	tunings_Shared.cvar_hover_vehicle_glide_max_duration )


	SetConVarFloat( "hover_vehicle_hover_height", tunings_Shared.cvar_hover_vehicle_hover_height )
}



bool function HoverVehicle_Rework_Enabled()
{
	return( file.hovervehicle_rework_enabled )
}

void function Tunings_Init()
{
#if DEV

			DevOut( FUNC_NAME() + "(): VEHICLE REWORK ON" )



#endif


	
		if( !HoverVehicle_Rework_Enabled() )
		{
			Tunings_Use_Old()
		}



	Tunings_Shared_PLV_Set()

	
	sTunings_HoverVehicle tunings_Trident
	Tunings_Vehicle_Setup_From_PLV_And_Defaults( tunings_Trident, tunings_Trident_Default, eHoverVehicleTypes.TRIDENT )
	VehicleTunings_ByType_Set( eHoverVehicleTypes.TRIDENT, tunings_Trident )

	
	sTunings_HoverVehicle tunings_Trident_OldModel_Default

		
		tunings_Trident_OldModel_Default.vehModel = HOVER_VEHICLE_MODEL_OLD
		tunings_Trident_OldModel_Default.vehDestruction_VFX = FX_VEHICLE_DEATH_FX_OLD
		sTunings_HoverVehicle tunings_Trident_OldModel
		Tunings_Vehicle_Setup_From_PLV_And_Defaults( tunings_Trident_OldModel, tunings_Trident_OldModel_Default, eHoverVehicleTypes.TRIDENT_OLDMODEL )
		VehicleTunings_ByType_Set( eHoverVehicleTypes.TRIDENT_OLDMODEL, tunings_Trident_OldModel )


	
}



void function Tunings_Use_Old()
{
	Tunings_Shared_Use_Old()
	Tunings_Trident_Use_Old()
}

