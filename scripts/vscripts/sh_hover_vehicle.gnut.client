void function HoverVehicle_SV2CL_ParkedIcon_Create( entity vehicle )
{
	if( !IsValid( vehicle ) )
		return

	EHI vehicleEHI = ToEHI( vehicle )
	if( file.vehicleEHIs_WithParkedIcons.contains( vehicleEHI ) )
		return

	thread CL_ParkedIcon_Think_Thread( vehicle )
	file.vehicleEHIs_WithParkedIcons.append( vehicleEHI )
}

void function HoverVehicle_SV2CL_ParkedIcon_Destroy( entity vehicle )
{
	EHI vehicleEHI = ToEHI( vehicle )
	if( !file.vehicleEHIs_WithParkedIcons.contains( vehicleEHI ) )
		return

	vehicle.Signal( SIG_HOVERVEHICLE_PARKEDICON ) 
}

void function CL_ParkedIcon_Think_Thread( entity vehicle )
{
	if( !IsValid( vehicle ) )
		return

	if( !EntIsHoverVehicle( vehicle ) )
		return

	vehicle.Signal( SIG_HOVERVEHICLE_PARKEDICON )
	vehicle.EndSignal( SIG_HOVERVEHICLE_PARKEDICON )
	vehicle.EndSignal( "OnDestroy" )

	vector loc = vehicle.GetOrigin()
	vector ang = FlattenVec( vehicle.GetAngles() )
	vector iconColor = COLOR_DARK_GRAY

	const float SCALE_MINIMAP = 1.2
	const float SCALE_FULLMAP = 12

	var minimapRui = Minimap_AddIconAtPosition	( loc, ang, HOVER_VEHICLE_SPAWNPOINT_ICON, 	SCALE_MINIMAP, iconColor )
	var fullmapRui = FullMap_AddIconAtPos		( loc, ang + < 0, -90, 0 >, HOVER_VEHICLE_SPAWNPOINT_ICON,	SCALE_FULLMAP, iconColor )

	OnThreadEnd(
		function(): ( vehicle, minimapRui, fullmapRui )
		{
			Minimap_CommonCleanup( minimapRui )
			Fullmap_RemoveRui( fullmapRui )
			RuiDestroy( fullmapRui )

			EHI vehicleEHI = ToEHI( vehicle )
			file.vehicleEHIs_WithParkedIcons.fastremovebyvalue( vehicleEHI )
		}
	)

	
	
	
	

	WaitForever()
}

























 





























































































































#if DEV
void function DevOut( string printMe )
{
	if( !file.devOut )
		return

	printt( ":>>" + printMe )
}

void function DevOut_DamageSourceId( int damageSrc )
{
	if( !file.devDmg )
		return

	string damageSource = GetEnumStringSlow( eDamageSourceId, damageSrc )

	float timeDelta = Time() - file.devDmg_LastTime
	if( timeDelta < file.devDmg_Debounce )
		return

	DevOut( "Damage Source == " + damageSource )
	file.devDmg_LastTime = Time()
}

#endif
