void function Tunings_Shared_PLV_Set()
{
	
	tunings_Shared.cvar_Camera_Yaw_Spring_Enabled			= GetCurrentPlaylistVarBool( "hoverveh_camera_yaw_spring_enabled", 			tunings_Shared_Default.cvar_Camera_Yaw_Spring_Enabled )
	tunings_Shared.cvar_Camera_Yaw_NoSpring_SmoothTime		= GetCurrentPlaylistVarFloat( "hoverveh_camera_yaw_nospring_smoothtime", 	tunings_Shared_Default.cvar_Camera_Yaw_NoSpring_SmoothTime )
	tunings_Shared.cvar_Camera_Yaw_NoSpring_SmoothTime_Boosting		= GetCurrentPlaylistVarFloat( "hoverveh_camera_yaw_nospring_smoothtime_boosting", 	tunings_Shared_Default.cvar_Camera_Yaw_NoSpring_SmoothTime_Boosting )

	
	tunings_Shared.cvar_camera_offset_height_base		= GetCurrentPlaylistVarFloat( "hoverveh_camera_offset_height_base", 		tunings_Shared_Default.cvar_camera_offset_height_base )
	tunings_Shared.cvar_camera_offset_height_speedDelta = GetCurrentPlaylistVarFloat( "hoverveh_camera_offset_height_speeddelta", 	tunings_Shared_Default.cvar_camera_offset_height_speedDelta )
	tunings_Shared.cvar_camera_smooth_rate				= GetCurrentPlaylistVarFloat( "hoverveh_camera_smooth_rate", 				tunings_Shared_Default.cvar_camera_smooth_rate )
	tunings_Shared.cvar_reset_camera_while_embarking	= GetCurrentPlaylistVarBool( "hover_vehicle_reset_camera_while_embarking", 	tunings_Shared_Default.cvar_reset_camera_while_embarking )

	
	tunings_Shared.cvar_Boost_On_Hold					= GetCurrentPlaylistVarBool	( "hoverveh_boost_on_hold", 	tunings_Shared_Default.cvar_Boost_On_Hold )
	tunings_Shared.cvar_hover_vehicle_boost_style 		= GetCurrentPlaylistVarInt	( "hover_vehicle_boost_style", 	tunings_Shared_Default.cvar_hover_vehicle_boost_style )

	
	tunings_Shared.cvar_Air_Brake_Style = GetCurrentPlaylistVarInt( "hoverveh_air_brake_style",	tunings_Shared_Default.cvar_Air_Brake_Style )

	
	tunings_Shared.cvar_Health_Start_On	= GetCurrentPlaylistVarBool( "hoverveh_health_start_on", 	tunings_Shared_Default.cvar_Health_Start_On )

	
	tunings_Shared.cvar_Eject_Enabled	= GetCurrentPlaylistVarBool( "hoverveh_eject_enabled", tunings_Shared_Default.cvar_Eject_Enabled )
	tunings_Shared.cvar_Smoke_Enabled	= GetCurrentPlaylistVarBool( "hoverveh_smoke_enabled", tunings_Shared_Default.cvar_Smoke_Enabled )

	
	tunings_Shared.autoRespawn_Enabled 	= GetCurrentPlaylistVarBool( "hoverveh_autorespawn_enabled", tunings_Shared_Default.autoRespawn_Enabled )
	tunings_Shared.autoRespawn_Delay	= GetCurrentPlaylistVarFloat( "hoverveh_autorespawn_delay",  tunings_Shared_Default.autoRespawn_Delay )

	
	tunings_Shared.damagePropagation_Enabled = GetCurrentPlaylistVarBool( "hoverveh_damagepropagation_enabled", tunings_Shared_Default.damagePropagation_Enabled )

	
	tunings_Shared.vo_VehicleDamaged_Enabled = GetCurrentPlaylistVarBool( "hoverveh_vo_vehicledamaged_enabled", tunings_Shared_Default.vo_VehicleDamaged_Enabled )


		if( HoverVehicle_Rework_Enabled() )
		{
