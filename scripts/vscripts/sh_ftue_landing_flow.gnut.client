bool function FTUEFlow_IsConVarDisabled()
{
	if ( !GetConVarBool( "ftue_flow_enabled" ) || GetConVarBool( "orientation_matches_disabled" ) )
	{
		return true
	}

#if DEV
	if ( GetConVarBool( "skip_training" ) )
	{
		return true
	}
#endif

	return false
}



bool function FTUEFlow_IsFTUEFlowEnabled( entity player )
{
	if ( FTUEFlow_IsConVarDisabled() )
	{
		return false
	}


		if ( !IsFullyConnected() )
			return true


	if ( GetCurrentPlaylistVarBool( "ftue_flow_disabled", false ) )
	{
		return false
	}

	return true
}




















































































































