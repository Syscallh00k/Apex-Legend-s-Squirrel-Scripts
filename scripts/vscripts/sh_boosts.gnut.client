void function ShPlayerPass_LevelInit()
{
	AddCallback_RegisterRootItemFlavors( OnRegisterRootItemFlavors )











		Remote_RegisterServerFunction ( "ClientCallback_UpdatePlayerPassAssignment" )
		Remote_RegisterServerFunction( "ClientCallback_rppAssignmentAcknowledged" )
		Remote_RegisterServerFunction( "ClientCallback_UpdatePassLastInfo", "int", 0, ePassLastSeenType.COUNT - 1, "itemflavor", eItemType.battlepass ) 
		Remote_RegisterServerFunction( "ClientCallback_UpdateAllPassLastInfo", "int", 0, ePassLastSeenType.COUNT - 1 )


	AddCallback_OnItemFlavorRegistered( eItemType.battlepass, void function( ItemFlavor pass ) {
		if ( PlayerPass_IsPassOfType( pass, ePassType.SEASONAL ) )
		{
			return 
		}
		if ( PlayerPass_IsPassOfType( pass, ePassType.ACCOUNT ) )
		{
			return 
		}

#if CHALLENGE_DEBUG
			printt( FUNC_NAME() )
#endif

		PlayerPassData passData
		passData.pass = pass

		var passDataTable = BattlePass_GetScheduleDatatable( pass )
		int numRows       = GetDataTableRowCount( passDataTable )
		int maxLevels     = GetDataTableInt( passDataTable, numRows - 1, GetDataTableColumnByName( passDataTable, "levelIndex" ) ) + 1

		passData.maxPassLevel = maxLevels - 1 


		if ( BattlePass_GetType( pass ) == ePassType.LEGEND )
			PlayerPass_GetLinkedChallengeCollection( pass ) 


		file.passDataMap[pass] <- passData
	} )
}

void function OnRegisterRootItemFlavors()
{
	foreach ( asset battlePassAsset in GetBaseItemFlavorsFromArray( "nonSeasonalPasses" ) )
	{
		if ( battlePassAsset == $"" )
		{
			continue
		}

		ItemFlavor ornull battlePass = RegisterItemFlavorFromSettingsAsset( battlePassAsset )
		if ( battlePass == null )
		{
			continue
		}

		expect ItemFlavor( battlePass )
		if ( PlayerPass_IsPassOfType( battlePass, ePassType.SEASONAL ) )
		{
			continue
		}

		if ( GetGlobalSettingsBool( ItemFlavor_GetAsset( battlePass ), "latestVersionPass" ) )
		{
			if ( PlayerPass_IsPassOfType( battlePass, ePassType.NEWPLAYER ) )
			{
				if ( PlayerPass_GetLatestPassOfType( ePassType.NEWPLAYER ) != null )
				{
					if ( ItemFlavor_GetGUID( battlePass ) != ItemFlavor_GetGUID( expect ItemFlavor( PlayerPass_GetLatestPassOfType( ePassType.NEWPLAYER ) ) ) )
					{
						Assert( false, "Multiple NPPs " + ItemFlavor_GetGUIDString( battlePass ) + " and " + ItemFlavor_GetGUIDString( expect ItemFlavor( PlayerPass_GetLatestPassOfType( ePassType.NEWPLAYER ) ) ) + " are marked as the current NPP. Correct in bakery." )
					}
				}
				else
				{
					PlayerPass_SetLatestVersionPassOfType( ePassType.NEWPLAYER, battlePass )
				}
			}

			if ( PlayerPass_IsPassOfType( battlePass, ePassType.RETURNING_PLAYER ) )
			{
				if ( PlayerPass_GetLatestPassOfType( ePassType.RETURNING_PLAYER ) != null )
				{
					if ( ItemFlavor_GetGUID( battlePass ) != ItemFlavor_GetGUID( expect ItemFlavor( PlayerPass_GetLatestPassOfType( ePassType.RETURNING_PLAYER ) ) ) )
					{
						Assert( false, "Multiple RPPs " + ItemFlavor_GetGUIDString( battlePass ) + " and " + ItemFlavor_GetGUIDString( expect ItemFlavor( PlayerPass_GetLatestPassOfType( ePassType.RETURNING_PLAYER ) ) ) + " are marked as the current RPP. Correct in bakery." )
					}
				}
				else
				{
					PlayerPass_SetLatestVersionPassOfType( ePassType.RETURNING_PLAYER, battlePass )
				}
			}

			foreach ( int index, var voucherBlock in IterateSettingsAssetArray( ItemFlavor_GetAsset( battlePass ), "nonStarVouchers" ) )
			{
				RegisterItemFlavorFromSettingsAsset( GetSettingsBlockAsset( voucherBlock, "voucherFlav" ) )
			}
		}
	}
}



