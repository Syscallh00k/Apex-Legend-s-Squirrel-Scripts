void function PlayerPass_SetLatestVersionPassOfType( int passType, ItemFlavor ornull pass )
{
	switch ( passType )
	{
		case ePassType.NEWPLAYER:
			file.latestVersionNPP = pass
			break

		case ePassType.RETURNING_PLAYER:
			file.latestVersionRPP = pass
			break
	}
}

bool function PlayerPass_IsPassOfType( ItemFlavor pass, int passType )
{
	if ( pass.typeIndex != eItemType.battlepass )
	{
		Assert( false, "Called PlayerPass_IsPassOfType on non-Battlepass Item Flavor" )
		return false
	}

	return ( BattlePass_GetType( pass ) == passType )
}

array< ItemFlavor > function PlayerPass_GetAllPassesOfType( int passType )
{
	array< ItemFlavor > passes
	foreach ( ItemFlavor pass in GetAllItemFlavorsOfType( eItemType.battlepass ) )
	{
		if ( BattlePass_GetType( pass ) == passType )
		{
			passes.append( pass )
		}
	}

	return passes
}

ItemFlavor ornull function PlayerPass_GetLatestPassOfType( int passType )
{
	ItemFlavor ornull passOrNull = null

	switch ( passType )
	{
		case ePassType.NEWPLAYER:
			passOrNull = file.latestVersionNPP
			break

		case ePassType.RETURNING_PLAYER:
			passOrNull = file.latestVersionRPP
			break
	}

	return passOrNull
}

int function PlayerPass_GetMaxLevelIndex( ItemFlavor pass )
{
	PlayerPassData passData = file.passDataMap[pass]
	return passData.maxPassLevel
}

ItemFlavor ornull function PlayerPass_GetLinkedChallengeCollection( ItemFlavor pass )
{
	if ( pass.typeIndex != eItemType.battlepass )
	{
		Assert( false, "Called PlayerPass_IsPassOfType on non-Battlepass Item Flavor" )
		return null
	}

	asset linkedChallengeCollectionAsset = GetGlobalSettingsAsset( ItemFlavor_GetAsset( pass ), "linkedChallengeCollection" )
	if ( linkedChallengeCollectionAsset == $"" )
	{
		return null
	}

	if ( IsValidItemFlavorSettingsAsset( linkedChallengeCollectionAsset ) )
		return GetItemFlavorByAsset( linkedChallengeCollectionAsset )

	return RegisterItemFlavorFromSettingsAsset( linkedChallengeCollectionAsset )
}









































var function PlayerPass_GetFallbackRewardDataTable( ItemFlavor pass )
{
	Assert( ItemFlavor_GetType( pass ) == eItemType.battlepass )

	asset rewardScheduleAsset = GetGlobalSettingsAsset( ItemFlavor_GetAsset( pass ), "nonSeasonalFallbackRewardDatatable" )

	if ( rewardScheduleAsset == $"" )
	{
		return rewardScheduleAsset
	}

	return GetDataTable( rewardScheduleAsset )
}

int function PlayerPass_GetDaysDuration( ItemFlavor pass )
{
	Assert( ItemFlavor_GetType( pass ) == eItemType.battlepass )

	int daysDuration = GetGlobalSettingsInt( ItemFlavor_GetAsset( pass ), "bpv2DaysDuration" )

	if ( PlayerPass_IsPassOfType( pass, ePassType.RETURNING_PLAYER ) )
	{
		daysDuration = GetPlaylistVarInt( GetCurrentPlaylistName(), "rpp_days_duration_override", daysDuration )
	}

	return daysDuration
}

bool function PlayerPass_IsPassTypeActive( entity player, int passType )
{
	bool isTypeEnabled

	switch ( passType )
	{
		case ePassType.NEWPLAYER:
			isTypeEnabled = PlayerPass_IsFeatureEnabled( ePassType.NEWPLAYER )
			break

		case ePassType.RETURNING_PLAYER:
			isTypeEnabled = PlayerPass_IsFeatureEnabled( ePassType.RETURNING_PLAYER )
			break

		case ePassType.LEGEND:
			isTypeEnabled = PlayerPass_IsFeatureEnabled( ePassType.LEGEND )
			break

		case ePassType.ACCOUNT:
			isTypeEnabled = PlayerPass_IsFeatureEnabled( ePassType.ACCOUNT )
			break
	}

	if ( !isTypeEnabled )
	{
		return false
	}

	if ( !IsValid( player ) )
	{
		return false
	}









	bool active

	switch ( passType )
	{
		case ePassType.NEWPLAYER:
			active = bool( player.GetPersistentVar( NPP_IS_ACTIVE_PVAR ) )
			break

		case ePassType.RETURNING_PLAYER:
			active = bool( player.GetPersistentVar( RPP_IS_ACTIVE_PVAR ) )
			break


		case ePassType.LEGEND:
			
			for ( int passArrayIdx = 0 ; passArrayIdx < NUM_ACTIVE_PLAYER_PASSES ; passArrayIdx++ )
			{
				ItemFlavor ornull pass = PlayerPass_GetPassAtPersistenceSlot( player, passArrayIdx )
				if ( pass != null )
				{
					int persistencePassType = BattlePass_GetType( expect ItemFlavor( pass ) )
					if ( persistencePassType == ePassType.LEGEND )
					{
						active = true
						break
					}
				}
			}
			break

		case ePassType.ACCOUNT:
			active = isTypeEnabled
			break
	}

	return active
}

int function PlayerPass_GetPassLevel( entity player, ItemFlavor pass )
{
	int passLevel
	switch ( BattlePass_GetType( pass ) )
	{
		case ePassType.NEWPLAYER:
			passLevel = player.GetPersistentVarAsInt( NPP_CARD_PVAR ) / PLAYER_PASSES_XP_PER_LEVEL
			break

		case ePassType.ACCOUNT:
			passLevel = GetPlayerAccountLevel( player )
			break


		default:
			passLevel = player.GetPersistentVarAsInt( format( PLAYER_PASSES_PDEF_PVAR_FORMAT_STRING, ItemFlavor_GetGUIDString( pass ), PLAYER_PASSES_PDEF_XP_PVAR_NAME ) ) / PLAYER_PASSES_XP_PER_LEVEL
			break

	}

	return passLevel
}

int function PlayerPass_GetPassLevelForXP( entity player, ItemFlavor pass, int xp )
{
	int passLevel
	switch ( BattlePass_GetType( pass ) )
	{
		case ePassType.ACCOUNT:
			passLevel = GetAccountLevelForXP( xp )
			break

		default:
			passLevel = xp / PLAYER_PASSES_XP_PER_LEVEL
			break
	}

	return passLevel
}

int function PlayerPass_GetCurrentLevelProgress( entity player, ItemFlavor pass )
{
	int levelProgress

	switch ( BattlePass_GetType( pass ) )
	{
		case ePassType.NEWPLAYER:
			levelProgress = player.GetPersistentVarAsInt( NPP_CARD_PVAR ) % PLAYER_PASSES_XP_PER_LEVEL
			break


		default:
			levelProgress = PlayerPass_GetProgress( player, pass ) % PLAYER_PASSES_XP_PER_LEVEL
			break

	}

	return levelProgress
}

int function PlayerPass_GetExpirationTime( entity player, int passType )
{
	int expirationTime

	switch ( passType )
	{
		case ePassType.NEWPLAYER:
			expirationTime = player.GetPersistentVarAsInt( NPP_EXPIRATION_TIME_PVAR )
			break

		case ePassType.RETURNING_PLAYER:
			expirationTime = player.GetPersistentVarAsInt( RPP_EXPIRATION_TIME_PVAR)
	}

	return expirationTime
}

ItemFlavor ornull function PlayerPass_GetAssignedPass( entity player, int passType )
{

	Assert( passType != ePassType.LEGEND )


	switch ( passType )
	{
		case ePassType.NEWPLAYER:
			if ( PlayerPass_IsActive( player, ePassType.NEWPLAYER ) )
			{
				return GetItemFlavorOrNullByGUID( player.GetPersistentVarAsInt( "nppAssignedGUID" ) )
			}
			break

		case ePassType.RETURNING_PLAYER:
			if ( PlayerPass_IsActive( player, ePassType.RETURNING_PLAYER ) )
			{
				return GetItemFlavorOrNullByGUID( player.GetPersistentVarAsInt( "rppAssignedGUID" ) )
			}
			break

		case ePassType.ACCOUNT:
			if ( PlayerPass_IsActive( player, ePassType.ACCOUNT ) )
			{




				return GetAccountProgressionPass()

			}
			break
	}

	return null
}

array<ItemFlavor> function PlayerPass_GetAssignedPassesOfType( entity player, int passType )
{
	array<ItemFlavor> passes

	switch ( passType )
	{
		case ePassType.NEWPLAYER:
			if ( PlayerPass_IsActive( player, ePassType.NEWPLAYER ) )
			{
				ItemFlavor ornull npp = GetItemFlavorOrNullByGUID( player.GetPersistentVarAsInt( "nppAssignedGUID" ) )
				if ( npp != null )
				{
					passes.append( expect ItemFlavor( npp ) )
				}
			}
			break

		case ePassType.RETURNING_PLAYER:
			if ( PlayerPass_IsActive( player, ePassType.RETURNING_PLAYER ) )
			{
				ItemFlavor ornull rpp = GetItemFlavorOrNullByGUID( player.GetPersistentVarAsInt( "rppAssignedGUID" ) )
				if ( rpp != null )
				{
					passes.append( expect ItemFlavor( rpp ) )
				}
			}
			break

		case ePassType.LEGEND:
			if ( PlayerPass_IsActive( player, ePassType.LEGEND ) )
			{
				for ( int passArrayIdx = 0 ; passArrayIdx < NUM_ACTIVE_PLAYER_PASSES ; passArrayIdx++ )
				{
					ItemFlavor ornull pass = PlayerPass_GetPassAtPersistenceSlot( player, passArrayIdx )
					if ( pass != null )
					{
						passes.append( expect ItemFlavor( pass ) )
					}
				}
			}
			break

	}

	return passes
}

bool function PlayerPass_GetCompleteAcknowledged( entity player, ItemFlavor pass )
{
	switch ( BattlePass_GetType( pass ) )
	{
		case ePassType.NEWPLAYER:
			return bool( player.GetPersistentVar( NPP_COMPLETE_ACK_PVAR ) )


		default:
			return bool( player.GetPersistentVar( format( PLAYER_PASSES_PDEF_PVAR_FORMAT_STRING, ItemFlavor_GetGUIDString( pass ), PLAYER_PASSES_PDEF_COMPLETE_ACK_PVAR ) ) )

	}

	return false
}

bool function PlayerPass_IsFeatureEnabled( int passType )
{
	bool isEnabled = true


	if ( !IsFullyConnected() )
	{
		return isEnabled
	}


	switch ( passType )
	{
		case ePassType.NEWPLAYER:
			isEnabled = GetCurrentPlaylistVarBool( NPP_KILLSWITCH_VAR, true )
			break

		case ePassType.RETURNING_PLAYER:
			isEnabled = GetCurrentPlaylistVarBool( RPP_KILLSWITCH_VAR, true )
			break


		case ePassType.LEGEND:
			isEnabled = GetCurrentPlaylistVarBool( LEGENDPASS_KILLSWITCH_VAR, true )
			break

		case ePassType.ACCOUNT:
			isEnabled = GetCurrentPlaylistVarBool( ACCOUNTPASS_KILLSWITCH_VAR, true )
			break
	}

	return isEnabled
}

bool function PlayerPass_IsFeatureAssignmentEnabled( int passType )
{
	bool isEnabled = true

	switch ( passType )
	{
		case ePassType.NEWPLAYER:
#if DEV
				if ( GetConVarBool( "ftue_npp_assignment_enabled" ) == false )
				{
					return false
				}
#endif

			isEnabled = GetCurrentPlaylistVarBool( NPP_ASSIGNMENT_KILLSWITCH_VAR, true )
			break

		case ePassType.RETURNING_PLAYER:
#if DEV
				if ( GetConVarBool( "rpp_assignment_enabled" ) == false )
				{
					return false
				}
#endif

			isEnabled = GetCurrentPlaylistVarBool( RPP_ASSIGNMENT_KILLSWITCH_VAR, true )
			break


			isEnabled = GetCurrentPlaylistVarBool( LEGENDPASS_ASSIGNMENT_KILLSWITCH_VAR, true )

	}

	return isEnabled
}




























int function PlayerPass_GetOwnershipState( ItemFlavor pass, entity player = null )
{
	Assert( BattlePass_GetType( pass ) == ePassType.LEGEND ) 




		Assert( player != null )
		Assert( GRX_IsInventoryReady( player ) )


	ItemFlavor ornull currentSeason = GetActiveSeason( GetUnixTimestamp() )
	int purchaseTimestamp = player.GetPersistentVarAsInt( format( PLAYER_PASSES_PDEF_PVAR_FORMAT_STRING, ItemFlavor_GetGUIDString( pass ), PLAYER_PASSES_PDEF_ASSIGN_TIME_PVAR ) )
	ItemFlavor ornull seasonOfPurchase = GetActiveSeason( purchaseTimestamp )
	if ( purchaseTimestamp != 0 )
	{
		if ( seasonOfPurchase == currentSeason )
			return ePassOwnershipState.CANNOT_BUY_LOCKED

		return ePassOwnershipState.CAN_BUY_REPURCHASE
	}

	return ePassOwnershipState.CAN_BUY_FIRST_TIME
}


bool function PlayerPass_IsActive( entity player, int passType )
{
	bool active = false

	if ( !PlayerPass_IsFeatureEnabled( passType ) )
	{
		return false
	}

	switch ( passType )
	{
		case ePassType.NEWPLAYER:
			
			if ( player.GetPersistentVarAsInt( "installUnixTime" ) == 0 )
			{
				active = true
				break
			}

			if ( PlayerPass_IsPassTypeActive( player, ePassType.NEWPLAYER ) )
			{
				active = true
				break
			}
			break

		case ePassType.RETURNING_PLAYER:

			if ( PlayerPass_IsPassTypeActive( player, ePassType.RETURNING_PLAYER ) )
			{
				active = true
				break
			}
			break


		case ePassType.LEGEND:
			if ( PlayerPass_IsPassTypeActive( player, ePassType.LEGEND ) )
			{
				active = true
				break
			}
			break


		case ePassType.ACCOUNT:
			if ( PlayerPass_IsPassTypeActive( player, ePassType.ACCOUNT ) )
				return true 
	}

	return active
}



int function PlayerPass_GetPersistenceSlot( entity player, ItemFlavor passFlav )
{
	Assert( ItemFlavor_GetType( passFlav ) == eItemType.battlepass )
	for ( int passArrayIdx = 0 ; passArrayIdx < NUM_ACTIVE_PLAYER_PASSES ; passArrayIdx++ )
	{
		SettingsAssetGUID passGuid = player.GetPersistentVarAsInt( format( PASSES_PVAR_KEY_FSTRING_GUID, passArrayIdx ) )
		if ( passGuid == passFlav.guid )
			return passArrayIdx
	}

	return -1
}

ItemFlavor ornull function PlayerPass_GetPassAtPersistenceSlot( entity player, int passArrayIdx )
{
	SettingsAssetGUID passGuid = player.GetPersistentVarAsInt( format( PASSES_PVAR_KEY_FSTRING_GUID, passArrayIdx ) )
	if ( passGuid > 0 )
		return GetItemFlavorOrNullByGUID( passGuid )

	return null
}
































bool function PlayerPass_IsAssigned( entity player, ItemFlavor passFlav )
{
	return PlayerPass_GetPersistenceSlot( player, passFlav ) >= 0
}

bool function PlayerPass_IsLegendPass( ItemFlavor flav )
{
	return ( ItemFlavor_GetType( flav ) == eItemType.battlepass && BattlePass_GetType( flav ) == ePassType.LEGEND )
}





























int function PlayerPass_GetProgress( entity player, ItemFlavor pass )
{
	Assert(  BattlePass_GetType( pass ) != ePassType.SEASONAL )
	int passType = BattlePass_GetType( pass )
	switch ( passType )
	{
 		case ePassType.NEWPLAYER:
			return player.GetPersistentVarAsInt( NPP_CARD_PVAR )

		case ePassType.ACCOUNT:



				return player.GetPersistentVarAsInt( "xp" )


		default:
			string pvarName = format( PLAYER_PASSES_PDEF_PVAR_FORMAT_STRING, ItemFlavor_GetGUIDString( pass ), PLAYER_PASSES_PDEF_XP_PVAR_NAME )
			return player.GetPersistentVarAsInt( pvarName )
	}
	unreachable
}

int function PlayerPass_GetLastSeenProgress( entity player, ItemFlavor pass, int source )
{
	int passType = BattlePass_GetType( pass )
	string baseString
	switch ( passType )
	{
		case ePassType.SEASONAL:
			baseString = format( BATTLE_PASS_PDEF_PREFIX + "[%s]", ItemFlavor_GetGUIDString( pass ) )
			break

		case ePassType.NEWPLAYER:
			baseString = format( NEW_PLAYER_PASS_PDEF_PREFIX + "[%s]", ItemFlavor_GetGUIDString( pass ) )
			break

		case ePassType.ACCOUNT:
		default:
			baseString = format( PLAYER_PASSES_PDEF_PREFIX + "[%s]", ItemFlavor_GetGUIDString( pass ) )
			break
	}

	switch ( source )
	{
		case ePassLastSeenType.LOBBY:



			return player.GetPersistentVarAsInt( baseString + "." + PLAYER_PASSES_PDEF_LOBBY_LAST_SEEN_PVAR )

			break

		default:



			return player.GetPersistentVarAsInt(  baseString + "." + PLAYER_PASSES_PDEF_LAST_SEEN_PVAR )

			break
	}
	unreachable
}

































































































































































































































































































































































































































































































































































































