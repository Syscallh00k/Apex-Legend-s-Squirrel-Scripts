];

const array< asset > REBUILD_VFXS = [
	
	$"P_breachglass_rebuild_sm", 
	$"P_breachglass_rebuild_sm", 
	$"P_breachglass_rebuild_sm_wide", 

	
	$"P_breachglass_rebuild_med", 
