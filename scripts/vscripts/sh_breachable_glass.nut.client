const string SIG_BREACHABLE_GLASS_REBUILT = "BreachableGlass_Rebuilt"
const string SIG_BREACH_GLASS_USE_FAIL = "BreachableGlass_UseFail"
const string SIG_BREACHABLE_GLASS_SELF_HEAL = "BreachableGlass_SelfHeal"
const string SIG_BREACHABLE_GLASS_DECAY = "BreachableGlass_Decay"
global const string SIG_BREACHABLE_GLASS_BREAK = "BreachableGlass_Break"

global const string BREACH_GLASS_SCRIPTNAME = "breachable_glass"

global enum eGlassSize
{
	SMALL,
	MEDIUM,
	LARGE,
	_COUNT
}

global enum eGlassShape
{
	NARROW,
	SQUARE,
	WIDE,
	_COUNT
}

struct
{
	table< entity, float > hardlightRegenDebounceTracker
	table< entity, bool > hardLightFirstReset
	table< entity, float > reinforceBlockEndTimes
	table< entity, entity > reinforcedGlassOwner
	table< entity, array< entity > > playerReinforcedGlass
	table< int, bool > initializedRealms
} file

struct
{
	float breachableGlassRestoreTime = 70.0










	float meleeDamage = 200.0
	bool reinforceEnabled = true
	float reinforceUseDuration = 0.45

	bool controllerOnlyReinforce = true
	bool shieldBoysCanReinforce = false
	bool onlyCatalystMaxReinforce = false

	bool reinforceBlockedAfterDestruction = true
	float reinforcementBlockDuration = 4.0
	float playerReinforceCooldown = 0.0

	bool wattsonHardlightRegenEnabled = true
	float wattsonHardlightRegenRadius = 13 * METERS_TO_INCHES
	float wattsonHardlightRegenDebounceDuration = 6.0

	bool empDestroysBreachGlass = true

	bool blackholeDestroysBreachGlass = true

	bool hardlightSelfHealEnabled = true
	float hardlightSelfHealTime = 70.0
	float hardlightSelfHealRate = 10.0

	bool reinforcedGlassDecayEnabled = true
	float reinforcedGlassDecayDistanceSqr = 150.0 * METERS_TO_INCHES
	int reinforcedGlassMaxPerPlayer = 4
	float globalHealthDecay = 4000.0

	float healthOverride = 200.0
	float reinforcedHealthOverride = 1250.0
	float maxReinforcedHealthOverride = 1600.0

	float useDistance = 150.0

	float mediumSizeThreshold = 150000.0 
	float largeSizeThreshold = 300000.0 

	bool disableBreachGlassDamage = false 
	bool blockBreachGlassSpawn = false 
} tunings

