const asset BREAKABLE_DOOR_DAMAGED_MODEL = $"mdl/door/canyonlands_door_single_02_damaged.rmdl"
const asset BREAKABLE_DOOR_DAMAGED_MODEL_AVT = $"mdl/door/canyonlands_door_single_02_damaged_avt.rmdl"
const asset BREAKABLE_DOOR_DAMAGED_FX = $"P_door_damaged"
const asset BREAKABLE_DOOR_DESTRUCTION_FX = $"P_door_breach"

const bool BLOCKABLE_DOOR_DEBUG = false

const float GUARANTEED_KICK_OFFSET = 0.5

global struct DoorData
{
	string          className
	string          scriptName
	vector          origin
	vector          angles
	int             realm
	asset           modelName
	entity          linkDoor
	bool            hasLinkDoor
	DoorData ornull linkDoorData
}

struct Tuning
{




















}
Tuning tuning

struct
{









	array<entity> allCodeDoors
} file

void function ShDoors_Init()
{
	SetupTuning()

	PrecacheScriptString( "survival_door_model" )
	PrecacheScriptString( "survival_door_blockable" )
	PrecacheScriptString( "survival_door_sliding" )
	PrecacheScriptString( "survival_door_plain" )

	PrecacheModel( BREAKABLE_DOOR_DAMAGED_MODEL )
	PrecacheModel( BREAKABLE_DOOR_DAMAGED_MODEL_AVT )
	PrecacheParticleSystem( BREAKABLE_DOOR_DAMAGED_FX )
	PrecacheParticleSystem( BREAKABLE_DOOR_DESTRUCTION_FX )





















		AddCreateCallback( "prop_door", OnCodeDoorCreated_Client )
		AddDestroyCallback( "prop_door", OnCodeDoorDestroyed_Client )


}

void function SetupTuning()
{
	Tuning defaultTuning




















}

#if INTELLIJ_OUTLINE_SECTION_MARKER
void function _____________CommonHelpers___________________________(){}
#endif
bool function IsDoor( entity ent )
{
	if ( IsCodeDoor( ent ) )
		return true

	if ( IsPlainDoor( ent ) )
			return true

	return false
}

bool function IsCodeDoor( entity door )
{
	return door.GetNetworkedClassName() == "prop_door"
}

bool function IsPlainDoor( entity door )
{
	return door.GetScriptName() == "survival_door_plain"
}

bool function IsDoorOpen( entity door )
{
	if ( !IsDoor( door ) )
		return false

	if ( IsCodeDoor( door ) )
	{
		return door.IsDoorOpen()
	}
	else
	{
		return GradeFlagsHas( door, eGradeFlags.IS_OPEN ) 
	}

	return false
}

bool function DoorsAreEnabled()
{
	return GetCurrentPlaylistVarBool( "enable_doors", true )
}

































































