		[ eDamageSourceId.prowler_melee ] = "#DEATH_PROWLER_MELEE",

			[ eDamageSourceId.spider_melee ] = "#DEATH_SPIDER_MELEE",
			[ eDamageSourceId.spider_ranged ] = "#DEATH_SPIDER_RANGED",

