{
	EndSignal( fileLevel.signalDummy, "MassLootCeremonyExit" )
	EndSignal( fileLevel.signalDummy, "MassLootCeremonyAnimSeqStart" )
	EndSignal( fileLevel.lootTickModel, "MassTickAnimStartDeployment" )

	if ( fileLevel.tickRandomFlashFXStarted )
		return

	fileLevel.tickRandomFlashFXStarted = true

	OnThreadEnd(
		function() : ()
		{
			fileLevel.tickRandomFlashFXStarted = false
		}
	)

	int attachID = tickModel.LookupAttachment( "FX_C_EYE" )

	while( true )
	{
		int rarity  = 0
		int randInt = RandomInt( 1000 )

		if ( randInt > 995 )
			rarity = 4
		if ( randInt > 970 )
			rarity = 3
		else if ( randInt > 900 )
			rarity = 2
		else if ( randInt > 600 )
			rarity = 1

		vector rarityColor = GetFXRarityColorForUnlockable( rarity )

		int fxIndex = StartParticleEffectOnEntity( tickModel, GetParticleSystemIndex( TICK_FX_RARITY_IDLE ), FX_PATTACH_POINT_FOLLOW, attachID )
		EffectSetControlPointVector( fxIndex, 1, rarityColor )

		

		Wait( RandomFloatRange( 0.2, 0.4 ) )
	}
}



void function MassLootCeremony_RarityBeamFX( entity tickModel, string fxAttachment )
{
	int rarity
	switch ( fxAttachment )
	{
		case ATTACHNAME_LEFT:
			rarity = fileLevel.highestsRarities[0]
			break
		case ATTACHNAME_CENTER :
			rarity = fileLevel.highestsRarities[1]
			break
		case ATTACHNAME_RIGHT:
			rarity = fileLevel.highestsRarities[2]
			break
	}

	vector rarityColor = GetFXRarityColorForUnlockable( rarity )
	Chroma_LootCeremonyBeam( rarity )
	int attachID = tickModel.LookupAttachment( fxAttachment )
	int fxIndex = StartParticleEffectOnEntity( tickModel, GetParticleSystemIndex( TICK_FX_RARITY_BEAM ), FX_PATTACH_POINT_FOLLOW, attachID )

	EffectSetControlPointVector( fxIndex, 1, rarityColor )

	fileLevel.rarityBeamFXHandles.append( fxIndex )
}



void function MassLootCeremony_RarityBeamSFX( entity tickModel, string fxAttachment )
{
	int rarity
	switch ( fxAttachment )
	{
		case TICK_LOOT_ATTACHMENTS[0]:
			rarity = fileLevel.highestsRarities[0]
			break
		case TICK_LOOT_ATTACHMENTS[1]:
			rarity = fileLevel.highestsRarities[1]
			break
		case TICK_LOOT_ATTACHMENTS[2]:
			rarity = fileLevel.highestsRarities[2]
			break
	}

	vector rarityColor = GetFXRarityColorForUnlockable( rarity )

	if ( rarity in MassLootCeremonyRarityToBeamSFX )
		RunUIScript( "ClientToUI_PlayLootCeremonySound", MassLootCeremonyRarityToBeamSFX[rarity] )
}



void function MassLootCeremony_RarityBeamFX_Stop( bool stopImmediately = false )
{
	foreach ( int fxID in fileLevel.rarityBeamFXHandles )
	{
		if ( EffectDoesExist( fxID ) )
		{
			if ( stopImmediately )
				EffectStop( fxID, true, false )
			else
				EffectStop( fxID, false, true )
		}
	}

	fileLevel.rarityBeamFXHandles.clear()
}



void function MassLootCeremony_PlayLootTickSound( entity tickModel, string soundKindRef )
{
	string soundAlias = GRXPack_GetTickSoundAlias( fileLevel.currentPackFlav, eGRXPackTickSoundKind[soundKindRef] )
	if ( soundAlias != "" )
		EmitSoundOnEntity( tickModel, soundAlias )
}



void function MassLootCeremony_RarityFlashFX( entity tickModel, string attachmentHead, string attachmentEye )
{
	int rarity         = fileLevel.highestRarityItem
	vector rarityColor = GetFXRarityColorForUnlockable( rarity )

	int attachID  = tickModel.LookupAttachment( attachmentHead )
	vector origin = tickModel.GetAttachmentOrigin( attachID )
	vector angles = tickModel.GetAttachmentAngles( attachID )

	Chroma_LootCeremonyFlash( rarity )

	int fxIndex = LootCeremony_GetRarityFlashFXIndex( rarity, origin, angles )
	EffectSetControlPointVector( fxIndex, 1, rarityColor )
}



void function MassLootCeremony_FireworkFX( entity tickModel, string fxAttachment )
{
	int highestRarity = fileLevel.highestsRarities[0]
	array<int> highestRaritiesReversed = clone(fileLevel.highestsRarities)
	highestRaritiesReversed.reverse()

	int rarity = eRarityTier.COMMON
	if ( highestRarity == eRarityTier.MYTHIC )
		rarity = eRarityTier.MYTHIC
	else
		rarity = highestRaritiesReversed[fileLevel.vfxFireworksPlayedCounter]

	vector rarityColor = GetFXRarityColorForUnlockable( rarity )

	int attachID = tickModel.LookupAttachment( fxAttachment )
	if ( rarity in MassLootCeremonyRarityToFireworkFX )
	{
		int fxIndex = StartParticleEffectOnEntity( tickModel, GetParticleSystemIndex( MassLootCeremonyRarityToFireworkFX[rarity] ), FX_PATTACH_POINT_FOLLOW, attachID )
		EffectSetControlPointVector( fxIndex, 1, rarityColor )
	}

	if ( rarity in MassLootCeremonyRarityToFireworkSFX )
		RunUIScript( "ClientToUI_PlayLootCeremonySound", MassLootCeremonyRarityToFireworkSFX[rarity] )

	fileLevel.vfxFireworksPlayedCounter++
}



void function MassLootCeremony_TrailFX( entity tickModel, string fxAttachment )
{
	int highestRarity = fileLevel.highestsRarities[0]
	array<int> highestRaritiesReversed = clone(fileLevel.highestsRarities)
	highestRaritiesReversed.reverse()

	int rarity = eRarityTier.COMMON
	if ( highestRarity == eRarityTier.MYTHIC )
		rarity = eRarityTier.MYTHIC
	else
		rarity = highestRaritiesReversed[fileLevel.vfxTrailsPlayedCounter]

	vector rarityColor = GetFXRarityColorForUnlockable( rarity )

	int attachID = tickModel.LookupAttachment( fxAttachment )
	int fxIndex = StartParticleEffectOnEntity( tickModel, GetParticleSystemIndex( TICK_FX_TRAIL ), FX_PATTACH_POINT_FOLLOW, attachID )

	EffectSetControlPointVector( fxIndex, 1, rarityColor )
	fileLevel.vfxTrailsPlayedCounter++
}

