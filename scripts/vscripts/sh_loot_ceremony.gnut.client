		}

		case eLootCeremonyPackType.THEMATIC_WEAPON_PACK:
		{
			return "THEMATIC_WEAPON_PACK"
		}

		case eLootCeremonyPackType.THEMATIC_WEAPON_CATEGORY_PACK:
		{
