void function EnableLobbyMenuCameraZoom()
{
	const float ZOOM_DISTANCE_CHARACTER_SKIN = 72.0
	const float ZOOM_DISTANCE_INSPECT_CHARACTER_SKIN = 160.0

	const float ZOOM_DISTANCE_WEAPON_SKIN = 24.0
	const float ZOOM_DISTANCE_INSPECT_WEAPON_SKIN = 53.333333

	const float ZOOM_DISTANCE_WEAPON_CHARM = 100.0
	const float ZOOM_DISTANCE_INSPECT_WEAPON_CHARM = 222.222222
	const float ZOOM_DISTANCE_INSPECT_MELEE_SKIN = 133.333333

	EndSignal( level, "EndCameraZoom" )

	
	while( !file.cameraZoomModelInitialized )
		WaitFrame()

	vector focalPoint
	float maxZoomDistance
	int cameraTargetIndex

	if ( file.desiredPresentationType == ePresentationType.CHARACTER_SKIN )
	{
		entity characterModel = ModelData_GetModel( file.customizeCharacter )

		ItemFlavor skinFlavor      = ModelData_GetSkinFlavor( file.customizeCharacter )

		if( !IsItemFlavorStructValid( skinFlavor.guid, eValidation.DONT_ASSERT ) )
			return

		ItemFlavor characterFlavor = CharacterSkin_GetCharacterFlavor( skinFlavor )
		vector offset              = CharacterClass_GetMenuZoomOffset( characterFlavor )

		focalPoint = characterModel.GetAttachmentOrigin( characterModel.LookupAttachment( "HEADSHOT" ) ) + offset
		maxZoomDistance = ZOOM_DISTANCE_CHARACTER_SKIN
		cameraTargetIndex = eCameraTargetNames.customize_character_camera_target
	}
	else if ( file.desiredPresentationType == ePresentationType.WEAPON_SKIN )
	{
		ItemFlavor skinFlavor     = ModelData_GetSkinFlavor( file.customizeWeapon )

		if( !IsItemFlavorStructValid( skinFlavor.guid, eValidation.DONT_ASSERT ) )
			return

		ItemFlavor weaponFlavor   = WeaponSkin_GetWeaponFlavor( skinFlavor )
		ItemFlavor categoryFlavor = WeaponItemFlavor_GetCategory( weaponFlavor )
		

		entity weaponModel = ModelData_GetModel( file.customizeWeapon )
		vector modelRotateOrigin = weaponModel.GetAttachmentOrigin( weaponModel.LookupAttachment( "MENU_ROTATE" ) )
		focalPoint = modelRotateOrigin

		maxZoomDistance = ZOOM_DISTANCE_WEAPON_SKIN
		cameraTargetIndex = eCameraTargetNames.customize_weapon_camera_target
	}
	else if ( file.desiredPresentationType == ePresentationType.STORE_INSPECT || file.desiredPresentationType == ePresentationType.STORE_INSPECT_LOOT_POOL )
	{
		entity model        = ModelData_GetModel( file.storeInspectModelData )
		ItemFlavor itemFlav = ModelData_GetSkinFlavor( file.storeInspectModelData )

		if( !IsItemFlavorStructValid( itemFlav.guid, eValidation.DONT_ASSERT ) )
			return

		int itemType        = ItemFlavor_GetType( itemFlav )
		switch ( itemType )
		{
			case eItemType.character:
			case eItemType.character_skin:
			case eItemType.character_emote:
				focalPoint = model.GetAttachmentOrigin( model.LookupAttachment( "HEADFOCUS" ) )
				maxZoomDistance = ZOOM_DISTANCE_INSPECT_CHARACTER_SKIN
				break

			case eItemType.weapon_skin:
				asset video = WeaponSkin_GetVideo( itemFlav )
				if ( video != $"" )
					break

				ItemFlavor weaponFlavor = WeaponSkin_GetWeaponFlavor( itemFlav )
				ItemFlavor categoryFlavor = WeaponItemFlavor_GetCategory( weaponFlavor )
				if( model != null && IsValid( model ) )
					focalPoint = model.GetAttachmentOrigin( model.LookupAttachment( "MENU_ROTATE" ) )
				maxZoomDistance = ZOOM_DISTANCE_INSPECT_WEAPON_SKIN
				break

			case eItemType.weapon_charm:
				focalPoint = GetCharmForWeaponEntity( model ).GetWorldSpaceCenter()
				maxZoomDistance = ZOOM_DISTANCE_INSPECT_WEAPON_CHARM
				break

			case eItemType.melee_skin:
				focalPoint = model.GetAttachmentOrigin( model.LookupAttachment( "MENU_ROTATE" ) )
				maxZoomDistance = ZOOM_DISTANCE_INSPECT_MELEE_SKIN
				break

			default: 
				return
		}
		cameraTargetIndex = eCameraTargetNames.store_inspect_camera_target
	}
	else if ( file.desiredPresentationType == ePresentationType.WEAPON_OVERVIEW )
	{
		entity model        = ModelData_GetModel( file.weaponOverviewModelData )
		ItemFlavor itemFlav = ModelData_GetSkinFlavor( file.weaponOverviewModelData )

		if( !IsItemFlavorStructValid( itemFlav.guid, eValidation.DONT_ASSERT ) )
			return

		int itemType = ItemFlavor_GetType( itemFlav )
		switch ( itemType )
		{
			case eItemType.weapon_skin:
				ItemFlavor weaponFlavor = WeaponSkin_GetWeaponFlavor( itemFlav )
				ItemFlavor categoryFlavor = WeaponItemFlavor_GetCategory( weaponFlavor )
				if( model != null && IsValid( model ) )
					focalPoint = model.GetAttachmentOrigin( model.LookupAttachment( "MENU_ROTATE" ) )
				maxZoomDistance = 0
				break
			default: 
			return
		}

		cameraTargetIndex = eCameraTargetNames.weapon_mastery_inspect_camera_target
	}
	else if ( file.desiredPresentationType == ePresentationType.MELEE_INSPECT )
	{
		entity model        = ModelData_GetModel( file.meleeInspectModelData )
		ItemFlavor itemFlav = ModelData_GetSkinFlavor( file.meleeInspectModelData )

		if( !IsItemFlavorStructValid( itemFlav.guid, eValidation.DONT_ASSERT ) )
			return

		int itemType = ItemFlavor_GetType( itemFlav )
		if ( itemType != eItemType.melee_skin )
			return

		focalPoint = model.GetAttachmentOrigin( model.LookupAttachment( "MENU_ROTATE" ) )
		maxZoomDistance = ZOOM_DISTANCE_CHARACTER_SKIN
		cameraTargetIndex = eCameraTargetNames.customize_character_camera_target
	}

	

	entity cameraTarget      = file.cameraTargets[ cameraTargetIndex ]
	vector cameraStartOrigin = file.cameraStartOriginsAngles[ cameraTargetIndex ]["origin"]
	vector cameraStartAngles = file.cameraStartOriginsAngles[ cameraTargetIndex ]["angles"]

	file.cameraZoomData.mover.SetOrigin( cameraStartOrigin )
	file.cameraZoomData.mover.SetAngles( cameraStartAngles )
	cameraTarget.SetParent( file.cameraZoomData.mover )

	vector normVec = Normalize( focalPoint - cameraStartOrigin )
	file.cameraZoomData.startPos = cameraStartOrigin
	file.cameraZoomData.endPos = file.cameraZoomData.startPos + (normVec * maxZoomDistance)
	file.cameraZoomData.maxDist = maxZoomDistance
	file.cameraZoomData.normVec = normVec

	OnThreadEnd(
		function () : ( cameraTarget, cameraStartOrigin, cameraStartAngles )
		{
			cameraTarget.ClearParent()
			cameraTarget.SetOrigin( cameraStartOrigin )
			cameraTarget.SetAngles( cameraStartAngles )
			file.cameraZoomModelInitialized = false
		}
	)

	waitthread CameraZoomThread( file.cameraZoomData )
}

void function InitMenuEntities()
{
	printf( "InitMenuEntitiesDebug: InitMenuEntities() START" )
#if DEV
		if ( BuildingCubeMaps() )
			return
#endif

	Assert( MenuMapEntitiesExist() )

	InitPresentationData()
	InitMenuModelFlashData()


	InitTeammatePosition( "play_teammate1_quads_ref", GetLobbyIdleActivity( eLobbyEntityIndex.TEAMMATE1 ) )
	InitTeammatePosition( "play_teammate2_quads_ref", GetLobbyIdleActivity( eLobbyEntityIndex.TEAMMATE2 ) )
	InitTeammatePosition( "play_teammate3_quads_ref", GetLobbyIdleActivity( eLobbyEntityIndex.TEAMMATE3 ) )





	file.cameraZoomData.mover = CreateClientsideScriptMover( $"mdl/dev/empty_model.rmdl", <0, 0, 0>, <0, 0, 0> )

	file.cameraTargets.clear()
	file.cameraStartOriginsAngles.clear()
	foreach ( string scriptName, int eNumIdx in eCameraTargetNames )
	{

		
		if ( !IsLobbyRefreshEnabled() && scriptName == "play_camera_target_refresh" )
			continue


		entity targetEnt = GetEntByScriptName( scriptName )
		file.cameraTargets[ eNumIdx ] <- targetEnt
		file.cameraStartOriginsAngles[ eNumIdx ] <- { origin = targetEnt.GetOrigin(), angles = targetEnt.GetAngles() }
	}

	clGlobal.menuCamera = CreateClientSidePointCamera( <0, 0, 0>, <0, 0, 0>, DEFAULT_FOV )

	
	EHI localPlayerEHI = WaitForLocalClientEHI()
	if ( IsSpectator( GetLocalClientPlayer() ) && !IsPrivateMatchLobby() )
	{
		printf( "InitMenuEntitiesDebug: InitMenuEntities() Return: Local Client is Spectator" )
		return 
	}

	if ( IsLobby() || IsPrivateMatchLobby() )
	{
		entity localPlayer = GetLocalClientPlayer()
		localPlayer.SetMenuCameraEntityWithAudio( clGlobal.menuCamera ) 
	}

	entity refEnt
	entity model
	float[2] baseRotationDelta


	refEnt = GetEntByScriptName( "play_character_quads_ref" )



	ModelData_SetBaseOrigin( file.playCharacter, refEnt.GetOrigin() )
	ModelData_SetBaseAngles( file.playCharacter, refEnt.GetAngles() )
	model = CreateMenuModel( file.playCharacter, $"mdl/dev/empty_model.rmdl" )
	ItemFlavor character     = LoadoutSlot_WaitForItemFlavor( localPlayerEHI, Loadout_Character() )
	ItemFlavor characterSkin = LoadoutSlot_WaitForItemFlavor( localPlayerEHI, Loadout_CharacterSkin( character ) )
	CharacterSkin_Apply( model, characterSkin )
	model.SetAlive( true )

	refEnt = GetEntByScriptName( "customize_character_ref" )

	refEnt.SetOrigin( refEnt.GetOrigin()  + <-20, 0, -2 > )

	ModelData_SetBaseOrigin( file.customizeCharacter, refEnt.GetOrigin() )

	ModelData_SetBaseAngles( file.customizeCharacter, <0, -100, 0> )



	baseRotationDelta[0] = 0
	baseRotationDelta[1] = 0
	ModelData_SetBaseRotationDelta( file.customizeCharacter, baseRotationDelta )
	model = CreateMenuModel( file.customizeCharacter, $"mdl/dev/empty_model.rmdl" )
	ModelData_CreateMover( file.customizeCharacter )
	CharacterSkin_Apply( model, characterSkin )
	model.SetAlive( true )

	refEnt = GetEntByScriptName( "customize_weapon_ref" )
	file.customizeWeaponRefEnt = refEnt
	ModelData_SetBaseOrigin( file.customizeWeapon, refEnt.GetOrigin() )
	ModelData_SetBaseAngles( file.customizeWeapon, WEAPON_BASE_ANGLES )
	ModelData_SetBaseRotationDelta( file.customizeWeapon, WEAPON_BASE_ROTATION_DELTA )
	model = CreateMenuModel( file.customizeWeapon, $"mdl/dev/empty_model.rmdl" )
	model.kv.rendercolor = "0 0 0 255" 
	ModelData_CreateMover( file.customizeWeapon )
	ItemFlavor weapon     = GetAllWeaponItemFlavors( true )[0]
	ItemFlavor weaponSkin = LoadoutSlot_GetItemFlavor( localPlayerEHI, Loadout_WeaponSkin( weapon ) )
	WeaponCosmetics_Apply( model, weaponSkin, null )

	refEnt = GetEntByScriptName( "store_inspect_ref" )
	file.storeInspectRefEnt = refEnt
	ModelData_SetBaseOrigin( file.storeInspectModelData, refEnt.GetOrigin() )
	ModelData_SetBaseAngles( file.storeInspectModelData, refEnt.GetAngles() )
	ModelData_SetBaseRotationDelta( file.storeInspectModelData, baseRotationDelta )
	model = CreateMenuModel( file.storeInspectModelData, $"mdl/dev/empty_model.rmdl" )
	ModelData_CreateMover( file.storeInspectModelData )

	refEnt = GetEntByScriptName( "weapons_mastery_inspect_ref" )
	file.weaponOverviewRefEnt = refEnt
	ModelData_SetBaseOrigin( file.weaponOverviewModelData, refEnt.GetOrigin() )
	ModelData_SetBaseAngles( file.weaponOverviewModelData, refEnt.GetAngles() )
	ModelData_SetBaseRotationDelta( file.weaponOverviewModelData, baseRotationDelta )
	model = CreateMenuModel( file.weaponOverviewModelData, $"mdl/dev/empty_model.rmdl" )
	ModelData_CreateMover( file.weaponOverviewModelData )

	refEnt = GetEntByScriptName( "customize_character_skin_ref" )
	file.meleeInspectRefEnt = refEnt
	ModelData_SetBaseOrigin( file.meleeInspectModelData, refEnt.GetOrigin() )
	ModelData_SetBaseAngles( file.meleeInspectModelData, <0, 0, 0> )
	ModelData_SetBaseRotationDelta( file.meleeInspectModelData, baseRotationDelta )
	model = CreateMenuModel( file.meleeInspectModelData, $"mdl/dev/empty_model.rmdl" )
	ModelData_CreateMover( file.meleeInspectModelData )

	
	refEnt = GetEntByScriptName( "battlepass_right_ref" )    
	ModelData_SetBaseOrigin( file.questGoalModelData, refEnt.GetOrigin() )
	ModelData_SetBaseAngles( file.questGoalModelData, <0, -115, 0> )
	model = CreateMenuModel( file.questGoalModelData, $"mdl/dev/empty_model.rmdl" )
	CreateMenuSubModel( file.questGoalModelData, $"mdl/dev/empty_model.rmdl" )
	ModelData_CreateMover( file.questGoalModelData )

	refEnt = GetEntByScriptName( "customize_weapon_ref" ) 
	ModelData_SetBaseOrigin( file.appliedStickerModelData, refEnt.GetOrigin() + <3.25, 0, 2.5> )
	ModelData_SetBaseAngles( file.appliedStickerModelData, <0, 0, 0> )
	model = CreateMenuModel( file.appliedStickerModelData, $"mdl/dev/empty_model.rmdl" )
	ModelData_CreateMover( file.appliedStickerModelData )

	ModelData_SetBaseOrigin( file.unappliedStickerModelData, refEnt.GetOrigin() + <4, 0, 2> )
	ModelData_SetBaseAngles( file.unappliedStickerModelData, <0, 255, 0> )
	model = CreateMenuModel( file.unappliedStickerModelData, $"mdl/dev/empty_model.rmdl" )
	ModelData_CreateMover( file.unappliedStickerModelData )

	refEnt = GetEntByScriptName( "loot_ceremony_camera_target" ) 
	ModelData_SetBaseOrigin( file.lootCeremonyModelData, refEnt.GetOrigin() + <200, 0, -40> )
	ModelData_SetBaseAngles( file.lootCeremonyModelData, <0, 0, 0> )
	model = CreateMenuModel( file.lootCeremonyModelData, $"mdl/dev/empty_model.rmdl" )
	ModelData_CreateMover( file.lootCeremonyModelData )

	
	
	
	

	InitBattlePassLights()
	InitLightingConfigs()
	InitBackgroundModels()

	file.initializedMenuModels = true
	printf( "InitMenuEntitiesDebug: InitMenuEntities() END" )
}

void function InitBackgroundModels()
{

		entity targetBackground = GetEntByScriptName( STORE_BACKGROUND_ENT_NAME )

		vector offset            = <0, 0, 24>
		UISize screenSize        = GetScreenSize()
		float nearestAspectRatio = GetNearestAspectRatio( screenSize.width, screenSize.height )
		if ( nearestAspectRatio > 2.25 )
			offset += <0, 25, 0>

		file.storeBackgroundModelGeo = CreateClientSidePropDynamic( targetBackground.GetOrigin() - offset, targetBackground.GetAngles(), STORE_BACKGROUND_GEO_MODEL )
		file.storeBackgroundModelGeo.kv.solid = 0
		file.storeBackgroundModelGeo.kv.disableshadows = 1
		file.storeBackgroundModelGeo.kv.fadedist = -1
		file.storeBackgroundModelGeo.MakeSafeForUIScriptHack()
		file.storeBackgroundModelGeo.Hide()

		file.storeBackgroundModelSmoke = CreateClientSidePropDynamic( targetBackground.GetOrigin() - offset, targetBackground.GetAngles(), STORE_BACKGROUND_SMOKE_MODEL )
		file.storeBackgroundModelSmoke.kv.solid = 0
		file.storeBackgroundModelSmoke.kv.disableshadows = 1
		file.storeBackgroundModelSmoke.kv.fadedist = -1
		file.storeBackgroundModelSmoke.MakeSafeForUIScriptHack()
		file.storeBackgroundModelSmoke.Hide()


		file.arenasBackgroundModelGeo = CreateClientSidePropDynamic( targetBackground.GetOrigin() - offset, targetBackground.GetAngles(), ARENAS_BACKGROUND_GEO_MODEL )
		file.arenasBackgroundModelGeo.kv.solid = 0
		file.arenasBackgroundModelGeo.kv.disableshadows = 1
		file.arenasBackgroundModelGeo.kv.fadedist = -1
		file.arenasBackgroundModelGeo.MakeSafeForUIScriptHack()
		file.arenasBackgroundModelGeo.Hide()

		file.arenasBackgroundModelSmoke = CreateClientSidePropDynamic( targetBackground.GetOrigin() - offset, targetBackground.GetAngles(), ARENAS_BACKGROUND_SMOKE_MODEL )
		file.arenasBackgroundModelSmoke.kv.solid = 0
		file.arenasBackgroundModelSmoke.kv.disableshadows = 1
		file.arenasBackgroundModelSmoke.kv.fadedist = -1
		file.arenasBackgroundModelSmoke.MakeSafeForUIScriptHack()
		file.arenasBackgroundModelSmoke.Hide()


		entity weaponOverviewTargetBackground = GetEntByScriptName( WEAPON_OVERVIEW_BACKGROUND_ENT_NAME )

		file.weaponOverviewBackgroundModelGeo = CreateClientSidePropDynamic( weaponOverviewTargetBackground.GetOrigin() + <0, -100, 0 >, weaponOverviewTargetBackground.GetAngles(), STORE_BACKGROUND_GEO_MODEL )
		file.weaponOverviewBackgroundModelGeo.kv.solid = 0
		file.weaponOverviewBackgroundModelGeo.kv.disableshadows = 1
		file.weaponOverviewBackgroundModelGeo.kv.fadedist = -1
		file.weaponOverviewBackgroundModelGeo.MakeSafeForUIScriptHack()
		file.weaponOverviewBackgroundModelGeo.Hide()

		file.weaponOverviewBackgroundModelSmoke = CreateClientSidePropDynamic( weaponOverviewTargetBackground.GetOrigin() + <0, -100, 0 >, weaponOverviewTargetBackground.GetAngles(), STORE_BACKGROUND_SMOKE_MODEL )
		file.weaponOverviewBackgroundModelSmoke.kv.solid = 0
		file.weaponOverviewBackgroundModelSmoke.kv.disableshadows = 1
		file.weaponOverviewBackgroundModelSmoke.kv.fadedist = -1
		file.weaponOverviewBackgroundModelSmoke.MakeSafeForUIScriptHack()
		file.weaponOverviewBackgroundModelSmoke.Hide()

		if ( HasEntWithScriptName( LOBBY_SCREEN_SCRIPT_NAME ) )
		{
			file.lobbyScreen = GetEntByScriptName( LOBBY_SCREEN_SCRIPT_NAME )
		}

		if ( HasEntWithScriptName( LOBBY_TWEAK_LIGHT_SCRIPT_NAME ) )
		{
			file.lobbyLights = GetEntArrayByScriptName( LOBBY_TWEAK_LIGHT_SCRIPT_NAME )
		}

		foreach ( entity light in file.lobbyLights )
		{
			file.lobbyLightColors.append( LOBBY_TWEAK_LIGHT_MID_TRANSITION_COLOR )
			light.SetTweakLightColor( LOBBY_TWEAK_LIGHT_MID_TRANSITION_COLOR )
		}

		int fxAsset = GetParticleSystemIndex( tuning.mainMenuVFX )
		file.mainMenuVfxHandle = StartParticleEffectInWorldWithHandle( fxAsset, MAIN_MENU_SMOKE_VFX_ORIGIN, MAIN_MENU_SMOKE_VFX_ANGLE )
		EffectSetControlPointVector( file.mainMenuVfxHandle, 1, MAIN_MENU_SMOKE_VFX_DARK_COLOR )
		EffectSetControlPointVector( file.mainMenuVfxHandle, 2, MAIN_MENU_SMOKE_VFX_DARK_COLOR )

		int unixTimeNow = GetUnixTimestamp()
		if ( tuning.eventStartTime <= unixTimeNow && unixTimeNow <= tuning.eventEndTime )
		{
			foreach ( EventEntity eventEntity in tuning.eventEntity )
			{
				if ( eventEntity.turnon == EventEntityTurnon.EnterLobby )
				{
					int particleIndex = GetParticleSystemIndex( eventEntity.VFX )
					StartParticleEffectInWorld( particleIndex, eventEntity.origin, eventEntity.angle )
				}
			}
		}

		file.isBootup = true
		LobbyScreen_PlayBootupAnimation()


}

entity function CreateMenuModel_( MenuModelData modelData, asset modelAsset, bool isMainModel )
{
	vector origin     = <0, 0, 0>
	vector angles     = <0, 0, 0>
	vector baseOrigin = ModelData_GetBaseOrigin( modelData )
	vector baseAngles = ModelData_GetBaseAngles( modelData )

	if ( baseOrigin != origin )
		origin = baseOrigin

	if ( baseAngles != angles )
		angles = baseAngles

	entity oldModel = isMainModel ? ModelData_GetModel( modelData ) : ModelData_GetSubModel( modelData )
	if ( IsValid( oldModel ) )
		oldModel.Destroy()

	entity model = CreateClientSidePropDynamic( origin, angles, modelAsset )
	model.SetVisibleForLocalPlayer( 0 )
	model.MakeSafeForUIScriptHack()
	if ( isMainModel )
		ModelData_SetModel( modelData, model )
	else
		ModelData_SetSubModel( modelData, model )

	return model
}
entity function CreateMenuModel( MenuModelData modelData, asset modelAsset )
{
	return CreateMenuModel_( modelData, modelAsset, true )
}
entity function CreateMenuSubModel( MenuModelData modelData, asset modelAsset )
{
	return CreateMenuModel_( modelData, modelAsset, false )
}

void function UpdateMenuCharacterModel( entity player, int overrideCharacterFlavorGUID = -1, bool isCentered = false )
{
	if ( !file.isInitialized )
		return

	if ( player != GetLocalClientPlayer() )
		return

	thread UpdateMenuCharacterModelInternal( overrideCharacterFlavorGUID, isCentered )
}


void function UpdateMenuCharacterModelInternal( int overrideCharacterFlavorGUID, bool isCentered = false )
{
	Signal( file.signalDummy, "UpdateMenuCharacterModelInternal" )
	EndSignal( file.signalDummy, "UpdateMenuCharacterModelInternal" )

	while ( !file.initializedMenuModels ) 
		WaitFrame()

	EHI playerEHI = LocalClientEHI()
	LoadoutSlot_WaitForItemFlavor( playerEHI, Loadout_Character() )


	if ( file.currentPresentationType == ePresentationType.HOLOSPRAYS )
		return 

	if ( file.currentPresentationType == ePresentationType.CHARACTER_SELECT )
	{
		if ( overrideCharacterFlavorGUID == -1 )
			overrideCharacterFlavorGUID = file.playerSelectCharacterGUID
		else
			file.playerSelectCharacterGUID = overrideCharacterFlavorGUID
	}

	ItemFlavor character
	if ( overrideCharacterFlavorGUID == -1 )
		character = LoadoutSlot_GetItemFlavor( playerEHI, Loadout_Character() )
	else
		character = GetItemFlavorByGUID( overrideCharacterFlavorGUID )

#if DEV
		if ( GetBugReproNum() == 1747 ) 
			character = GetItemFlavorByCharacterRef( "character_dummie"  )
#endif

	clGlobal.currentMenuPilotModels.characterSkin = LoadoutSlot_WaitForItemFlavor( playerEHI, Loadout_CharacterSkin( character ) )

	clGlobal.currentMenuPilotModels.garment = LoadoutSlot_WaitForItemFlavor( playerEHI, Loadout_DigitalGarment() )

	
	

	if ( file.presentationData[ file.currentPresentationType ].useCharacterOffsets && file.presentationData[ file.currentPresentationType ].modelData != null )
	{
		entity refEnt = ModelData_GetPoseEntity( expect MenuModelData( file.presentationData[ file.currentPresentationType ].modelData ) )
		vector base   = refEnt.GetOrigin()
		vector offset = CharacterClass_GetGalleryModelOffset( character )
#if DEV
			if ( ItemFlavor_GetCharacterRef( character ) == file.DEV_characterOffsetCharacter )
				offset = file.DEV_characterOffset
#endif

		ModelData_GetMover( expect MenuModelData( file.presentationData[ file.currentPresentationType ].modelData ) ).SetOrigin( base + offset )
	}

	if ( isCentered )
	{
		ModelData_GetMover( file.customizeCharacter ).SetOrigin( GetEntByScriptName( "customize_character_skin_ref" ).GetOrigin() + <-20, 0, 0> )
		ModelData_GetMover( file.customizeCharacter ).SetAngles( GetEntByScriptName( "customize_character_skin_ref" ).GetAngles() + <-1.1, 0, 0> )
	}

	bool doTransitionFX = (file.currentPresentationType == ePresentationType.CHARACTER_SKIN)
	UpdateCharacterModelDisplay( file.playCharacter, doTransitionFX )
	UpdateCharacterModelDisplay( file.customizeCharacter, doTransitionFX )
}

void function StartBaseFX( bool isCentered )
{
	StopBaseFX()

	if ( isCentered )
		file.baseFXHandle = StartParticleEffectInWorldWithHandle( GetParticleSystemIndex( CHARACTER_BASE_EFFECT ), GetEntByScriptName( "customize_character_skin_ref" ).GetOrigin() + <-20, 0, 0> + <0, 0, -1.2>, <-1.1, 0, 0> )
	else
		file.baseFXHandle = StartParticleEffectInWorldWithHandle( GetParticleSystemIndex( CHARACTER_BASE_EFFECT ), ModelData_GetMover( file.customizeCharacter ).GetOrigin() + <0, 0, -1.2>, <-2.2, 0, 0> )

	EffectSetDontKillForReplay( file.baseFXHandle )
}

void function StopBaseFX()
{
	if ( EffectDoesExist( file.baseFXHandle ) )
	{
		EffectStop( file.baseFXHandle, true, false )
	}
}

void function UIToClient_StartCharacterModelBaseFX( bool isCentered )
{
	StartBaseFX( isCentered )
}

void function UIToClient_PreviewCharacterEmote( int guid, int overrideCharacterFlavorGUID )
{
	UpdateMenuCharacterModel( GetLocalClientPlayer(), overrideCharacterFlavorGUID )

	ItemFlavor flav = GetItemFlavorByGUID( guid )
	string anim3p   = CharacterQuip_GetAnim3p( flav, GetItemFlavorByGUID( overrideCharacterFlavorGUID ) )

	entity model = ModelData_GetModel( file.customizeCharacter )
	if ( model.Anim_HasActivity( anim3p ) || model.Anim_HasSequence( anim3p ) )
	{
		thread ModelPerformEmote( model, flav, ModelData_GetMover( file.customizeCharacter ), false, true )
	}

	if ( clGlobal.previewMenuPilotModels.characterSkin != null && EffectDoesExist( file.baseFXHandle ) )
		EffectSetControlPointVector( file.baseFXHandle, 1, ItemFlavor_GetQualityColor( flav ) )
}

void function UIToClient_PreviewUnappliedSticker( SettingsAssetGUID itemFlavorGUID )
{
	ItemFlavor stickerItem = GetItemFlavorByGUID( itemFlavorGUID )

	Assert( !Sticker_IsTheEmpty( stickerItem ) )


	if ( IsValidStickerInstance( file.currentUnappliedStickerInstance ) )
		DestroyStickerInstance( file.currentUnappliedStickerInstance )

	entity stickerEnt = ModelData_GetModel( file.unappliedStickerModelData )








	stickerEnt.SetLocalOrigin( <0, 0, 0> )
	stickerEnt.SetLocalAngles( <0, 0, 0> )
	stickerEnt.SetModel( UNAPPLIED_STICKER_MODEL )
	stickerEnt.SetModelScale( 0.65 )
	asset stickerMat = Sticker_GetReplacementMaterialAsset( stickerItem )
	file.currentUnappliedStickerInstance = Sticker_SetMaterialModForLocalPlayer( stickerEnt, stickerMat )
	stickerEnt.Show()

	if ( ItemFlavor_HasQuality( stickerItem ) )
	{
		vector flashColor = ItemFlavor_GetQualityColor( stickerItem ) / 255
		Sticker_CreateFlashData( file.currentUnappliedStickerInstance, stickerEnt, eMenuModelFlashType.DEFAULT, flashColor )
		Sticker_OnPlaced( file.currentUnappliedStickerInstance, Sticker_FlashOnLoadComplete )
	}
}



















































void function UIToClient_PreviewAppliedStickers( int stickerObjectType, int updatedStickerSlot )
{
	if ( IsValidStickerInstance( file.currentUnappliedStickerInstance ) )
	{
		DestroyStickerInstance( file.currentUnappliedStickerInstance )
		file.currentUnappliedStickerInstance = -1
	}

	entity objectEnt  = ModelData_GetModel( file.appliedStickerModelData )
	float objectScale = stickerObjectType == eStickerObjectType.injector ? 2.5 : 1.5

	if ( file.currentStickerObjectType != stickerObjectType )
	{
		table< int, table<int, AppliedStickerData> > appliedStickersDataCopy = clone file.appliedStickersData

		
		foreach ( stickerObjectTypeKey, stickerSlotTable in appliedStickersDataCopy )
		{
			if ( stickerObjectTypeKey == stickerObjectType )
				continue

			foreach ( stickerSlot, appliedStickerData in stickerSlotTable )
			{
				if ( IsValidStickerInstance( appliedStickerData.stickerInstance ) )
					DestroyStickerInstance( appliedStickerData.stickerInstance )
			}

			delete file.appliedStickersData[stickerObjectTypeKey]
		}

		ModelData_ResetRotation( file.appliedStickerModelData )

		asset objectAsset = GetStickerObjectModel( stickerObjectType )
		objectEnt.SetSkin( 0 )
		objectEnt.SetModel( objectAsset )

		
		
		
		
		
		

		if ( stickerObjectType == eStickerObjectType.phoenix_kit )
			objectEnt.SetSkin( 1 )

		vector localAngles = <-113, -177, -79>
		string renderColor = "0 0 0 255"
		if ( stickerObjectType == eStickerObjectType.injector )
		{
			localAngles = <26, 175, 18>
			renderColor = "255 255 255 255"
		}

		objectEnt.SetModelScale( objectScale )
		objectEnt.SetLocalAngles( localAngles )
		objectEnt.kv.rendercolor = renderColor
	}

	ItemFlavor spoofItem = GetItemFlavorByGUID( FRAG_DEFAULT_SKIN_GUID ) 
	UpdateWeaponLights( objectEnt, WEAPON_LIGHT_RIG_OFFSET, spoofItem )

	file.currentStickerObjectType = stickerObjectType

	if ( !( stickerObjectType in file.appliedStickersData ) )
		file.appliedStickersData[stickerObjectType] <- {}

	ItemFlavor ornull updatedStickerItem
	int updatedStickerInstance = -1

	
	for ( int stickerSlot = 0; stickerSlot < GetMaxStickersForObjectType( stickerObjectType ); stickerSlot++ )
	{
		bool stickerSlotExists = (stickerSlot in file.appliedStickersData[stickerObjectType])
		ItemFlavor stickerItem = LoadoutSlot_WaitForItemFlavor( LocalClientEHI(), Loadout_Sticker( stickerObjectType, stickerSlot ) )
		int stickerInstance    = -1

		if ( Sticker_IsTheEmpty( stickerItem ) )
		{
			if ( stickerSlotExists )
			{
				if ( IsValidStickerInstance( file.appliedStickersData[stickerObjectType][stickerSlot].stickerInstance ) )
					DestroyStickerInstance( file.appliedStickersData[stickerObjectType][stickerSlot].stickerInstance )

				delete file.appliedStickersData[stickerObjectType][stickerSlot]
			}
		}
		else if ( !( stickerSlotExists && file.appliedStickersData[stickerObjectType][stickerSlot].stickerItem == stickerItem ) )
		{
			if ( stickerSlotExists && IsValidStickerInstance( file.appliedStickersData[stickerObjectType][stickerSlot].stickerInstance ) )
				DestroyStickerInstance( file.appliedStickersData[stickerObjectType][stickerSlot].stickerInstance )

			asset stickerMat   = Sticker_GetDecalMaterialAsset( stickerItem )
			float stickerScale = Sticker_GetDecalScale( stickerItem, stickerObjectType, stickerSlot + 1 ) * objectScale
			stickerInstance    = Sticker_PlaceDecalForLocalPlayer( objectEnt, stickerMat, "STICKER_" + (stickerSlot + 1), stickerScale )

			AppliedStickerData appliedStickerData
			appliedStickerData.stickerInstance = stickerInstance
			appliedStickerData.stickerItem     = stickerItem

			if ( stickerSlotExists )
				file.appliedStickersData[stickerObjectType][stickerSlot] = appliedStickerData
			else
				file.appliedStickersData[stickerObjectType][stickerSlot] <- appliedStickerData
		}

		if ( stickerSlot == updatedStickerSlot )
		{
			updatedStickerItem = stickerItem
			updatedStickerInstance = stickerInstance
		}
	}

	if ( updatedStickerItem != null && updatedStickerInstance != -1 )
	{
		expect ItemFlavor( updatedStickerItem )

		
		if ( !Sticker_IsTheEmpty( updatedStickerItem ) && ItemFlavor_HasQuality( updatedStickerItem ) )
		{
			vector flashColor = ItemFlavor_GetQualityColor( updatedStickerItem ) / 255
			Sticker_CreateFlashData( updatedStickerInstance, objectEnt, eMenuModelFlashType.DEFAULT, flashColor )
			Sticker_OnPlaced( updatedStickerInstance, Sticker_FlashOnLoadComplete )
		}
	}
}


void function UIToClient_PreviewCharacterSkin( int guid, int overrideCharacterFlavorGUID, bool isCentered = false )
