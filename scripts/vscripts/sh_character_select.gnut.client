			if ( localPlayerIsLockedIn )
				hintStrings.push( "#CHAR_SEL_BUTTON_HINT_CANEL_DETAILS" )
			else
				hintStrings.push( "#CHAR_SEL_BUTTON_HINT_SELECT_DETAILS" )
		}
	}

