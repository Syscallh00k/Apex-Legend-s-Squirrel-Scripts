void function EndPresentation_CHARACTER_SELECT()
{
	file.playerSelectCharacterGUID = -1
	foreach ( entity light in file.presentationData[ ePresentationType.CHARACTER_SELECT ].lights )
	{
		if ( !IsValid( light ) )
			continue

		light.SetTweakLightRealtimeShadows( false )
		light.SetTweakLightUpdateShadowsEveryFrame( false )
		light.SetTweakLightDistance( 2.0 ) 
		light.SetTweakLightBrightness( 0.01 )
	}
}

