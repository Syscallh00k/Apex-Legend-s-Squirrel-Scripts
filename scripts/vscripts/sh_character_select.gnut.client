void function UIToClient_OnToggleJumpmasterButtonClick()
{
	if ( !IsFullyConnected() )
		return

	entity localPlayer = GetLocalClientPlayer()
	if ( !IsValid( localPlayer ) )
		return

	
	if ( GetCurrentPlaylistVarBool( "enable_jumpmaster_volunteering", false ) )
	{
		int currentMatchPreferenceFlags = localPlayer.GetPersistentVarAsInt( "matchPreferences" )

		if ( file.volunteeredForJumpMasterCache )
		{
			Remote_ServerCallFunction( "ClientCallback_PlayerClearMatchPreferenceFlag", localPlayer, eMatchPreferenceFlags.JUMPMASTER_OPT_IN )
		}
		else
		{
			Remote_ServerCallFunction( "ClientCallback_PlayerSetMatchPreferenceFlag", localPlayer, eMatchPreferenceFlags.JUMPMASTER_OPT_IN )
		}

		file.volunteeredForJumpMasterCache = !file.volunteeredForJumpMasterCache
		UpdateButtonPrompts()
	}
}

