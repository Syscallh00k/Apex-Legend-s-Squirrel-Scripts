void function StartPresentation_PLAY()
{
	if ( file.presentationData[file.previousPresentationType].startFunc != StartPresentation_PLAY )
	{
		Signal( ModelData_GetModel( file.playCharacter ), "EndOnReadyThread" )


		if ( IsLobbyRefreshEnabled() )
		{
			if ( AreAllPartyMembersReady() )
			{
				file.partyWasReady = true
				PlayAnimationForParty(eCharacterActivityState.READY_IDLE)
			}
			else if ( file.partyWasReady )
			{
				file.partyWasReady = false
				PlayAnimationForParty(eCharacterActivityState.IDLE)
			}
			else
			{
				ModelData_SetAnim( file.playCharacter, GetLobbyIdleActivity( eLobbyEntityIndex.PLAYER ) )
			}
		}
		else

			ModelData_SetAnim( file.playCharacter, GetLobbyIdleActivity( eLobbyEntityIndex.PLAYER ) )
		UpdateMenuCharacterModel( GetLocalClientPlayer(), -1 )

		thread TrackPartyMembersAndDisplayModelsThread()
	}

	AddCallback_OnPartyUpdated( UpdateMenuWithPartyMembers )
}

void function OnReady_PLAY( bool ready )
{
	if ( IsPlayPresentationType( file.currentPresentationType ) == false )
		return


	file.isClientPlayerReady = ready


	if ( ready )
	{
		int unixTimeNow = GetUnixTimestamp()
		if ( tuning.eventStartTime <= unixTimeNow && unixTimeNow <= tuning.eventEndTime )
		{
			foreach ( EventEntity eventEntity in tuning.eventEntity )
			{
				if ( eventEntity.turnon == EventEntityTurnon.Readyup )
				{
					int particleIndex = GetParticleSystemIndex( eventEntity.VFX )
					StartParticleEffectInWorld( particleIndex, eventEntity.origin, eventEntity.angle )
				}
			}
		}

		if ( file.currentStage in file.stageReadyUpVFX )
		{
			foreach ( ReadyUpVFXData readyUpVFXData in file.stageReadyUpVFX[file.currentStage] )
			{
				int particleIndex = GetParticleSystemIndex( readyUpVFXData.VFX )

				StartParticleEffectInWorld( particleIndex, readyUpVFXData.origin, readyUpVFXData.angles )
			}
		}
		else
		{
			Warning( "Stage not setup in VFX table" )
		}
	}


	PlayPartyAnimationForPartyReadyStatusUpdated()





















}

void function OnReadyThread( bool onReady )
{
	Signal( ModelData_GetModel( file.playCharacter ), "EndOnReadyThread" )
	EndSignal( ModelData_GetModel( file.playCharacter ), "EndOnReadyThread"  )

	if ( onReady )
	{
		if ( ModelData_GetModel( file.playCharacter ).GetCurrentSequenceName().find( "lobby_center_idle" ) != -1 )
		{
			ModelData_SetAnim( file.playCharacter, "ACT_MP_MENU_LOBBY_CENTER_READYUP" )
			WaittillAnimDone( ModelData_GetModel( file.playCharacter ) )
			ModelData_SetAnim( file.playCharacter, "ACT_MP_MENU_LOBBY_CENTER_READY_IDLE" )
			wait file.readyUpIdleTime
			ModelData_SetAnim( file.playCharacter, "ACT_MP_MENU_LOBBY_CENTER_UNREADY" )
			WaittillAnimDone( ModelData_GetModel( file.playCharacter ) )
			ModelData_SetAnim( file.playCharacter, GetLobbyIdleActivity( eLobbyEntityIndex.PLAYER ) )
		}
	}
	else
	{
		if ( file.playCharacter.bodyAnim == "ACT_MP_MENU_LOBBY_CENTER_READY_IDLE" )
		{
			ModelData_SetAnim( file.playCharacter, "ACT_MP_MENU_LOBBY_CENTER_UNREADY" )
			WaittillAnimDone( ModelData_GetModel( file.playCharacter ) )
			ModelData_SetAnim( file.playCharacter, GetLobbyIdleActivity( eLobbyEntityIndex.PLAYER ) )
		}
		else if ( file.playCharacter.bodyAnim == "ACT_MP_MENU_LOBBY_CENTER_READYUP"  )
		{
			WaittillAnimDone( ModelData_GetModel( file.playCharacter ) )
			ModelData_SetAnim( file.playCharacter, "ACT_MP_MENU_LOBBY_CENTER_UNREADY" )
			WaittillAnimDone( ModelData_GetModel( file.playCharacter ) )
			ModelData_SetAnim( file.playCharacter, GetLobbyIdleActivity( eLobbyEntityIndex.PLAYER ) )
		}
	}
}

#if DEV
void function DEV_ToggleForceAllPartyMembersReady()
{
	file.DEV_forceAllPartyMembersReady = !file.DEV_forceAllPartyMembersReady
}
#endif


bool function AreAllPartyMembersReady()
{
	if ( !file.isClientPlayerReady )
		return false

#if DEV
	if ( file.DEV_forceAllPartyMembersReady )
		return true
#endif

	foreach ( string partyMemberUid, PartyMemberDisplayThreadData partyMemberDisplayThreadData in file.partyMemberUidCharacterDataMap )
	{
		if ( !partyMemberDisplayThreadData.isReady )
			return false
	}

	return true
}



void function PlayPartyAnimationForPartyReadyStatusUpdated()
{
	if ( !IsLobbyRefreshEnabled() )
		return

	if ( AreAllPartyMembersReady() )
	{
		file.partyWasReady = true
		PlayAnimationForParty(eCharacterActivityState.READY)
	}
	else if ( file.partyWasReady )
	{
		file.partyWasReady = false
		PlayAnimationForParty(eCharacterActivityState.IDLE)
	}
}



string function GetNextAnimationToPlay( entity model, string currentAnim )
{
	if ( !IsLobbyRefreshEnabled() )
		return ""

	if ( !IsValid( model ) || currentAnim.len() <= 0 )
		return ""

	string currentAnimBase = ""
	string nextAnimBase = ""
	if ( currentAnim.find( JOIN_ACTIVITY_BASE ) != -1 )
	{
		currentAnimBase = JOIN_ACTIVITY_BASE
		nextAnimBase = IDLE_ACTIVITY_BASE
	}
	else if ( currentAnim.find( READY_ACTIVITY_BASE ) != -1 && currentAnim.find( READY_IDLE_ACTIVITY_BASE ) == -1 )
	{
		currentAnimBase = READY_ACTIVITY_BASE
		nextAnimBase = READY_IDLE_ACTIVITY_BASE
	}
	else
	{
		return ""
	}

	string numericActivityStr = currentAnim.slice( ( currentAnimBase + "_" ).len() )
	if ( numericActivityStr.len() <= 0 || !numericActivityStr.isnumeric() )
	{
		Warning( "Cannot get next anim cause current anim is not handled: " + currentAnim )
		return ""
	}

	string nextAnim = nextAnimBase + "_" + numericActivityStr
	if ( !model.Anim_HasSequence( nextAnim ) )
	{
		Warning( "Character doesn't have next anim set: " + nextAnim )
		return ""
	}

	return nextAnim
}



array<string> function GetAvailableAnimationsForState( entity model, int characterActivityState )
{
	if ( !IsLobbyRefreshEnabled() )
		return []

	if ( !IsValid( model ) )
		return []

	int index                         = 1
	string activityBase               = ""
	switch ( characterActivityState )
	{
		case eCharacterActivityState.JOIN:
			activityBase = JOIN_ACTIVITY_BASE
			break
		case eCharacterActivityState.IDLE:
			activityBase = IDLE_ACTIVITY_BASE
			break
		case eCharacterActivityState.READY:
			activityBase = READY_ACTIVITY_BASE
			break
		case eCharacterActivityState.READY_IDLE:
			activityBase = READY_IDLE_ACTIVITY_BASE
			break
	}

	array<string> availableAnimations = []
	string numericStr = index < 10 ? "_0" : "_"
	string checkActivity = activityBase  + numericStr + index.tostring()
	while ( model.Anim_HasSequence( checkActivity ) )
	{
		availableAnimations.append( checkActivity )
		index++
		numericStr = index < 10 ? "_0" : "_"
		checkActivity = activityBase + numericStr + index.tostring()
	}

	return availableAnimations
}



string function GetRandomAnimationForState( entity model, int characterActivityState )
{
	if ( !IsLobbyRefreshEnabled() )
		return ""

	array<string> animations = GetAvailableAnimationsForState( model, characterActivityState )
	if ( animations.len() <= 0 )
	{
		Warning( "No animations were available for that character for the given state" )
		return ""
	}

	return animations.getrandom()
}



void function PlayAnimationForParty(int characterActivityState)
{
	if ( !IsLobbyRefreshEnabled() )
		return

	thread PlayAnimationOnCharacter ( file.playCharacter.model, characterActivityState, file.playCharacter )

	const int maxPlayersToCheck = 10
	for ( int i = 0; i < maxPlayersToCheck; i ++ )
	{
		if ( i in file.teammateModel )
		{
			entity teammateModel = file.teammateModel[i]
			if ( !IsValid( teammateModel ) )
				continue

			thread PlayAnimationOnCharacter ( teammateModel, characterActivityState )
		}
	}
}



void function PlayAnimationOnCharacter( entity model, int characterActivityState, MenuModelData ornull data = null )
{
	if ( !IsLobbyRefreshEnabled() )
		return

	Assert ( IsNewThread(), "Must be threaded off" )
	Signal( model, "EndPlayAnimationOnCharacterThread" )
	EndSignal( model, "EndPlayAnimationOnCharacterThread" )

	if ( !IsValid( model ) )
		return

	string activity = GetRandomAnimationForState( model, characterActivityState )
	if ( activity.len() > 0 )
	{
		if ( data != null )
		{
			expect MenuModelData( data )
			data.bodyAnim = activity
		}

		model.Anim_Play( activity )
		WaittillAnimDone( model )
	}

	activity = GetNextAnimationToPlay( model, activity )
	if ( activity.len() > 0 )
	{
		if ( data != null )
		{
			expect MenuModelData( data )
			data.bodyAnim = activity
		}

		model.Anim_Play( activity )
		WaittillAnimDone( model )
	}
}


