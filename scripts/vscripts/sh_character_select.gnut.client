		Assert( totalLegendCount <= NUM_CHARACTER_SELECT_BUTTONS_PER_CLASS, "Character select doesn't have enough character buttons to support the playlist var 'legend_select_all_one_group' with " + totalLegendCount + " Legends Enabled. Only supports up to " + NUM_CHARACTER_SELECT_BUTTONS_PER_CLASS )

		
