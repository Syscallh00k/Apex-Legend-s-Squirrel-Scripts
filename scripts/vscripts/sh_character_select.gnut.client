	}

	bool isTempUnlocked = GetCurrentPlaylistVarBool( "all_characters_unlocked", false )
	bool isFiringRangeTemp = GameModeVariant_IsActivze.height )
		RuiSetFloatIfExists( fileLevel.buttonHintRui, "xPosOffset", 142 / aspectRatio )
	}



	if ( currentLockStepIndex == fileLevel.localClientLockstepIndex || !CharacterSelectIsLockStep() )



