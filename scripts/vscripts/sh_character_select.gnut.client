void function UIToClient_ResetWeaponRotation()
{
	ModelData_ResetRotation( file.customizeWeapon )
}

const vector EXTRA_LIGHT_RIG_ROTATION = <-10, -80, 0> 

void function UIToClient_PreviewWeaponSkin( int skinFlavorGUID, int charmFlavorGUID, bool shouldHighlightWeapon, bool shouldAllowZoom = true, bool isCentered = false )
{
	if ( !file.initializedMenuModels ) 
		return

	bool isCharms  = file.currentPresentationType == ePresentationType.WEAPON_CHARMS
	bool isSkins  = file.currentPresentationType == ePresentationType.WEAPON_SKIN
	ItemFlavor weaponSkin   = GetItemFlavorByGUID( skinFlavorGUID )
	ItemFlavor weaponFlavor = WeaponSkin_GetWeaponFlavor( weaponSkin )

	entity weaponModel = ModelData_GetModel( file.customizeWeapon )
	entity weaponMover = ModelData_GetMover( file.customizeWeapon )
	ItemFlavor weapon = WeaponSkin_GetWeaponFlavor( weaponSkin )
	ItemFlavor charmFlavor = GetItemFlavorByGUID( charmFlavorGUID )

	
	ModelData_SetSkinFlavor( file.customizeWeapon, weaponSkin )
	WeaponCosmetics_Apply( weaponModel, weaponSkin, charmFlavor )
	if( ( isCharms && !file.cameraZoomedToGunCharm ) || !isCharms )
	{
		entity refEnt = file.customizeWeaponRefEnt
		vector universalSkinOffset = isCentered ? <-6, 0, 0> : <0, 0, 0> 
		vector origin = refEnt.GetOrigin() + universalSkinOffset + MainWeapon_GetLoadoutSkinsOffset( weapon )

		
		file.cameraZoomModelInitialized = true

		
		float armoryScale = 1.0

		if ( ShouldScaleWeaponAndCharmForPreview() )
		{
			Signal( level, "EndGunCharmScaleLerp" )
			ScaleWeaponSkinAndCharm( weaponModel, charmFlavor, armoryScale )
		}

		weaponMover.SetOrigin( ModelData_GetBaseOrigin( file.customizeWeapon ) )
		ModelData_SetBaseOrigin( file.customizeWeapon, origin )

		vector modelOffset = < 0, 0, 0 >
		int cameraTargetIndex = eCameraTargetNames.customize_weapon_camera_target
		vector baseOffset   = GetWeaponOffsetFromCameraPositionToOrigin( file.cameraStartOriginsAngles[ cameraTargetIndex ]["origin"], ModelData_GetBaseOrigin( file.customizeWeapon ), WeaponItemFlavor_GetArmoryOffset( weaponFlavor ) )
		file.weaponVectorScale = WeaponItemFlavor_GetArmoryVectorScale( weaponFlavor )
		modelOffset = baseOffset * file.weaponVectorScale

		SetWeaponSkinLocalOffset( weaponModel, false )

		if( isCharms )
			SetWeaponSkinLocalOffset( weaponModel, true )

		
		bool shouldZoomIn  = isCharms
		bool shouldZoomOut = isSkins && file.cameraZoomedToGunCharm
		if ( shouldZoomIn || shouldZoomOut )
		{
			if ( shouldZoomIn )
				thread ZoomInCameraToWeaponCharm( weaponModel, weaponMover, armoryScale )
			else
				thread ZoomOutCameraToWeaponSkin( weaponModel, weaponSkin, charmFlavor, weaponMover, armoryScale, weaponFlavor )
		}
		else
		{
			weaponMover.SetOrigin( ModelData_GetBaseOrigin( file.customizeWeapon ) + modelOffset )
		}
		UpdateWeaponLights( weaponModel, WEAPON_LIGHT_RIG_OFFSET + EXTRA_LIGHT_RIG_ROTATION, weaponSkin )
		UpdateReactiveWeaponModel( weaponSkin, weaponFlavor, weaponModel )

		if ( ItemFlavor_GetQuality( weaponSkin ) == eRarityTier.MYTHIC )
			weaponModel.SetPoseParameter( MYTHIC_301_LOBBY_POSE_PARAM, 1.0 )

		if ( WeaponItemFlavor_GetStatsCategory( weapon ) == WEAPON_STAT_CATEGORY_ORDNANCE )
		{
			if ( ItemFlavor_GetGUID( weapon ) == THERMITE_WEAPON_GUID )
				OnWeaponActivate_ThermiteGrenade( weaponModel )
			else
				Grenade_OnWeaponActivate( weaponModel )
		}

		asset animSeq = WeaponSkin_GetMenuAnimSeq( weaponSkin )
		if ( animSeq != $"" )
			weaponModel.Anim_Play( animSeq )
	}
	
	if ( shouldHighlightWeapon )
	{
		vector flashColor = ItemFlavor_HasQuality( weaponSkin ) ? ItemFlavor_GetQualityColor( weaponSkin ) / 255 : MENU_MODELS_DEFAULT_HIGHLIGHT_COLOR / 255
		thread FlashMenuModel( weaponModel, eMenuModelFlashType.DEFAULT, flashColor, false )
	}

	if ( !WeaponCharm_IsTheEmpty( charmFlavor ) )
	{
		entity charmEntity = GetCharmForWeaponEntity( weaponModel )
		vector flashColor = ItemFlavor_HasQuality( charmFlavor ) ? ItemFlavor_GetQualityColor( charmFlavor ) / 255 : MENU_MODELS_DEFAULT_HIGHLIGHT_COLOR / 255
		thread FlashMenuModel( charmEntity, eMenuModelFlashType.DEFAULT, flashColor )
	}

	if ( !shouldAllowZoom )
	{
		CameraZoomThreadEnd()
	}
}

