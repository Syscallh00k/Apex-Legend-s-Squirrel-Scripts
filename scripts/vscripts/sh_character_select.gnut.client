void function UpdateReactiveWeaponModel( ItemFlavor weaponSkin, ItemFlavor weaponFlavor, entity weaponModel )
{
	bool isReactive = WeaponSkin_DoesReactToKills( weaponSkin )

	
	string weaponName = WeaponItemFlavor_HasTakeover( weaponFlavor ) ? WeaponItemFlavor_GetTakeoverClassname( weaponFlavor ) : WeaponItemFlavor_GetClassname( weaponFlavor )
	ShowDefaultBodygroupsOnFakeWeapon( weaponModel, weaponName )

	if ( isReactive )
		MenuWeaponModel_ApplyReactiveSkinBodyGroup( weaponSkin, weaponName, weaponModel )

	MenuWeaponModel_ClearReactiveEffects( weaponModel )
	if ( isReactive )
	{
		weaponModel.Anim_SetPaused( false )
		MenuWeaponModel_Start3PReactiveEffects( weaponModel, weaponSkin, true )
	}
	else
		weaponModel.Anim_SetPaused( true )
}

void function UIToClient_OverviewWeaponStopReactiveEffect()
{
	entity weaponModel = ModelData_GetModel( file.weaponOverviewModelData )
	MenuWeaponModel_ClearReactiveEffects( weaponModel )
}

void function UpdateModelsforStoreItem( vector origin, vector moverAngles, vector modelAngles, asset modelAsset, float modelScale )
{
	ModelData_SetBaseOrigin( file.storeInspectModelData, origin )
	ModelData_SetBaseAngles( file.storeInspectModelData, moverAngles )
	entity model = CreateMenuModel( file.storeInspectModelData, modelAsset )
	if ( IsValid( file.storeInspectModelData.mover ) )
	{
		file.storeInspectModelData.mover.Destroy()
		ModelData_CreateMover( file.storeInspectModelData )
	}
	ModelData_SetBaseAngles( file.storeInspectModelData, modelAngles )
	model.SetModelScale( modelScale )
}

void function UpdateStoreItemDisplay_ApexPack( ItemFlavor item )
{
	Assert( ItemFlavor_GetType( item ) == eItemType.account_pack )

	entity refEnt = file.storeInspectRefEnt
	vector origin = refEnt.GetOrigin() + <0, 0, -4.5>
	vector angles = refEnt.GetAngles()

	asset modelAsset = GRXPack_GetTickModel( item )
	const float modelScale = 1.111111

	UpdateModelsforStoreItem( origin, angles, AnglesCompose( angles, <0, 135, 0> ), modelAsset, modelScale )

	string skin = GRXPack_GetTickModelSkin( item )
	entity model = ModelData_GetModel( file.storeInspectModelData )
	model.SetSkin( model.GetSkinIndexByName( skin ) )
}

void function UpdateStoreItemDisplay_Currency( ItemFlavor item )
{
	Assert( ItemFlavor_GetType( item ) == eItemType.account_currency || ItemFlavor_GetType( item ) == eItemType.account_currency_bundle )

	
	entity refEnt = file.storeInspectRefEnt
	vector origin = refEnt.GetOrigin() + <0, 0, 26>
	vector angles = refEnt.GetAngles()
	const float modelScale = 2

	asset modelAsset = $"mdl/dev/empty_model.rmdl"
	int rarity       = 0
	if ( ItemFlavor_HasQuality( item ) )
		rarity = ItemFlavor_GetQuality( item )

	if ( ItemFlavor_GetType( item ) == eItemType.account_currency )
	{
		if ( GRXCurrency_GetPreviewModel( item ) != $"" )
			modelAsset = GRXCurrency_GetPreviewModel( item )
	}
	else
	{
		asset itemAsset = ItemFlavor_GetAsset( item )
		Assert( itemAsset == $"settings/itemflav/currency_bundle/crafting_common.rpak" ||
		itemAsset == $"settings/itemflav/currency_bundle/crafting_rare.rpak" ||
		itemAsset == $"settings/itemflav/currency_bundle/crafting_epic.rpak" ||
		itemAsset == $"settings/itemflav/currency_bundle/crafting_legendary.rpak" ||
		itemAsset == $"settings/itemflav/currency_bundle/heirloom.rpak" )

		switch ( rarity )
		{
			case eRarityTier.COMMON:
				modelAsset = CURRENCY_MODEL_COMMON
				break

			case eRarityTier.RARE:
				modelAsset = CURRENCY_MODEL_RARE
				break

			case eRarityTier.EPIC:
				modelAsset = CURRENCY_MODEL_EPIC
				break

			case eRarityTier.LEGENDARY:
				string alias = ItemFlavor_GetGRXAlias( item )
				if ( alias == "exotic" || alias == "currency_bundle_exotic" )
					modelAsset = CURRENCY_MODEL_EXOTIC
				else
					modelAsset = CURRENCY_MODEL_LEGENDARY
				break

			case eRarityTier.MYTHIC:
				ItemFlavor currencyFlav = GRXCurrencyBundle_GetCurrencyFlav( item )
				modelAsset = GRXCurrency_GetPreviewModel( currencyFlav )
				break

			default: Assert( false )
		}
	}

	UpdateModelsforStoreItem( origin, angles, AnglesCompose( angles, <0, 135, 0> ), modelAsset, modelScale )
}

void function UpdateStoreItemDisplay_Character( ItemFlavor item )
{
	Assert( ItemFlavor_GetType( item ) == eItemType.character )

	ItemFlavor characterSkin = CharacterClass_GetDefaultSkin( item )
	UpdateStoreItemDisplay_CharacterSkin( characterSkin )
}

void function UpdateStoreItemDisplay_CharacterSkin( ItemFlavor item )
{
	Assert( ItemFlavor_GetType( item ) == eItemType.character_skin )

	entity refEnt = file.storeInspectRefEnt
	vector origin = refEnt.GetOrigin() + <0, 0, -38> + CharacterClass_GetItemInspectOffset( CharacterSkin_GetCharacterFlavor( item ) )
	vector angles = refEnt.GetAngles()

	asset modelAsset = CharacterSkin_GetBodyModel( item )
	const float MODEL_SCALE_STORE_INSPECT = 1.555556
	const float MODEL_SCALE_STORE_INSPECT_LOOT_POOL = 1.4

	float modelScale = file.desiredPresentationType == ePresentationType.STORE_INSPECT_LOOT_POOL ? MODEL_SCALE_STORE_INSPECT_LOOT_POOL : MODEL_SCALE_STORE_INSPECT

	UpdateModelsforStoreItem( origin, angles, angles, modelAsset, modelScale )

	entity model = ModelData_GetModel( file.storeInspectModelData )
	entity mover = ModelData_GetMover( file.storeInspectModelData )
	CharacterSkin_Apply( model, item )
	thread PlayAnim( model, "ACT_MP_MENU_LOOT_CEREMONY_IDLE", mover )
}

void function UpdateStoreItemDisplay_WeaponSkin( ItemFlavor item )
{
	Assert( ItemFlavor_GetType( item ) == eItemType.weapon_skin )

	entity refEnt = file.storeInspectRefEnt
	vector origin = refEnt.GetOrigin() + <0, 0, 26.6>
	vector moverAngles = refEnt.GetAngles()
	vector baseAngles = refEnt.GetAngles()

	ItemFlavor weapon = WeaponSkin_GetWeaponFlavor( item )
	asset modelAsset = WeaponSkin_GetViewModel( item )
	ModelData_SetBaseOrigin( file.storeInspectModelData, origin )

	float modelScale = 1.0
	vector modelOffset = < 0,0,0 >
	
	entity cameraTarget = file.cameraTargets[ eCameraTargetNames.store_inspect_camera_target ]
	vector baseOffset = GetWeaponOffsetFromCameraToOrigin( cameraTarget, < 0,0,0 >, ModelData_GetBaseOrigin( file.storeInspectModelData ), WeaponItemFlavor_GetStoreInspectOffset( weapon ) )
	file.weaponVectorScale = WeaponItemFlavor_GetStoreInspectVectorScale( weapon )
	modelOffset = baseOffset * file.weaponVectorScale
	baseAngles += WeaponItemFlavor_GetStoreInspectAngleOffset( weapon )
	UpdateModelsforStoreItem( origin + modelOffset, moverAngles, baseAngles, modelAsset, modelScale )

	entity model = ModelData_GetModel( file.storeInspectModelData )
	model.Anim_SetPaused( true )
	WeaponCosmetics_Apply( model, item, null )

	vector extraRotation = <11, -45, 0>
	vector originOffset = GetAttachmentOriginOffset( model, "MENU_ROTATE", extraRotation )
	model.SetLocalOrigin( originOffset )
	model.SetLocalAngles( extraRotation )

	UpdateWeaponLights( model, WEAPON_LIGHT_RIG_OFFSET, item )
	UpdateReactiveWeaponModel( item, weapon, model )

	if ( ItemFlavor_GetQuality( item ) == eRarityTier.MYTHIC )
		model.SetPoseParameter( MYTHIC_301_LOBBY_POSE_PARAM, 1.0 )

	if ( WeaponItemFlavor_GetStatsCategory( weapon ) == WEAPON_STAT_CATEGORY_ORDNANCE )
	{
		if ( ItemFlavor_GetGUID( weapon ) == THERMITE_WEAPON_GUID )
			OnWeaponActivate_ThermiteGrenade( model )
		else
			Grenade_OnWeaponActivate( model )
	}

	asset animSeq = WeaponSkin_GetMenuAnimSeq( item )
	if ( animSeq != $"" )
		model.Anim_Play( animSeq )
}

void function UpdateStoreItemDisplay_Deathbox( ItemFlavor item )
{
	Assert( ItemFlavor_GetType( item ) == eItemType.artifact_component_deathbox )

	entity refEnt = file.storeInspectRefEnt
	vector origin = refEnt.GetOrigin() + <0, 0, 15>
	vector angles = refEnt.GetAngles()

	UpdateModelsforStoreItem( origin, angles, angles, Artifacts_GetDeathboxModel( item ), 1.0 )
	entity model = ModelData_GetModel( file.storeInspectModelData )
	model.SetLocalAngles( <10, -45, -8> )

	string skinName = Deathbox_GetSkinName( item )
	if ( skinName != "" )
	{
		int skinIdx = model.GetSkinIndexByName( skinName )
		if ( skinIdx != -1 )
			model.SetSkin( skinIdx )
	}

	MenuModel_Start3PDeathboxEffects( model, item )
	MenuModel_UpdateDeathboxLights( model, origin, item )
}


vector function GetWeaponOffsetFromCameraToOrigin( entity cameraTarget, vector cameraOffset, vector position, vector baseOffset)
{
	vector cameraCurrentPos  = cameraTarget.GetOrigin() + cameraOffset
	vector modelBasePosition = position + baseOffset
	return cameraCurrentPos - modelBasePosition
}



vector function GetWeaponOffsetFromCameraPositionToOrigin( vector cameraPosition, vector position, vector baseOffset)
{
	vector modelBasePosition = position + baseOffset
	return cameraPosition - modelBasePosition
}


void function UpdateStoreItemDisplay_WeaponVideo( ItemFlavor item )
{
	Assert( ItemFlavor_GetType( item ) == eItemType.weapon_skin || ItemFlavor_GetType( item ) == eItemType.weapon_addon )

	entity refEnt        = file.storeInspectRefEnt
	vector origin        = refEnt.GetOrigin() + <0, 0, 31>
	vector angles        = refEnt.GetAngles()
	vector placardAngles = AnglesCompose( angles, <0, 180, 0> )

	const asset ruiAsset = $"ui/finisher_video.rpak"
	const float ruiAspectRatio = 1920.0 / 1080.0
	const float ruiHeight = 52
	const float ruiWidth = ruiHeight * ruiAspectRatio

	var topo         = CreateRUITopology_Worldspace( origin, placardAngles, ruiWidth, ruiHeight )
	var rui          = RuiCreate( ruiAsset, topo, RUI_DRAW_VIEW_MODEL, 0 )
	int videoChannel = ReserveVideoChannel()

	RuiSetInt( rui, "channel", videoChannel )
	StartVideoOnChannel( videoChannel, WeaponSkin_GetVideo( item ), true, 0.0 )

	file.topo         = topo
	file.rui          = rui
	file.videoChannel = videoChannel
}

void function UpdateWeaponOverviewDisplay_WeaponSkin( ItemFlavor item )
{
	Assert( ItemFlavor_GetType( item ) == eItemType.weapon_skin )

	ItemFlavor weapon = WeaponSkin_GetWeaponFlavor( item )

	entity refEnt = file.weaponOverviewRefEnt
	vector origin = refEnt.GetOrigin() + <-25, 0, 29.6>
	vector angles = refEnt.GetAngles() + <4, -15, 15> + MainWeapon_GetLoadoutOverviewRotation( weapon )

	asset modelAsset = WeaponSkin_GetViewModel( item )
	float modelScale = 1.0

	ModelData_SetBaseOrigin( file.weaponOverviewModelData, origin )

	vector modelOffset = < 0,0,0 >
	
	entity cameraTarget = file.cameraTargets[ eCameraTargetNames.weapon_mastery_inspect_camera_target ]
	vector baseOffset = GetWeaponOffsetFromCameraToOrigin( cameraTarget, < 0,0,0 >, ModelData_GetBaseOrigin( file.weaponOverviewModelData ), WeaponItemFlavor_GetOverviewOffset( weapon ) )
	file.weaponVectorScale = WeaponItemFlavor_GetOverviewVectorScale( weapon )
	modelOffset = baseOffset * file.weaponVectorScale

	UpdateModelsforWeaponOverview( origin + modelOffset, angles, angles, modelAsset, modelScale )

	entity model = ModelData_GetModel( file.weaponOverviewModelData )
	model.Anim_SetPaused( true )
	WeaponCosmetics_Apply( model, item, null )

	vector extraRotation = <11, -45, 0>
	vector originOffset = GetAttachmentOriginOffset( model, "MENU_ROTATE", extraRotation )
	model.SetLocalOrigin( originOffset )
	model.SetLocalAngles( extraRotation )

	const vector extraLightRigRotation = <0, 0, 45> 
	UpdateWeaponLights( model, WEAPON_LIGHT_RIG_OFFSET + extraLightRigRotation, item )
	UpdateReactiveWeaponModel( item, weapon, model )

	if ( ItemFlavor_GetQuality( item ) == eRarityTier.MYTHIC )
		model.SetPoseParameter( MYTHIC_301_LOBBY_POSE_PARAM, 1.0 )

	asset animSeq = WeaponSkin_GetMenuAnimSeq( item )
	if ( animSeq != $"" )
		model.Anim_Play( animSeq )
}

void function UpdateModelsforWeaponOverview( vector origin, vector moverAngles, vector modelAngles, asset modelAsset, float modelScale )
{
	ModelData_SetBaseOrigin( file.weaponOverviewModelData, origin )
	ModelData_SetBaseAngles( file.weaponOverviewModelData, moverAngles )
	entity model = CreateMenuModel( file.weaponOverviewModelData, modelAsset )
	if ( IsValid( file.weaponOverviewModelData.mover ) )
	{
		file.weaponOverviewModelData.mover.Destroy()
		ModelData_CreateMover( file.weaponOverviewModelData )
	}
	ModelData_SetBaseAngles( file.weaponOverviewModelData, modelAngles )
	model.SetModelScale( modelScale )
}

void function UpdateModelsforMeleeInspect( vector origin, vector moverAngles, vector modelAngles, asset modelAsset, float modelScale )
{
	ModelData_SetBaseOrigin( file.meleeInspectModelData, origin )
	ModelData_SetBaseAngles( file.meleeInspectModelData, moverAngles )
	entity model = CreateMenuModel( file.meleeInspectModelData, modelAsset )
	if ( IsValid( file.meleeInspectModelData.mover ) )
	{
		file.meleeInspectModelData.mover.Destroy()
		ModelData_CreateMover( file.meleeInspectModelData )
	}
	ModelData_SetBaseAngles( file.meleeInspectModelData, modelAngles )
	model.SetModelScale( modelScale )
}

void function UpdateMeleeInspectDisplay( ItemFlavor item )
{
	
	

	Assert( ItemFlavor_GetType( item ) == eItemType.melee_skin )

	ItemFlavor meleeWeapon = Melee_GetWeaponForSkin( item )
	entity refEnt = file.meleeInspectRefEnt
	vector origin = refEnt.GetOrigin() + <-10, 0, 42> + MeleeWeapon_GetItemInspectOffset( meleeWeapon )
	vector angles = refEnt.GetAngles()

	asset modelAsset = MeleeSkin_GetMenuModel( item )

	float inspectVectorScale = MeleeWeapon_GetInspectVectorScale( meleeWeapon )
	if ( inspectVectorScale != 0.0 )
	{
		UpdateModelsforMeleeInspect( origin, angles, angles, modelAsset, 1.0 )

		int cameraTargetIndex = eCameraTargetNames.customize_character_camera_target
		vector cameraOrigin = file.cameraStartOriginsAngles[ cameraTargetIndex ]["origin"]
		vector baseOffset = GetWeaponOffsetFromCameraPositionToOrigin( cameraOrigin, ModelData_GetBaseOrigin( file.meleeInspectModelData ), <0, 0, 0> )
		vector modelOffset = baseOffset * inspectVectorScale
		file.meleeInspectModelData.mover.SetOrigin( ModelData_GetBaseOrigin( file.meleeInspectModelData ) + modelOffset )
	}
	else
	{
		float modelScale = MeleeWeapon_GetItemInspectScale( meleeWeapon ) * 4.444444
		UpdateModelsforMeleeInspect( origin, angles, angles, modelAsset, modelScale )
	}

	entity model = ModelData_GetModel( file.meleeInspectModelData )

	vector extraRotation = MeleeWeapon_GetMenuModelRotation( meleeWeapon )
	vector originOffset = GetAttachmentOriginOffset( model, "MENU_ROTATE", extraRotation )
	model.SetLocalOrigin( originOffset )
	model.SetLocalAngles( extraRotation )

	if ( Artifacts_Loadouts_IsConfigPointerItemFlavor( item ) )
	{
		entity lcPlayer = GetLocalClientPlayer()

		if ( lcPlayer.p.artifactConfig == null )
			return

		ArtifactConfig artifactConfig = expect ArtifactConfig( lcPlayer.p.artifactConfig )

		int setIndex = eArtifactSetIndex._EMPTY
		if ( !Artifacts_IsEmptyComponent( artifactConfig.theme ) )
			setIndex = Artifacts_GetSetIndex( artifactConfig.theme )
		else
			setIndex = Artifacts_GetSetIndex( artifactConfig.blade )

		Assert( setIndex != eArtifactSetIndex._EMPTY )

		Artifacts_Loadouts_ApplyModelForSet( model, setIndex )
		Artifacts_Loadouts_PreviewBladeAndPowerSource( model, artifactConfig.blade, artifactConfig.powerSource )
		Artifacts_Loadouts_PreviewTheme( model, artifactConfig.theme )
	}

	asset animSeq = MeleeSkin_GetMenuInspectAnimSeq( item )
	if ( animSeq != $"" )
		model.Anim_Play( animSeq )
	model.Anim_Stop()

	string skinName = MeleeSkin_GetSkinName( item )
	if ( skinName != "" )
	{
		int skinIdx = model.GetSkinIndexByName( skinName )
		if ( skinIdx != -1 )
			model.SetSkin( skinIdx )
	}

	if ( inspectVectorScale != 0.0 )
		UpdateWeaponLights( model, WEAPON_LIGHT_RIG_OFFSET + WEAPON_LIGHT_RIG_OFFSET, meleeWeapon )
}

void function UpdateStoreItemDisplay_WeaponCharm( ItemFlavor item )
{
	Assert( ItemFlavor_GetType( item ) == eItemType.weapon_charm )

	const vector WEAPON_CHARM_ANGLES = <-5, -140, -2>

	entity refEnt = file.storeInspectRefEnt
	vector angles = refEnt.GetAngles() + <-7, 1, -3>
	vector origin = refEnt.GetOrigin() + <4, 0, 39.6> + -3.6 * AnglesToRight( angles )

	const float modelScale = 9.333333

	UpdateModelsforStoreItem( origin, angles, AnglesCompose( angles, WEAPON_CHARM_ANGLES ), $"mdl/techart/mshop/weapons/class/smg/alternator/alternator_base_v.rmdl", modelScale )

	entity weaponEnt = ModelData_GetModel( file.storeInspectModelData )
	weaponEnt.SetSkin( weaponEnt.GetSkinIndexByName( "