		Assert( clGlobal.onWeaponAttackCallbacks.contains( callbackFunc ), "Callback " + string( callbackFunc ) + " doesn't exist" )
		clGlobal.onWeaponAttackCallbacks.fastremovebyvalue( callbackFunc )

}

bool function CodeCallback_CanDeflectProjectile( entity collidingEntity, entity projectile, vector hitPos )
{
	if ( file.canDeflectProjectileCallback == null )
		return false

	return file.canDeflectProjectileCallback( collidingEntity, projectile, hitPos )
}

void function SetCallback_CanDeflectProjectile( bool functionref( entity collidingEntity, entity projectile, vector hitPos ) callbackFunc )
{
	Assert( file.canDeflectProjectileCallback == null, format( "%s - canDeflectProjectileCallback is already set", FUNC_NAME() ) )
