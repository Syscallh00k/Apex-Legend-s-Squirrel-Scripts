bool function LootPoolBrowser_IsEnabled()
{
	return GetCurrentPlaylistVarBool( "loot_pool_browser_enabled", true )
}

bool function GRXPack_ValidateLootPoolBrowserConfig( ItemFlavor flav )
{
	Assert( ItemFlavor_GetType( flav ) == eItemType.account_pack )

	if ( !GRXPack_GetIsLootPoolBrowsable( flav ) )
	{
		return true
	}

	bool isValid = true

	
	
	array< asset > completionRewardPool = []
	array< asset > mainPool             = []
	foreach ( var mainPoolBlock in IterateSettingsAssetArray( ItemFlavor_GetAsset( flav ), "packContents" ) )
	{
		mainPool.append( GetSettingsBlockAsset( mainPoolBlock, "flavor" ) )
	}

	foreach ( var poolBlock in IterateSettingsAssetArray( ItemFlavor_GetAsset( flav ), "completionRewards" ) )
	{
		asset iterPoolAsset = GetSettingsBlockAsset( poolBlock, "flavor" )

		if ( completionRewardPool.contains( iterPoolAsset ) )
		{
			Assert( false, format( "Duplicate flav (%s) found in pool flav (%s) - completion pools cannot contain duplicates", string( iterPoolAsset ), ItemFlavor_GetAssetString( flav ) ) )
			isValid = false
		}

		completionRewardPool.append( iterPoolAsset )

		if ( mainPool.contains( iterPoolAsset ) )
		{
			Assert( false, format( "Completion pool item (%s) found in main pool flav: %s", string( iterPoolAsset ), ItemFlavor_GetAssetString( flav ) ) )
			isValid = false
		}
	}

	
	table< string, float > rarityMap = {}
	array< asset > specificDroprateAssets = []
	const array< string > rarityCategoryKeys = [ "COMMON", "RARE", "EPIC", "LEGENDARY", "MYTHIC" ]
	foreach ( var poolRarityBlock in IterateSettingsAssetArray( ItemFlavor_GetAsset( flav ), "poolRarities" ) )
	{
		string rarityKey = GetSettingsBlockString( poolRarityBlock, "rarity" )
		Assert( rarityKey in eRarityTier || rarityKey == "SPECIFIC_FLAV", "Invalid rarity tier key: " + rarityKey )

		if ( rarityCategoryKeys.contains( rarityKey ) )
		{
			if ( rarityKey in rarityMap )
			{
				Assert( false, format( "Duplicate rarity defined in loot pool rarity config (%s) for pack pool: %s", rarityKey, ItemFlavor_GetAssetString( flav ) ) )
				isValid = false
			}
		}
		else
		{
			asset droprateAsset = GetSettingsBlockAsset( poolRarityBlock, "specificDroprateFlav" )
			if ( specificDroprateAssets.contains( droprateAsset ) )
			{
				Assert( false, format( "Duplicate specific flav defined in loot pool rarity config (%s) for pack pool: %s", string( droprateAsset ), ItemFlavor_GetAssetString( flav ) ) )
				isValid = false
			}

			specificDroprateAssets.append( droprateAsset )

			if ( !mainPool.contains( droprateAsset ) )
			{
				Assert( false, format( "Specific droprate asset (%s) was not found in the main loot pool on: %s", string( droprateAsset ), ItemFlavor_GetAssetString( flav ) ) )
				isValid = false
			}
		}

		float rarityDroprate = GetSettingsBlockFloat( poolRarityBlock, "droprate" )
		if ( !( rarityDroprate > 0.0 && rarityDroprate <= 100.0 ) )
		{
			Assert( false, format( "Rarity tier (%s) in flav (%s) is invalid: %d - must be >0 and <= 100", rarityKey, ItemFlavor_GetAssetString( flav ), rarityDroprate ) )
			isValid = false
		}

		rarityMap[ rarityKey ] <- rarityDroprate
	}

	
	float total = 0.0
	foreach ( string rarity, float droprate in rarityMap )
	{
		total += droprate
	}

	if ( total != 100.0 )
	{
		Assert( false, format( "Rarity configuration does not add up to 100 in flav: %s", ItemFlavor_GetAssetString( flav ) ) )
		isValid = false
	}

	
	if ( GetGlobalSettingsBool( ItemFlavor_GetAsset( flav ), "hasBackfillDefined" ) )
	{
		table< string, asset > backfillPools = {}
		foreach ( var backfillBlock in IterateSettingsAssetArray( ItemFlavor_GetAsset( flav ), "backfillPoolContents" ) )
		{
			string category = GetSettingsBlockString( backfillBlock, "category" )
			asset backfillFlav = GetSettingsBlockAsset( backfillBlock, "backfillPool" )

			
			if ( category in backfillPools )
			{
				Assert( false, format( "Duplicate category entry found: %s in asset: %s", category, ItemFlavor_GetAssetString( flav ) ) )
				isValid = false
			}

			backfillPools[ category ] <- backfillFlav
		}

		if ( backfillPools.len() == 0 )
		{
			Assert( false, format( "Backfill was enabled for pack (%s) but no backfill configurations were found.", ItemFlavor_GetAssetString( flav ) ) )
			isValid = false
		}
	}

	return isValid
}

int function GRXPack_GetPackSort( ItemFlavor flav )
{
	Assert( ItemFlavor_GetType( flav ) == eItemType.account_pack )
	Assert( GRXPack_GetIsLootPoolBrowsable( flav ) )

	string sortKey = GetGlobalSettingsString( ItemFlavor_GetAsset( flav ), "packSort" )
	Assert( sortKey in eLootPoolBrowserSortOrder )

	return eLootPoolBrowserSortOrder[ sortKey ]
}

bool function GRXPack_GetIsLootPoolBrowsable( ItemFlavor flav )
{
	Assert( ItemFlavor_GetType( flav ) == eItemType.account_pack )

	
	if ( !LootPoolBrowser_IsEnabled() )
		return false

	return GetGlobalSettingsBool( ItemFlavor_GetAsset( flav ), "isLootPoolBrowsable" )
}

array< ItemFlavor > function GRXPack_GetCompletionRewards( ItemFlavor flav, int sort )
{
	Assert( ItemFlavor_GetType( flav ) == eItemType.account_pack )
	Assert( GRXPack_GetIsLootPoolBrowsable( flav ) )

	array< ItemFlavor > contents = []
	foreach ( var poolBlock in IterateSettingsAssetArray( ItemFlavor_GetAsset( flav ), "completionRewards" ) )
	{
		asset iterPoolAsset = GetSettingsBlockAsset( poolBlock, "flavor" )
		Assert( IsValidItemFlavorSettingsAsset( iterPoolAsset, eValidation.ASSERT ) )

		contents.append( GetItemFlavorByAsset( iterPoolAsset ) )
	}

	SortItemFlavorArray( contents, sort )
	return contents
}

int function GRXPack_GetCompletionRewardType( ItemFlavor packFlav )
{
	Assert( ItemFlavor_GetType( packFlav ) == eItemType.account_pack )
	Assert( GRXPack_GetIsLootPoolBrowsable( packFlav ) )

	string type = GetGlobalSettingsString( ItemFlavor_GetAsset( packFlav ), "completionRewardType" )
	Assert( type in eLootPoolBrowserRewardType )

	return eLootPoolBrowserRewardType[ type ]
}

string function GRXPack_GetCompletionRewardSequenceString( ItemFlavor pack )
{
	Assert( ItemFlavor_GetType( pack ) == eItemType.account_pack )
	Assert( GRXPack_GetIsLootPoolBrowsable( pack ) )

	return GetGlobalSettingsString( ItemFlavor_GetAsset( pack ), "completionRewardSequenceRef" )
}

string function GRXPack_GetPackOpenProgressRewardSequenceString( ItemFlavor pack )
{
	Assert( ItemFlavor_GetType( pack ) == eItemType.account_pack )

	return GetGlobalSettingsString( ItemFlavor_GetAsset( pack ), "packOpenProgressRewardSequenceRef" )
}

asset function GRXPack_GetCompletionRewardAsset( ItemFlavor pack )
{
	Assert( ItemFlavor_GetType( pack ) == eItemType.account_pack )

	return GetGlobalSettingsAsset( ItemFlavor_GetAsset( pack ), "completionRewardAsset" )
}

bool function GRXPack_GetIsBackfillEnabled( ItemFlavor flav )
{
	Assert( ItemFlavor_GetType( flav ) == eItemType.account_pack )
	return GetGlobalSettingsBool( ItemFlavor_GetAsset( flav ), "hasBackfillDefined" )
}

array< ItemFlavor > function GRXPack_GetBackfillPool( ItemFlavor flav, int category, int sort )
{
	Assert( ItemFlavor_GetType( flav ) == eItemType.account_pack )
	Assert( GRXPack_GetIsLootPoolBrowsable( flav ) )

	if ( !GRXPack_GetIsBackfillEnabled( flav ) )
	{
		return []
	}

	table< int, ItemFlavor > categoryPoolMap = {}
	foreach ( var backfillBlock in IterateSettingsAssetArray( ItemFlavor_GetAsset( flav ), "backfillPoolContents" ) )
	{
		asset iterPoolAsset = GetSettingsBlockAsset( backfillBlock, "flavor" )
		Assert( IsValidItemFlavorSettingsAsset( iterPoolAsset, eValidation.ASSERT ) )

		string categoryKey = GetSettingsBlockString( backfillBlock, "category" )
		if ( !(categoryKey in eBackfillPoolCategory) )
		{
			Assert( false, format