void function Newness_MarkItemAsNewAndInformServer( ItemFlavor flavor )
{
	Assert( IsItemFlavorStructValid( flavor.guid, eValidation.ASSERT ) )
	if ( !ItemForGUIDSupportsNewness( ItemFlavor_GetGUID( flavor ) ) )
	{
		return
	}

#if DEBUG_NEWNESS
		string assetName = ItemFlavor_GetAssetName( flavor )

			printt( "DEBUG_NEW: Client Newness_MarkItemAsNewAndInformServer with itemFlav = " + assetName )



#endif

	SettingsAssetGUID guid = ItemFlavor_GetGUID( flavor )
	Remote_ServerCallFunction( "ClientCallback_Newness_MarkAsNew", guid )


		RunUIScript( "Wishlist_UpdateCachedOwnershipAsOwned", guid )



}







































































































































































































bool function AreQueryStructsIdentical( Newness_Query qa, Newness_Query qb )
{
	if ( qa == qb )
		return true 

	if ( qa.cb != qb.cb )
		return false

	if ( qa.uiCategory != qb.uiCategory )
		return false

	if ( qa.panelOrButton != qb.panelOrButton )
		return false

	if ( qa.itemFlavor != qb.itemFlavor )
		return false

	if ( qa.itemTypeList.len() != qb.itemTypeList.len() )
		return false

	foreach ( int type in qa.itemTypeList )
	{
		if ( !qb.itemTypeList.contains( type ) )
			return false
	}

	return true
}


bool function ItemForGUIDSupportsNewness( int guid )
{
	bool isValidForNewness = IsValidItemFlavorGUID( guid )
	if ( isValidForNewness )
	{
		int storedItemType = ItemFlavor_GetType( GetItemFlavorByGUID( guid ) )
		isValidForNewness = ItemFlavor_IsEquippableCosmeticType( storedItemType ) && !(COSMETIC_ITEM_TYPES_THAT_DO_NOT_SUPPORT_NEWNESS.contains( storedItemType ))
	}
	return isValidForNewness
}



























































































































