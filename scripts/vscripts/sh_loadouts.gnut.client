void function RequestSetItemFlavorLoadoutSlot_AllLegends( EHI playerEHI, LoadoutEntry entry, ItemFlavor itemFlavor )
{
	Assert( entry.category == eLoadoutCategory.GCARD_TRACKER_ART )

	_Shared_RequestSetItemFlavorLoadoutSlot( playerEHI, entry, itemFlavor, true )
}

void function RequestSetItemFlavorLoadoutSlot_WithDuplicatePrevention( EHI playerEHI, array<LoadoutEntry> loadoutEntries, ItemFlavor itemFlavor, int slotIndex = 0 )
{
	if ( GetCurrentPlaylistVarBool( "use_server_duplicate_loadout_verification", true ) && loadoutEntries.len() > 1 && loadoutEntries.len() <= 3 )
	{
		RequestSetItemFlavorLoadoutSlot_WithBadgeDuplicatePrevention( playerEHI, loadoutEntries, itemFlavor, slotIndex )
	}
	else
	{
		if ( loadoutEntries.len() > 1 )
		{
			
			LoadoutEntry oldSlot
			ItemFlavor itemInCurrentSlot = LoadoutSlot_GetItemFlavor( LocalClientEHI(), loadoutEntries[ slotIndex ] )

			foreach ( loadoutEntry in loadoutEntries )
			{
				ItemFlavor item = LoadoutSlot_GetItemFlavor( LocalClientEHI(), loadoutEntry )
				if ( item == itemFlavor )
				{
					RequestSetItemFlavorLoadoutSlot( LocalClientEHI(), loadoutEntry, itemInCurrentSlot )
					break
				}
			}
		}
		RequestSetItemFlavorLoadoutSlot( LocalClientEHI(), loadoutEntries[ slotIndex ], itemFlavor )
	}
}

void function RequestSetItemFlavorLoadoutSlot_WithBadgeDuplicatePrevention( EHI playerEHI, array<LoadoutEntry> loadoutEntries, ItemFlavor itemFlavor, int slotIndex = 0 )
{
	if ( !loadoutEntries.isvalidindex( slotIndex ) )
		return
	LoadoutEntry entry = loadoutEntries[ slotIndex ]

#if LOADOUTS_DBG_WRITES
		DEV_LoadoutsDebug( entry )
#endif









	Assert( playerEHI == LocalClientEHI(), "Tried to use RequestSetLoadoutSlot on a different player" )
	int slotContentsIndex = ConvertItemFlavorToLoadoutSlotContentsIndex( entry, itemFlavor )

	if ( !IsContentsIndexValidForLoadoutSlot( playerEHI, entry, slotContentsIndex, eValidation.DONT_ASSERT ) )
	{
		Assert( false, format( "Failed IsContentsIndexValidForLoadoutSlot. Entry=%s , itemFlavor=%s", entry.id, ItemFlavor_GetAssetName( itemFlavor ) ) )
	}
	else
	{
		Assert( loadoutEntries.len() <= 3, "RequestSetItemFlavorLoadoutSlot_WithBadgeDuplicatePrevention only support up to 3 entries" )
		array<int> otherEntryIdx = [-1, -1]
		int cnt = 0
		for( int i = 0; i < loadoutEntries.len(); i++ )
		{
			if ( i != slotIndex )
			{
				otherEntryIdx[cnt] = loadoutEntries[i].entryIndex
				cnt++
			}
		}
		Remote_ServerCallFunction( "ClientCallback_loadouts_swap_set", entry.entryIndex, otherEntryIdx[0], otherEntryIdx[1], slotContentsIndex )
	}
}

void function RequestSetItemFlavorLoadoutSlot( EHI playerEHI, LoadoutEntry entry, ItemFlavor itemFlavor )
{
	_Shared_RequestSetItemFlavorLoadoutSlot( playerEHI, entry, itemFlavor, false )
}

void function _Shared_RequestSetItemFlavorLoadoutSlot( EHI playerEHI, LoadoutEntry entry, ItemFlavor itemFlavor, bool setForAllLegends )
{
#if LOADOUTS_DBG_WRITES
		DEV_LoadoutsDebug( entry )
#endif









	Assert( playerEHI == LocalClientEHI(), "Tried to use RequestSetLoadoutSlot on a different player" )
	int slotContentsIndex = ConvertItemFlavorToLoadoutSlotContentsIndex( entry, itemFlavor )

	if ( !IsContentsIndexValidForLoadoutSlot( playerEHI, entry, slotContentsIndex, eValidation.DONT_ASSERT ) )
	{
		Assert( false, format( "Failed IsContentsIndexValidForLoadoutSlot. Entry=%s , itemFlavor=%s", entry.id, ItemFlavor_GetAssetName( itemFlavor ) ) )
	}
	else
	{
		Remote_ServerCallFunction( "ClientCallback_loadouts_set", entry.entryIndex, slotContentsIndex, setForAllLegends )
	}
}

